        function renderManagerSidebar(players) {
            const container = document.getElementById('sidebarContent');
            container.innerHTML = '';
            const humans = players.filter(p => !p.bot_name);
            humans.forEach(p => {
                const readyBadge = p.is_ready ? `<span class="bg-emerald-500/20 text-emerald-400 text-xs font-bold px-2 py-0.5 rounded border border-emerald-500/30">✓</span>` : `<span class="bg-slate-700 text-slate-400 text-xs font-bold px-2 py-0.5 rounded">...</span>`;
                container.innerHTML += `
                    <div class="bg-[#1e2328] p-3 rounded-sm border border-[#c8aa6e]/30 flex justify-between items-center">
                        <div class="flex items-center gap-2">
                            <img src="${getUserAvatar(p.username, true)}" class="w-6 h-6 border border-[#c8aa6e]/50">
                            <span class="font-bold text-slate-200 text-sm">${p.username}</span>
                        </div>
                        ${readyBadge}
                    </div>`;
            });
        }
        
        function drawTeamOnMap(teamPlayersArr, side) {
            const getPlayer = (role) => teamPlayersArr.find(p => p.ingame_role === role);
            ['TOP', 'JUNGLE', 'MID', 'ADC', 'SUPPORT'].forEach(role => {
                const node = document.getElementById(`node-${role}-${side}`);
                if (!node) return;
                const player = getPlayer(role);
                if (player) {
                    node.classList.remove('hidden');
                    node.innerHTML = `
                        <div class="map-node-filled flex flex-col items-center">
                            <img src="${getEsportImage(player.name, false, player.season)}" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="object-cover object-top" alt="${player.name}">
                            <div class="badge">
                                <span class="text-white block">${player.name}</span>
                                <span class="text-slate-400 text-[0.55rem] font-mono leading-none">${player.season}</span>
                            </div>
                        </div>
                    `;
                } else { node.classList.add('hidden'); }
            });
        }

        function renderBracket(matches) {
            const area = document.getElementById('bracketArea');
            const container = document.getElementById('bracketContainer');
            
            area.classList.remove('hidden');
            area.classList.add('flex');
            
            const quarters = matches.filter(m => m.match_type === 'QUARTER');
            const semis = matches.filter(m => m.match_type === 'SEMI'); 
            const final = matches.filter(m => m.match_type === 'FINAL');
            
            const getMatchBox = (m, isFinal = false) => {
                if (!m) {
                    return `
                        <div class="hex-bg border border-[#c8aa6e]/20 p-${isFinal ? '4' : '2'} rounded-sm text-center text-${isFinal ? 'sm' : '[0.65rem]'} font-bold flex flex-col justify-center shadow-md">
                            <span class="text-slate-600">TBD</span>
                            <span class="text-[0.55rem] text-slate-700 italic font-normal my-0.5">vs</span>
                            <span class="text-slate-600">TBD</span>
                        </div>`;
                }
                const t1 = m.team1_name || 'TBD';
                const t2 = m.team2_name || 'TBD';
                const c1 = m.winner_name === t1 ? 'text-emerald-400' : (m.winner_name ? 'text-slate-500' : 'text-slate-300');
                const c2 = m.winner_name === t2 ? 'text-emerald-400' : (m.winner_name ? 'text-slate-500' : 'text-slate-300');
                const borderColor = isFinal ? 'border-gold shadow-[0_0_15px_rgba(200,170,110,0.2)]' : (m.match_type === 'SEMI' ? 'border-blue-500/50' : 'hex-border');
                return `
                    <div class="hex-bg border ${borderColor} p-${isFinal ? '4' : '2'} rounded-sm text-center text-${isFinal ? 'sm' : '[0.65rem]'} font-bold flex flex-col justify-center shadow-md">
                        <span class="${c1} truncate">${t1}</span>
                        <span class="text-[0.55rem] text-slate-500 italic font-normal my-0.5">vs</span>
                        <span class="${c2} truncate">${t2}</span>
                    </div>`;
            };

            let html = `<div class="flex-1 space-y-3 flex flex-col justify-around">`;
            for(let i=0; i<4; i++) html += getMatchBox(quarters[i]);
            html += `</div><div class="flex flex-col justify-around gap-4 flex-1">`;
            for(let i=0; i<2; i++) html += getMatchBox(semis[i]);
            html += `</div><div class="flex flex-col justify-center flex-1">`;
            html += getMatchBox(final[0], true);
            html += `</div>`;
            
            container.innerHTML = html;
        }

        socket.on('match_simulated_event', (data) => {
            if (isTournamentEnded) return;
            document.getElementById('matchStatusText').classList.add('hidden');
            document.getElementById('matchWinnerDisplay').classList.add('hidden');
            document.getElementById('fastForwardGroup').classList.add('hidden');
            document.getElementById('nextMatchBtn').classList.add('hidden');
            
            const badge = document.getElementById('matchGroupBadge');
            badge.classList.remove('hidden'); badge.innerText = data.isBO5 ? `${data.group} - Game ${data.gameNumber}` : data.group;
            
            const teamsDisplay = document.getElementById('matchTeamsDisplay');
            teamsDisplay.classList.remove('hidden'); teamsDisplay.classList.add('flex');
            
            document.getElementById('matchTeam1Img').src = getUserAvatar(data.team1, true);
            document.getElementById('matchTeam2Img').src = getUserAvatar(data.team2, true);

            const t1El = document.getElementById('matchTeam1'); const t2El = document.getElementById('matchTeam2');
            t1El.innerText = data.team1; t2El.innerText = data.team2;
            t1El.className = "text-2xl esport-font tracking-wider truncate w-full text-right text-slate-300 transition-colors duration-500";
            t2El.className = "text-2xl esport-font tracking-wider truncate w-full text-left text-slate-300 transition-colors duration-500";
            
            if (data.isBO5) {
                document.getElementById('bo5ScoreDisplay').classList.remove('hidden');
                document.getElementById('scoreT1').innerText = (data.winner === data.team1) ? data.score1 - 1 : data.score1;
                document.getElementById('scoreT2').innerText = (data.winner === data.team2) ? data.score2 - 1 : data.score2;
            } else { document.getElementById('bo5ScoreDisplay').classList.add('hidden'); }

            const logEl = document.getElementById('playByPlayLog');
            logEl.innerHTML = ''; logEl.classList.remove('hidden');

            const isMyTeamInvolved = (USER_ID === data.t1_user_id || USER_ID === data.t2_user_id);
            const myTeamId = (USER_ID === data.t1_user_id) ? data.team1_id : data.team2_id;
            
            if (isMyTeamInvolved) {
                document.getElementById('mapTitle').innerText = "AKTUÁLIS MÉRKŐZÉS";
                if (USER_ID === data.t1_user_id) { drawTeamOnMap(data.t1_players, 1); drawTeamOnMap(data.t2_players, 2); } 
                else { drawTeamOnMap(data.t2_players, 1); drawTeamOnMap(data.t1_players, 2); }
            } else {
                document.getElementById('mapTitle').innerText = "SAJÁT FELÁLLÁS";
                ['TOP', 'JUNGLE', 'MID', 'ADC', 'SUPPORT'].forEach(r => document.getElementById(`node-${r}-2`).classList.add('hidden'));
            }

            // Ha gyorsításról van szó, 0 lesz a delay, így azonnal kirajzolja a teljes felületet és gombokat
            let delay = 0;
            let stepDelay = data.isFastForward ? 0 : 1500;

            data.actionLogs.forEach((logObj, index) => {
                setTimeout(() => {
                    if (isTournamentEnded) return;
                    const p = document.createElement('p');
                    p.className = 'transition-opacity duration-500 font-medium tracking-wide flex gap-2 items-start';
                    if (!data.isFastForward) p.classList.add('opacity-0');
                    
                    let colorClass = 'text-[#c8aa6e]';
                    if (isMyTeamInvolved && logObj.favoredTeamId) { colorClass = (logObj.favoredTeamId === myTeamId) ? 'text-emerald-400' : 'text-red-400'; } 
                    else if (!isMyTeamInvolved && logObj.favoredTeamId) { colorClass = (logObj.favoredTeamId === data.team1_id) ? 'text-blue-300' : 'text-purple-300'; }

                    p.classList.add(colorClass); 
                    p.innerHTML = `<span class="mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 12l10 10 10-10L12 2zm0 3.8l6.2 6.2-6.2 6.2-6.2-6.2L12 5.8z"/></svg></span> <span>${logObj.text}</span>`;
                    logEl.appendChild(p); 
                    
                    if (!data.isFastForward) setTimeout(() => p.classList.remove('opacity-0'), 50);

                    if (index === data.actionLogs.length - 1) {
                        setTimeout(() => {
                            if (isTournamentEnded) return;
                            const winnerDisplay = document.getElementById('matchWinnerDisplay'); winnerDisplay.classList.remove('hidden');
                            document.getElementById('winnerText').innerText = data.winner;

                            if (data.isBO5) { document.getElementById('scoreT1').innerText = data.score1; document.getElementById('scoreT2').innerText = data.score2; }

                            if (data.isSeriesFinished) {
                                document.getElementById('winnerTextLabel').innerText = "🏆 GYŐZTES:";
                                if (data.team1 === data.winner) { t1El.classList.add('text-emerald-400'); t2El.classList.add('text-slate-600'); } 
                                else { t1El.classList.add('text-slate-600'); t2El.classList.add('text-emerald-400'); }
                            } else { document.getElementById('winnerTextLabel').innerText = "Game győztes:"; }

                            if (data.newState) { updateLobbyStateUI(data.newState); }
                        }, data.isFastForward ? 0 : 1000);
                    }
                }, delay);
                delay += stepDelay; 
            });
        });

        socket.on('tournament_winner', (data) => {
            isTournamentEnded = true;
            document.getElementById('hostControls').classList.add('hidden');
            document.getElementById('nextMatchBtn').classList.add('hidden');
            document.getElementById('studioMatchBox').classList.add('hidden');
            
            document.getElementById('sidebarContainer').classList.add('hidden');
            document.getElementById('leftMapArea').classList.add('hidden');
            document.getElementById('centerArea').classList.replace('xl:col-span-2', 'xl:col-span-4');
            
            document.getElementById('championArea').classList.remove('hidden');
            document.getElementById('championArea').classList.add('flex');
            document.getElementById('championName').innerText = data.winner;
            document.getElementById('championLogo').src = getUserAvatar(data.winner, true);

            const stContainer = document.getElementById('standingsContainer');
            stContainer.innerHTML = ''; 
            data.standings.forEach(st => {
                let cssClass = "bg-[#1e2328] border-[#c8aa6e]/30";
                if (st.rank === '1.') cssClass = "bg-gradient-to-r from-amber-900/40 to-transparent border-amber-500";
                else if (st.rank === '2.') cssClass = "bg-gradient-to-r from-slate-600/40 to-transparent border-slate-400";
                else if (st.rank === 'Top 4') cssClass = "bg-gradient-to-r from-orange-900/40 to-transparent border-orange-700";

                stContainer.innerHTML += `
                    <div class="flex items-center p-3 rounded-sm mb-2 shadow border ${cssClass}">
                        <span class="font-mono w-10 text-center ${st.rankColor} font-bold">${st.rank}</span>
                        <img src="${getUserAvatar(st.name, true)}" class="w-8 h-8 border border-[#c8aa6e]/50 mx-3">
                        <span class="flex-1 ${st.nameColor} truncate tracking-wide">${st.name}</span>
                    </div>
                `;
            });

            document.getElementById('finalGroupTablesArea').classList.remove('hidden');
            document.getElementById('finalGroupTablesArea').classList.add('flex');
            renderGroupTables(data.newState.players, 'finalGroupTablesContainer', 'final');
            
            if (data.newState && data.newState.bracket) {
                renderBracket(data.newState.bracket);
            }
        });

        function transitionToSimulation() {
            document.getElementById('lobbyTitle').innerText = "KÖZVETÍTÉS";
            document.getElementById('startArea').classList.add('hidden');
            document.getElementById('teamsAreaPhase1').classList.add('hidden');
            document.getElementById('teamsAreaPhase2').classList.add('hidden');
            document.getElementById('waitingArea').classList.add('hidden');
            
            document.getElementById('simulationStudio').classList.remove('hidden'); 
            document.getElementById('simulationStudio').classList.add('flex');
            document.getElementById('sidebarTitle').innerText = "CSOPORTÁLLÁSOK";

            if (USER_ID === CURRENT_HOST_ID) {
                document.getElementById('hostControls').classList.remove('hidden');
                document.getElementById('hostControls').classList.add('flex');
                document.getElementById('nextMatchBtn').classList.remove('hidden');
            }
        }

        function triggerNextMatch() {
            const btn = document.getElementById('nextMatchBtn');
            btn.disabled = true; btn.classList.add('hidden'); document.getElementById('fastForwardGroup').classList.add('hidden');
            socket.emit('next_match_step', { lobbyId: LOBBY_ID, userId: USER_ID }, (res) => {
                if (res.status === 'phase_changed') {
                    btn.classList.remove('hidden'); btn.disabled = false;
                    document.getElementById('matchStatusText').innerText = `✨ ${res.message} ✨`; document.getElementById('matchStatusText').classList.remove('hidden');
                    document.getElementById('matchGroupBadge').classList.add('hidden'); document.getElementById('matchTeamsDisplay').classList.add('hidden'); document.getElementById('matchWinnerDisplay').classList.add('hidden'); document.getElementById('bo5ScoreDisplay').classList.add('hidden'); document.getElementById('playByPlayLog').classList.add('hidden');
                    
                    ['TOP', 'JUNGLE', 'MID', 'ADC', 'SUPPORT'].forEach(r => document.getElementById(`node-${r}-2`).classList.add('hidden'));
                    document.getElementById('mapTitle').innerText = "SAJÁT FELÁLLÁS";
                } else if (res.status === 'error') {
                    alert('Hiba történt a szerveren: ' + res.message);
                    btn.classList.remove('hidden'); btn.disabled = false;
                }
            });
        }

        function fastForward(mode) {
            document.getElementById('fastForwardGroup').classList.add('hidden');
            document.getElementById('nextMatchBtn').classList.add('hidden');
            socket.emit('fast_forward_matches', { lobbyId: LOBBY_ID, userId: USER_ID, mode: mode }, (res) => {});
        }
    </script>
</body>
</html>