<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Draft Aréna | LoL Worlds Mayhem</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style> 
        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&display=swap');

        /* Szigorú 100vh elrendezés */
        body, html { 
            height: 100vh; width: 100vw; margin: 0; padding: 0; overflow: hidden;
            background-color: #010a13; color: #f0e6d2; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        } 
        
        .esport-font { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        .cyber-font { font-family: 'Orbitron', sans-serif; }

        .hex-bg { background-color: #1e2328; }
        .hex-bg-hover:hover { background-color: #2b3137; border-color: #f0e6d2; }
        
        .hex-panel {
            background: linear-gradient(135deg, #091428 0%, #010a13 100%);
            border: 1px solid rgba(200, 170, 110, 0.3);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
            position: relative;
        }

        .corner-borders { position: relative; border: 1px solid rgba(200, 170, 110, 0.3); }
        .corner-borders::before, .corner-borders::after { content: ''; position: absolute; width: 8px; height: 8px; border: 1px solid #c8aa6e; transition: all 0.2s ease; }
        .corner-borders::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
        .corner-borders::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
        .corner-borders:hover::before, .corner-borders:hover::after { width: 12px; height: 12px; border-color: #f0e6d2; }

        /* Belső görgetősáv styler */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(200,170,110,0.3); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #c8aa6e; }

        /* --- HÁTTÉR CSILLAGOK --- */
        .star-container { background: radial-gradient(ellipse at bottom, #091428 0%, #010a13 100%); position: absolute; inset: 0; z-index: -1; pointer-events: none; overflow: hidden; }
        #stars, #stars2, #stars3 { background: transparent; }
        #stars { width: 1px; height: 1px; box-shadow: 501px 811px #c8aa6e, 1450px 1324px #fff, 1093px 1780px #fff, 1469px 678px #c8aa6e, 904px 741px #fff, 1160px 781px #fff, 1841px 1962px #fff, 1630px 1667px #fff, 1788px 676px #fff, 367px 1734px #fff, 1343px 156px #fff, 1283px 1142px #fff, 1062px 378px #fff, 1395px 467px #fff, 1017px 1891px #fff, 137px 1114px #fff, 1767px 1403px #fff, 1543px 11px #fff, 1078px 181px #fff, 1189px 1574px #fff, 1697px 1551px #fff, 439px 472px #fff, 1491px 677px #fff, 1364px 599px #fff, 34px 382px #fff, 1221px 1584px #c8aa6e, 1266px 1499px #fff, 169px 1907px #fff, 1219px 1125px #fff, 659px 18px #fff, 1731px 1959px #fff, 332px 1216px #fff, 1913px 788px #fff, 80px 712px #fff, 326px 1605px #fff, 574px 1502px #fff, 473px 1653px #fff, 404px 975px #fff, 322px 1797px #fff, 425px 1321px #fff, 1121px 1797px #fff, 731px 647px #fff, 891px 1584px #fff, 1523px 109px #fff, 1379px 244px #fff, 865px 1064px #fff, 493px 956px #fff, 624px 1380px #fff, 440px 619px #fff, 1630px 767px #fff; animation: animStar 50s linear infinite; }
        #stars2 { width: 2px; height: 2px; box-shadow: 1925px 1320px #fff, 693px 1778px #fff, 1016px 711px #c8aa6e, 1171px 563px #fff, 661px 1919px #fff, 1610px 44px #fff, 1275px 140px #fff, 1208px 1802px #fff, 1473px 1587px #fff, 11px 1117px #fff, 853px 1757px #fff, 1149px 937px #fff, 1353px 428px #fff, 270px 279px #fff, 258px 1404px #fff, 417px 1188px #fff, 286px 561px #fff, 393px 1765px #fff, 147px 881px #fff, 666px 1097px #fff, 1425px 1278px #fff, 806px 156px #c8aa6e, 1252px 561px #fff, 218px 52px #fff, 1371px 1980px #fff, 171px 745px #fff, 1424px 89px #fff, 137px 244px #fff, 939px 1922px #fff, 137px 1080px #fff, 1757px 50px #fff, 904px 536px #fff, 1938px 1001px #fff, 1172px 440px #fff, 72px 1475px #fff, 102px 121px #fff, 804px 1671px #fff, 1314px 270px #fff, 440px 1341px #fff, 1216px 511px #fff; animation: animStar 100s linear infinite; }
        #stars3 { width: 3px; height: 3px; box-shadow: 200px 981px #fff, 1731px 521px #fff, 132px 1039px #fff, 1888px 1547px #c8aa6e, 899px 1226px #fff, 1887px 580px #fff, 1548px 1092px #fff, 1626px 689px #fff, 254px 1072px #fff, 1684px 1211px #fff, 672px 1267px #fff, 939px 668px #fff, 1969px 645px #fff, 1126px 983px #fff, 457px 568px #fff, 476px 876px #fff, 829px 1896px #fff, 1364px 1846px #fff, 1507px 1120px #fff, 936px 1948px #fff, 1833px 832px #fff, 1424px 285px #fff, 1377px 1596px #fff, 432px 153px #fff, 1348px 1410px #fff, 1529px 954px #c8aa6e, 1102px 387px #fff, 264px 297px #fff, 811px 977px #fff, 1931px 673px #fff, 1734px 978px #fff; animation: animStar 150s linear infinite; }
        @keyframes animStar { from { transform: translateY(0px); } to { transform: translateY(-2000px); } }

        /* --- MAP STYLES --- */
        .sr-map {
            background-image: url('/map.png');
            background-size: cover;
            background-position: center;
            border: 2px solid #c8aa6e; box-shadow: 0 0 20px rgba(200, 170, 110, 0.15);
        }
        
        .map-node { position: absolute; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; z-index: 10; transition: all 0.3s ease; }
        .map-node-empty { width: 40px; height: 40px; border-radius: 50%; border: 2px dashed rgba(200, 170, 110, 0.5); background: rgba(1, 10, 19, 0.7); display: flex; align-items: center; justify-content: center; }
        .map-node-filled img { width: 44px; height: 44px; border-radius: 50%; border: 2px solid #c8aa6e; background: #010a13; box-shadow: 0 4px 10px rgba(0,0,0,0.8); }
        .map-node-filled .badge { background: #010a13; border: 1px solid #c8aa6e; padding: 2px 4px; border-radius: 4px; font-size: 0.55rem; font-weight: bold; margin-top: -6px; z-index: 11; text-align: center; white-space: nowrap;}
        
        .pos-TOP-1 { top: 25%; left: 20%; } .pos-JUNGLE-1 { top: 45%; left: 35%; } .pos-MID-1 { top: 60%; left: 40%; } .pos-ADC-1 { top: 80%; left: 65%; } .pos-SUPPORT-1 { top: 88%; left: 50%; }
        .pos-TOP-2 { top: 12%; left: 50%; } .pos-JUNGLE-2 { top: 20%; left: 65%; } .pos-MID-2 { top: 40%; left: 60%; } .pos-ADC-2 { top: 55%; left: 80%; } .pos-SUPPORT-2 { top: 75%; left: 80%; }

        /* --- CHAT STYLES --- */
        .chat-msg { display: flex; flex-direction: column; margin-bottom: 4px; }

        /* --- AUDIO LOADER ANIMATION --- */
        .loader-wrapper {
            position: relative; display: flex; align-items: center; justify-content: center;
            width: 70px; height: 70px; font-family: "Inter", sans-serif; font-size: 0.55rem;
            font-weight: 700; color: #f0e6d2; border-radius: 50%; user-select: none;
        }
        .loader-spinner {
            position: absolute; top: 0; left: 0; width: 100%; aspect-ratio: 1/1; border-radius: 50%;
            background-color: transparent; animation: loader-rotate 3s linear infinite; z-index: 0;
        }
        @keyframes loader-rotate {
            0% { transform: rotate(90deg); box-shadow: 0 3px 6px 0 rgba(200,170,110,0.5) inset, 0 6px 10px 0 rgba(200,170,110,0.8) inset, 0 15px 15px 0 rgba(9,20,40,0.8) inset; }
            50% { transform: rotate(270deg); box-shadow: 0 3px 6px 0 rgba(200,170,110,0.5) inset, 0 6px 3px 0 rgba(240,230,210,0.8) inset, 0 10px 15px 0 rgba(1,10,19,0.8) inset; }
            100% { transform: rotate(450deg); box-shadow: 0 3px 6px 0 rgba(200,170,110,0.5) inset, 0 6px 10px 0 rgba(200,170,110,0.8) inset, 0 15px 15px 0 rgba(9,20,40,0.8) inset; }
        }
        .loader-letter {
            display: inline-block; opacity: 0.4; transform: translateY(0);
            animation: loader-letter-anim 2s infinite; z-index: 1; text-transform: uppercase;
        }
        @keyframes loader-letter-anim {
            0%, 100% { opacity: 0.4; transform: translateY(0); }
            20% { opacity: 1; transform: scale(1.15); text-shadow: 0 0 8px rgba(200,170,110,0.8); color: #c8aa6e; }
            40% { opacity: 0.7; transform: translateY(0); }
        }

        /* --- AUDIO VOLUME SLIDER --- */
        .slider-container { display: inline-flex; align-items: center; position: relative; cursor: pointer; }
        .slider-container .volume { color: #f0e6d2; width: 18px; height: auto; margin-right: 10px; pointer-events: auto; transition: opacity 0.3s; }
        .slider-container .level {
            -webkit-appearance: none; appearance: none;
            width: 80px; height: 8px; background: rgba(200, 170, 110, 0.2);
            overflow: hidden; border-radius: 5px; cursor: inherit; transform: rotate(0deg);
        }
        .slider-container .level::-webkit-slider-thumb {
            -webkit-appearance: none; width: 0; height: 0;
            box-shadow: -200px 0 0 200px #c8aa6e;
        }
        .slider-container .level::-moz-range-thumb {
            width: 0; height: 0; border-radius: 0; border: none;
            box-shadow: -200px 0 0 200px #c8aa6e;
        }
    </style>
</head>
<body class="flex w-screen h-screen bg-[#010a13] text-[#f0e6d2] overflow-hidden relative">

    <div class="star-container">
        <div id="stars"></div><div id="stars2"></div><div id="stars3"></div>
    </div>

    <!-- INVITE MODAL -->
    <div id="inviteModal" class="fixed top-6 left-1/2 transform -translate-x-1/2 z-[100] hidden flex-col gap-2 w-full max-w-md backdrop-blur-md">
        <div class="bg-[#091428]/95 border border-[#c8aa6e] p-6 rounded-sm shadow-[0_0_40px_rgba(200,170,110,0.3)]">
            <div class="flex justify-between items-center mb-4 border-b border-[#c8aa6e]/30 pb-3">
                <h2 class="text-lg text-[#f0e6d2] esport-font tracking-widest font-bold">Barát meghívása</h2>
                <button onclick="closeInviteModal()" class="text-slate-400 hover:text-white transition-colors text-lg font-bold">✕</button>
            </div>
            <div id="friendsListContainer" class="space-y-2 max-h-64 overflow-y-auto pr-2"></div>
        </div>
    </div>
    
    <!-- TOAST CONTAINER -->
    <div id="toastContainer" class="fixed top-6 left-1/2 transform -translate-x-1/2 z-[110] flex flex-col gap-2 pointer-events-none items-center w-full max-w-md"></div>

    <!-- MAIN CONTENT -->
    <div class="flex-1 flex flex-col h-full p-4 lg:p-6 gap-5 relative z-10 min-w-0 overflow-y-auto">
        
        <!-- HEADER SÁV -->
        <div class="flex flex-col sm:flex-row justify-between items-center border-b border-[#c8aa6e]/30 pb-3 shrink-0">
            <div class="flex items-center gap-6">
                <a href="/dashboard" class="bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] border border-[#c8aa6e]/50 px-4 py-2 rounded-sm text-xs font-bold transition-all cyber-font tracking-widest uppercase">← Vissza</a>
                <div>
                    <h1 id="lobbyTitle" class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font drop-shadow-[0_0_8px_rgba(200,170,110,0.3)]">LoL Worlds Mayhem</h1>
                    <p class="text-slate-400 uppercase tracking-widest text-[0.65rem] font-bold cyber-font mt-1">Draft Aréna</p>
                </div>
            </div>

            <!-- AUDIO PANEL (Jobb oldal) -->
            <div id="audioControlPanel" class="flex items-center gap-6 z-20">
                <div class="loader-wrapper" id="loaderWrapper">
                    <div class="loader-spinner"></div>
                </div>
                <div class="slider-container flex items-center">
                    <svg class="volume cursor-pointer" id="muteIcon" onclick="toggleMute()" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <g>
                            <path d="M18.36 19.36a1 1 0 0 1-.705-1.71C19.167 16.148 20 14.142 20 12s-.833-4.148-2.345-5.65a1 1 0 1 1 1.41-1.419C20.958 6.812 22 9.322 22 12s-1.042 5.188-2.935 7.069a.997.997 0 0 1-.705.291z" fill="currentColor" />
                            <path d="M15.53 16.53a.999.999 0 0 1-.703-1.711C15.572 14.082 16 13.054 16 12s-.428-2.082-1.173-2.819a1 1 0 1 1 1.406-1.422A6 6 0 0 1 18 12a6 6 0 0 1-1.767 4.241.996.996 0 0 1-.703.289zM12 22a1 1 0 0 1-.707-.293L6.586 17H4c-1.103 0-2-.897-2-2V9c0-1.103.897-2 2-2h2.586l4.707-4.707A.998.998 0 0 1 13 3v18a1 1 0 0 1-1 1z" fill="currentColor" />
                        </g>
                    </svg>
                    <input type="range" class="level" id="volumeSlider" min="0" max="100" value="10" oninput="changeVolume(this.value)" />
                </div>
            </div>
        </div>

        <!-- BELSŐ SCROLL KONTÉNER -->
        <div class="flex-1 min-h-0 overflow-y-auto pr-2">
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 h-full">
                
                <!-- BAL OSZLOP: TÉRKÉP ÉS KÓD -->
                <div class="xl:col-span-1 flex flex-col gap-4 h-full">
                    <div class="flex flex-col items-center justify-start relative hex-panel p-6 rounded-sm w-full" id="leftMapArea">
                        <div class="w-full flex justify-between items-center mb-6 border-b border-[#c8aa6e]/30 pb-3">
                            <h2 class="text-lg text-[#f0e6d2] font-bold esport-font tracking-widest" id="mapTitle">SAJÁT ROSTER</h2>
                            <button id="readyBtnTop" onclick="setReady()" class="hidden cyber-font text-[0.65rem] bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-1.5 rounded-sm tracking-widest transition-colors font-bold uppercase">Kész</button>
                        </div>
                        
                        <div id="mapContainer" class="relative w-full aspect-square max-w-[400px] sr-map rounded-sm mx-auto overflow-hidden">
                            <div id="node-TOP-1" class="map-node pos-TOP-1"><div class="map-node-empty text-[#c8aa6e]"></div></div>
                            <div id="node-JUNGLE-1" class="map-node pos-JUNGLE-1"><div class="map-node-empty text-[#c8aa6e]"></div></div>
                            <div id="node-MID-1" class="map-node pos-MID-1"><div class="map-node-empty text-[#c8aa6e]"></div></div>
                            <div id="node-ADC-1" class="map-node pos-ADC-1"><div class="map-node-empty text-[#c8aa6e]"></div></div>
                            <div id="node-SUPPORT-1" class="map-node pos-SUPPORT-1"><div class="map-node-empty text-[#c8aa6e]"></div></div>
                            
                            <div id="node-TOP-2" class="map-node pos-TOP-2 hidden"></div>
                            <div id="node-JUNGLE-2" class="map-node pos-JUNGLE-2 hidden"></div>
                            <div id="node-MID-2" class="map-node pos-MID-2 hidden"></div>
                            <div id="node-ADC-2" class="map-node pos-ADC-2 hidden"></div>
                            <div id="node-SUPPORT-2" class="map-node pos-SUPPORT-2 hidden"></div>
                        </div>
                    </div>

                    <!-- MEGHÍVÓ ÉS KÓD (Map alatti panel) -->
                    <div id="roomCodeContainer" class="hex-panel rounded-sm p-6 w-full flex flex-col gap-4 shadow-lg shrink-0">
                        <div class="text-center w-full">
                            <p class="text-[0.65rem] text-[#c8aa6e] uppercase tracking-widest mb-1 cyber-font font-bold">Szoba Kód</p>
                            <div class="bg-[#010a13] border border-[#c8aa6e]/50 px-4 py-2 rounded-sm font-mono text-xl font-bold text-white tracking-widest"><%= inviteCode %></div>
                        </div>
                        <button id="inviteFriendBtn" onclick="openInviteModal()" class="w-full bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] border border-[#c8aa6e]/50 px-5 py-2.5 rounded-sm text-sm font-bold text-[#c8aa6e] transition-colors cyber-font tracking-widest uppercase">
                            Barát Meghívása
                        </button>
                    </div>
                </div>

                <!-- KÖZÉPSŐ / JOBB OSZLOP: SORSOLÁS / SZIMULÁCIÓ -->
                <div class="xl:col-span-2 flex flex-col h-full relative" id="centerArea">
                    
                    <!-- SPIN AREA -->
                    <div id="startArea" class="w-full flex flex-col items-center justify-center min-h-[400px] hex-panel rounded-sm">
                        <button id="mainSpinBtn" onclick="rollTeams()" class="esport-font text-3xl text-[#010a13] bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] hover:from-[#f0e6d2] hover:to-[#c8aa6e] px-16 py-4 rounded-sm transition-all hover:scale-105 shadow-[0_0_20px_rgba(200,170,110,0.4)]">
                            SPIN
                        </button>
                        <p class="mt-5 text-[#c8aa6e] font-bold tracking-widest text-xs cyber-font" id="initialRerollText">3 REROLL MARADT</p>
                    </div>

                    <!-- DRAFT PHASE 1: Csapatválasztás -->
                    <div id="teamsAreaPhase1" class="w-full hidden flex-col hex-panel p-6 rounded-sm h-fit">
                        <div class="flex justify-between items-end mb-6 border-b border-[#c8aa6e]/30 pb-3">
                            <h2 class="text-lg text-[#f0e6d2] font-bold esport-font tracking-widest">VÁLASSZ EGY CSAPATOT</h2>
                            <div class="flex items-center gap-3">
                                <p id="rerollsTextP1" class="text-slate-400 font-bold tracking-widest text-[0.65rem] cyber-font mt-1">3 LEFT</p>
                                <button onclick="rollTeams()" class="cyber-font text-[0.65rem] text-[#010a13] font-bold uppercase tracking-widest bg-[#c8aa6e] hover:bg-[#f0e6d2] px-4 py-1.5 rounded-sm transition-colors">
                                    Reroll
                                </button>
                            </div>
                        </div>
                        <div id="teamsListPhase1" class="space-y-4"></div>
                    </div>

                    <!-- DRAFT PHASE 2: Játékosválasztás -->
                    <div id="teamsAreaPhase2" class="w-full hidden flex-col hex-panel p-6 rounded-sm h-fit">
                        <div class="flex items-center gap-4 mb-6 border-b border-[#c8aa6e]/30 pb-4" id="phase2Header"></div>
                        <div id="teamsListPhase2" class="space-y-3"></div>
                    </div>

                    <!-- VÁRAKOZÓ KÉPERNYŐ -->
                    <div id="waitingArea" class="w-full hidden flex-col items-center justify-center min-h-[400px] hex-panel rounded-sm">
                        <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-[#c8aa6e] mb-6"></div>
                        <h2 class="text-xl text-[#c8aa6e] font-bold esport-font tracking-widest">VÁRAKOZÁS A TÖBBIEKRE...</h2>
                    </div>

                    <!-- SZIMULÁCIÓS STÚDIÓ -->
                    <div id="simulationStudio" class="w-full hidden flex-col items-center justify-start">
                        <div id="studioMatchBox" class="bg-[#091428] border border-[#c8aa6e]/30 w-full rounded-sm p-8 mb-6 text-center min-h-[260px] flex flex-col items-center justify-center relative shadow-lg">
                            <div id="matchGroupBadge" class="hidden bg-[#1e2328] text-[#c8aa6e] border border-[#c8aa6e]/50 px-4 py-1.5 text-xs font-bold tracking-widest uppercase mb-6 cyber-font rounded-sm">Csoportmérkőzés</div>
                            
                            <div id="matchTeamsDisplay" class="hidden flex items-center justify-center gap-6 w-full mb-4">
                                <div class="flex flex-col items-end flex-1 min-w-0">
                                    <img id="matchTeam1Img" src="" class="w-20 h-20 rounded-full border-2 border-[#c8aa6e] mb-3 shadow-[0_0_15px_rgba(200,170,110,0.3)] object-cover">
                                    <div id="matchTeam1" class="text-2xl esport-font font-bold tracking-wider truncate w-full text-right">Team 1</div>
                                </div>
                                <div class="text-[#c8aa6e] font-black italic text-4xl px-2 mt-4 opacity-50">VS</div>
                                <div class="flex flex-col items-start flex-1 min-w-0">
                                    <img id="matchTeam2Img" src="" class="w-20 h-20 rounded-full border-2 border-[#c8aa6e] mb-3 shadow-[0_0_15px_rgba(200,170,110,0.3)] object-cover">
                                    <div id="matchTeam2" class="text-2xl esport-font font-bold tracking-wider truncate w-full text-left">Team 2</div>
                                </div>
                            </div>

                            <div id="bo5ScoreDisplay" class="hidden text-2xl font-mono text-[#c8aa6e] mb-4 font-black tracking-widest bg-[#010a13] px-6 py-2 rounded-sm border border-[#c8aa6e]/30">
                                <span id="scoreT1">0</span> <span class="text-slate-600 mx-2">-</span> <span id="scoreT2">0</span>
                            </div>

                            <div id="playByPlayLog" class="hidden text-xs mb-4 bg-[#010a13] px-6 py-4 border border-[#c8aa6e]/30 w-full flex flex-col gap-2 min-h-[120px] text-left rounded-sm font-sans"></div>
                            
                            <div id="matchWinnerDisplay" class="hidden mt-4 bg-emerald-900/30 border border-emerald-700 px-6 py-2.5 rounded-sm text-emerald-400 font-bold text-sm uppercase tracking-wider transition-opacity duration-500 flex items-center gap-2">
                                <span id="winnerTextLabel" class="text-emerald-500/70">Győztes:</span> <span id="winnerText" class="text-white">Winner</span>
                            </div>
                        </div>

                        <!-- HOST CONTROLS -->
                        <div id="hostControls" class="hidden flex-col gap-3 w-full items-center">
                            <button id="nextMatchBtn" onclick="triggerNextMatch()" class="w-full esport-font text-xl font-bold text-[#010a13] bg-[#c8aa6e] hover:bg-[#f0e6d2] py-3 rounded-sm transition-colors shadow-[0_0_15px_rgba(200,170,110,0.3)] disabled:opacity-50 disabled:cursor-not-allowed">
                                KÖVETKEZŐ MECCS
                            </button>
                            <div id="fastForwardGroup" class="flex gap-3 w-full mt-1">
                                <button id="ffGroupBtn" onclick="fastForward('group')" class="flex-1 bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] text-slate-300 text-[0.65rem] font-bold uppercase tracking-widest py-2.5 rounded-sm border border-[#c8aa6e]/50 transition-colors cyber-font">GYORSÍTÁS: CSOPORT</button>
                                <button id="ffAllBtn" onclick="fastForward('all')" class="flex-1 bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] text-slate-300 text-[0.65rem] font-bold uppercase tracking-widest py-2.5 rounded-sm border border-[#c8aa6e]/50 transition-colors cyber-font">GYORSÍTÁS: ÖSSZES</button>
                                <button id="ffBo5Btn" onclick="fastForward('bo5')" class="hidden flex-1 bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] text-slate-300 text-[0.65rem] font-bold uppercase tracking-widest py-2.5 rounded-sm border border-[#c8aa6e]/50 transition-colors cyber-font">TELJES BO5 LEJÁTSZÁSA</button>
                            </div>
                        </div>
                    </div>

                    <!-- VÉGEREDMÉNY / CHAMPION -->
                    <div id="championArea" class="hidden w-full flex-col items-center">
                        <div class="w-full bg-[#091428] border-2 border-[#c8aa6e] rounded-sm p-8 shadow-[0_0_50px_rgba(200,170,110,0.3)] flex flex-col items-center mb-8 relative overflow-hidden">
                            <h2 class="text-xl font-bold text-[#f0e6d2] esport-font tracking-widest mb-6">A torna véget ért</h2>
                            <img id="championLogo" src="" class="w-28 h-28 rounded-full border-4 border-[#c8aa6e] mb-5 shadow-xl object-cover">
                            <p class="text-4xl font-black text-white drop-shadow-lg mb-2 text-center">🏆 <span id="championName" class="mx-2 text-[#c8aa6e]">Bajnok neve</span> 🏆</p>
                            <p class="text-sm text-slate-400 font-bold uppercase tracking-widest cyber-font mt-2">Megnyerte a LoL Worlds Mayhem trófeát!</p>
                        </div>
                        
                        <div class="w-full hex-panel rounded-sm p-6 mb-8">
                            <h3 class="text-center text-[#c8aa6e] font-black text-lg mb-6 esport-font tracking-widest border-b border-[#c8aa6e]/30 pb-3">Végső ranglista</h3>
                            <div id="standingsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                        </div>

                        <div id="finalGroupTablesArea" class="w-full hidden flex-col gap-5 hex-panel p-6 rounded-sm">
                            <h3 class="text-center text-[#f0e6d2] text-sm uppercase tracking-widest font-bold border-b border-[#c8aa6e]/30 pb-3 cyber-font">Csoportkör végeredménye</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="finalGroupTablesContainer"></div>
                        </div>
                    </div>

                    <div id="bracketArea" class="w-full mt-6 hidden flex-col gap-4 hex-panel p-6 rounded-sm">
                        <h3 class="text-center text-[#f0e6d2] text-sm uppercase tracking-widest font-bold border-b border-[#c8aa6e]/30 pb-3 cyber-font">Kieséses ágrajz</h3>
                        <div class="flex justify-between gap-3 overflow-x-auto pb-2 min-h-[250px]" id="bracketContainer"></div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT SIDEBAR (Lobby Chat Panel) -->
    <div class="w-[350px] bg-[#091428] border-l border-[#c8aa6e]/40 flex flex-col h-full z-20 shadow-[-10px_0_30px_rgba(0,0,0,0.5)] shrink-0 relative">
        
        <!-- FELSŐ RÉSZ: Lobby Tagok -->
        <div id="sidebarTopSection" class="flex-1 flex flex-col min-h-0 border-b border-[#c8aa6e]/40 transition-all duration-500">
            <div class="p-4 border-b border-[#c8aa6e]/30 bg-[#010a13] shrink-0">
                <h2 id="sidebarTitle" class="text-sm font-bold text-[#c8aa6e] esport-font tracking-widest uppercase text-center">Felhasználók a szobában</h2>
            </div>
            <div id="sidebarContent" class="flex-1 overflow-y-auto p-3 space-y-2.5">
                <!-- Javascript tölti fel -->
            </div>
        </div>

        <!-- ALSÓ RÉSZ: Lobby Chat -->
        <div id="sidebarChatSection" class="h-[350px] flex flex-col bg-[#010a13] shrink-0 relative z-30 transition-all duration-500">
            <div class="p-3 border-b border-[#c8aa6e]/30 bg-[#1e2328] flex justify-between items-center shrink-0">
                <div class="flex items-center gap-2">
                    <div class="w-2.5 h-2.5 bg-emerald-500 rounded-full shadow-[0_0_5px_#10b981] animate-pulse"></div>
                    <span class="text-[#c8aa6e] text-[0.65rem] font-bold cyber-font uppercase tracking-widest">Szoba Chat</span>
                </div>
            </div>
            
            <div id="lobbyChatMessageList" class="flex-1 overflow-y-auto p-4 flex flex-col bg-gradient-to-b from-[#010a13] to-[#091428] gap-1">
            </div>
            
            <div class="p-3 border-t border-[#c8aa6e]/30 bg-[#091428] shrink-0">
                <input type="text" id="lobbyChatInput" class="w-full bg-[#010a13] border border-[#c8aa6e]/50 rounded-sm px-3 py-2 text-[#f0e6d2] focus:outline-none focus:border-[#c8aa6e] focus:shadow-[0_0_8px_rgba(200,170,110,0.3)] text-sm font-sans transition-all" placeholder="Üzenet a lobbiba..." onkeypress="handleLobbyChatInput(event)">
            </div>
        </div>
    </div>

    <script>
        const ROLE_ICONS = {
            'TOP': `<svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 114 112" fill="none"><path d="M101.055 1.13167e-06L-9.79135e-06 9.9662e-06L-9.56827e-07 101.055L22 79.0552L22 21L80.0552 21L101.055 1.13167e-06Z" fill="#C89B3C"/></svg>`,
            'JUNGLE': `<svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 112 125" fill="none"><path d="M64.5 60C66.9 64.8 68.1667 71.3333 68.5 74L74 61C73.6667 60 73.2 56 74 48C74.8 40 84.6667 13.3333 89.5 1C85.3333 6.66667 76 19.5 72 25.5C68 31.5 61.3333 44 58.5 49.5C59.5 51 62.1 55.2 64.5 60Z" fill="#C89B3C"/><path d="M81 97.5C78.2 99.9 74.5 104.167 73 106L72.5 91.5C73 89.5 74.3 84.5 75.5 80.5C76.7 76.5 80 68 86.5 56.5C88.1667 54 92.9 47.7 96.5 44.5C100.1 41.3 106 37.5 111.5 34.5C104 43 105 42 98 54.5C92.302 64.6751 91.3333 80.6667 91.5 90C89.1667 91.5 83.8 95.1 81 97.5Z" fill="#C89B3C"/><path d="M61 89C61 108.2 57.6667 121 56 125C43.2 105.8 26.6667 93 20 89C19.5 83 18 69.1 16 61.5C14 53.9 4.5 40.3333 0 34.5C4.5 36.5 15.4 42.2 23 49C30.6 55.8 35.8333 66.5 37.5 71C37.5 66.3333 37.2 54.4 36 44C34.8 33.6 25.8333 10.3333 21.5 0C25.3333 5.83333 33 15 39 25.5C43.1287 32.7252 61 65 61 89Z" fill="#C89B3C"/></svg>`,
            'MID': `<svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 114 112" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M114 18.2323L20.2323 112H0V93.8289L93.8289 0H114V18.2323Z" fill="#C89B3C"/></svg>`,
            'ADC': `<svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 114 112" fill="none"><path d="M12.9448 112H114V10.9448L92 32.9448V91H33.9448L12.9448 112Z" fill="#C89B3C"/></svg>`,
            'SUPPORT': `<svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 136 114" fill="none"><path d="M63 39.5L67.5 45.5L72.5 39.5L84.5 100.5L67.5 114L51.5 100.5L63 39.5Z" fill="#C89B3C"/><path d="M87.5 65L78.5 36L92 22.5L136 24C134 26.1667 128.9 30.7 124.5 33.5C120.1 36.3 114 39.5 108.5 40H97L108.5 56.5L87.5 65Z" fill="#C89B3C"/><path d="M67.5 32.5L47 9L51.5 0H84.5L88.5 9L67.5 32.5Z" fill="#C89B3C"/><path d="M56 36L44 24H0C1.66667 25.3333 3 29.5 13 34.5C20.7398 38.3699 27.1667 40.1667 28.5 40H38.5L27 56.5L48.5 65L56 36Z" fill="#C89B3C"/></svg>`
        };
        
        const socket = io();
        const LOBBY_ID = '<%= lobbyId %>';
        const USER_ID = '<%= userId %>';
        const USERNAME = "<%= typeof username !== 'undefined' ? username : 'Guest' %>"; 
        
        socket.emit('identify', { userId: USER_ID });

        // --- AUDIO MANAGER ---
        let currentTrack = null;
        let globalVolume = parseFloat(localStorage.getItem('lol_volume') || '0.1');
        let isMuted = localStorage.getItem('lol_muted') === 'true';

        const audioTracks = {
            draft: new Audio('/audio/LoL_Draft_Music_New.mp3'),
            groups: new Audio('/audio/LoL_Worlds_2025 _Orchestral_Theme_Csoportkor.mp3'),
            knockout: new Audio('/audio/LoL_Worlds_2023 _Orchestral_Theme_Kieseses.mp3'),
            silver: new Audio('/audio/LoL_SilverScrapes.mp3')
        };

        Object.values(audioTracks).forEach(audio => {
            audio.loop = true;
            audio.volume = isMuted ? 0 : globalVolume;
        });
        audioTracks.silver.loop = false; 

        let audioInitialized = false;

        function initAudio() {
            if(audioInitialized) return;
            let playPromise;
            if(!document.getElementById('startArea')?.classList.contains('hidden') || !document.getElementById('teamsAreaPhase1')?.classList.contains('hidden')) {
                setLoaderText('Draft fázis');
                currentTrack = 'draft';
                playPromise = audioTracks.draft.play();
            }
            if (playPromise !== undefined) {
                playPromise.then(() => { audioInitialized = true; }).catch(() => { console.log("Autoplay blokkolva."); });
            }
        }
        setTimeout(initAudio, 200);

        ['click', 'keydown', 'touchstart'].forEach(evt => 
            document.body.addEventListener(evt, () => {
                if(!audioInitialized) {
                    audioInitialized = true;
                    if(currentTrack) audioTracks[currentTrack].play().catch(e=>console.log(e));
                }
            }, { once: true })
        );

        const vSlider = document.getElementById('volumeSlider');
        if(vSlider) vSlider.value = globalVolume * 100;
        const mIcon = document.getElementById('muteIcon');
        if(mIcon) mIcon.style.opacity = isMuted ? '0.5' : '1';

        function changeVolume(val) {
            globalVolume = val / 100;
            localStorage.setItem('lol_volume', globalVolume);
            if(!isMuted && currentTrack) audioTracks[currentTrack].volume = globalVolume;
        }

        function toggleMute() {
            isMuted = !isMuted;
            localStorage.setItem('lol_muted', isMuted);
            if(currentTrack) audioTracks[currentTrack].volume = isMuted ? 0 : globalVolume;
            const mIcon = document.getElementById('muteIcon');
            if(mIcon) mIcon.style.opacity = isMuted ? '0.5' : '1';
        }

        function setLoaderText(text) {
            const wrapper = document.getElementById('loaderWrapper');
            if(!wrapper) return;
            wrapper.innerHTML = '<div class="loader-spinner"></div>';
            for(let i=0; i<text.length; i++) {
                const char = text[i] === ' ' ? '&nbsp;' : text[i];
                wrapper.innerHTML += `<span class="loader-letter" style="animation-delay: ${i*0.1}s">${char}</span>`;
            }
        }

        function playTrack(trackName, loaderText) {
            if (currentTrack === trackName) return;
            setLoaderText(loaderText);

            const fadeOutTrack = currentTrack ? audioTracks[currentTrack] : null;
            const fadeInTrack = audioTracks[trackName];
            currentTrack = trackName;

            fadeInTrack.play().catch(e => console.log("Kattintás szükséges a lejátszáshoz."));
            
            let vol = 0; fadeInTrack.volume = 0;
            const fadeInterval = setInterval(() => {
                vol += 0.05;
                if(vol >= 1) {
                    if(!isMuted) fadeInTrack.volume = globalVolume;
                    if(fadeOutTrack) { fadeOutTrack.pause(); fadeOutTrack.currentTime = 0; }
                    clearInterval(fadeInterval);
                } else {
                    if(!isMuted) {
                        fadeInTrack.volume = vol * globalVolume;
                        if(fadeOutTrack) fadeOutTrack.volume = (1 - vol) * globalVolume;
                    }
                }
            }, 50);
        }
        // --- VÉGE: AUDIO MANAGER ---

        let currentOffer = [];
        let selectedTeamIndex = null;
        const filledRoles = new Set(); 
        let isSimulating = false;
        let CURRENT_HOST_ID = null;
        let isTournamentEnded = false;

        // --- LOBBY CHAT LOGIC ---
        let lastLobbySender = null;

        function appendLobbyChatMessage(sender, msg, isSelf) {
            const list = document.getElementById('lobbyChatMessageList');
            if(!list) return;
            const textClass = `block text-[12px] text-slate-200 mt-0.5 break-words`;

            if (sender === lastLobbySender) {
                const msgDiv = list.lastElementChild;
                if (msgDiv && !msgDiv.classList.contains('sys-msg')) {
                    const textSpan = document.createElement('span');
                    textSpan.className = textClass;
                    textSpan.textContent = msg;
                    msgDiv.appendChild(textSpan);
                } else {
                    lastLobbySender = null;
                    appendLobbyChatMessage(sender, msg, isSelf);
                    return;
                }
            } else {
                const msgDiv = document.createElement('div');
                msgDiv.className = `flex flex-col w-full mt-2 items-start`;
                
                const senderSpan = document.createElement('span');
                senderSpan.className = `text-[10px] font-bold uppercase tracking-wider mb-0.5 ${isSelf ? 'text-[#c8aa6e]' : 'text-emerald-400'}`;
                senderSpan.textContent = isSelf ? 'Te' : sender;
                
                const textSpan = document.createElement('span');
                textSpan.className = textClass;
                textSpan.textContent = msg; 
                
                msgDiv.appendChild(senderSpan);
                msgDiv.appendChild(textSpan);
                list.appendChild(msgDiv);
                
                lastLobbySender = sender;
            }

            const allTexts = list.querySelectorAll('.text-[12px]');
            if (allTexts.length > 15) {
                const oldestText = allTexts[0];
                const parent = oldestText.parentElement;
                oldestText.remove();
                if (parent.querySelectorAll('.text-[12px]').length === 0) { parent.remove(); }
            }
            list.scrollTop = list.scrollHeight;
        }

        socket.on('receive_lobby_message', (data) => {
            appendLobbyChatMessage(data.senderName, data.message, data.senderId === USER_ID);
        });

        function handleLobbyChatInput(e) {
            if (e.key === 'Enter') {
                e.preventDefault(); 
                const input = document.getElementById('lobbyChatInput');
                if(!input) return;
                const msg = input.value.trim();
                
                if (msg) {
                    input.value = '';
                    socket.emit('send_lobby_message', { lobbyId: LOBBY_ID, senderId: USER_ID, message: msg.substring(0, 250) });
                }
            }
        }
        // --- VÉGE: LOBBY CHAT LOGIC ---

        function showToast(title, message, type, extraData = null) {
            const toastContainer = document.getElementById('toastContainer');
            if(!toastContainer) return;
            const toast = document.createElement('div');
            toast.className = `bg-[#091428] border ${type === 'success' ? 'border-[#c8aa6e]' : 'border-red-500'} p-3 rounded-sm shadow-xl w-full pointer-events-auto transform transition-all -translate-y-full opacity-0 relative overflow-hidden`;
            let actionHtml = '';
            if (type === 'invite') { actionHtml = `<div class="mt-2 flex gap-2"><button onclick="acceptInvite('${extraData.inviteCode}')" class="flex-1 bg-[#c8aa6e] text-[#010a13] px-2 py-1 text-[0.65rem] font-bold uppercase tracking-widest rounded-sm hover:bg-white transition-colors">Csatlakozás</button></div>`; }
            toast.innerHTML = `<h4 class="text-[${type === 'success' ? '#c8aa6e' : '#fff'}] font-bold text-[0.7rem] tracking-wider uppercase cyber-font">${title}</h4><p class="text-slate-300 text-[0.65rem] mt-1">${message}</p>${actionHtml}`;
            toastContainer.appendChild(toast);
            
            toast.offsetHeight; 
            setTimeout(() => { toast.classList.remove('-translate-y-full', 'opacity-0'); }, 10);
            if (type !== 'invite') { setTimeout(() => { toast.classList.add('-translate-y-full', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 5000); }
        }

        async function openInviteModal() {
            const modal = document.getElementById('inviteModal');
            if(modal) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
            const container = document.getElementById('friendsListContainer');
            if(!container) return;
            container.innerHTML = '<p class="text-slate-400 text-sm">Betöltés...</p>';
            try {
                const res = await fetch('/api/friends/list');
                const friends = await res.json();
                container.innerHTML = '';
                if (friends.length === 0) {
                    container.innerHTML = '<p class="text-slate-500 text-sm italic">Nincsenek elérhető barátaid a meghíváshoz.</p>';
                    return;
                }
                friends.forEach(f => {
                    container.innerHTML += `
                        <div class="flex justify-between items-center bg-[#1e2328] p-3 rounded-sm border border-[#c8aa6e]/30">
                            <span class="font-bold text-slate-200 text-sm">${f.username}</span>
                            <button onclick="sendInvite('${f.id}', this)" class="bg-[#c8aa6e] hover:bg-[#f0e6d2] text-[#010a13] px-3 py-1.5 rounded-sm text-xs font-bold transition-colors">Meghívás</button>
                        </div>
                    `;
                });
            } catch (e) { container.innerHTML = '<p class="text-red-400 text-sm">Hiba a betöltéskor.</p>'; }
        }

        function closeInviteModal() { 
            const modal = document.getElementById('inviteModal');
            if(modal) {
                modal.classList.add('hidden'); 
                modal.classList.remove('flex');
            }
        }
        
        function sendInvite(targetId, btn) {
            btn.disabled = true; btn.innerText = 'Elküldve!';
            btn.classList.replace('bg-[#c8aa6e]', 'bg-slate-600'); btn.classList.replace('text-[#010a13]', 'text-slate-300');
            socket.emit('send_lobby_invite', { userId: USER_ID, targetUserId: targetId, lobbyId: LOBBY_ID }, (res) => {
                if(res.status === 'error') {
                    showToast('Hiba', res.message, 'error');
                    btn.innerText = 'Meghívás'; btn.disabled = false;
                    btn.classList.replace('bg-slate-600', 'bg-[#c8aa6e]'); btn.classList.replace('text-slate-300', 'text-[#010a13]');
                }
            });
        }

        function getRegionBadge(region) {
            const map = {
                'KR': { text: 'KR', color: 'bg-blue-600' }, 'CN': { text: 'CN', color: 'bg-red-600' },
                'EU': { text: 'EU', color: 'bg-indigo-500' }, 'NA': { text: 'NA', color: 'bg-cyan-600' },
                'PCS': { text: 'PCS', color: 'bg-emerald-600' }, 'VN': { text: 'VN', color: 'bg-yellow-600' },
                'BR': { text: 'BR', color: 'bg-green-600' }, 'TR': { text: 'TR', color: 'bg-red-500' },
                'CIS': { text: 'CIS', color: 'bg-purple-600' }, 'LATAM': { text: 'LATAM', color: 'bg-pink-600' },
                'JP': { text: 'JP', color: 'bg-rose-500' }, 'OCE': { text: 'OCE', color: 'bg-sky-500' }
            };
            const r = map[region] || { text: region, color: 'bg-slate-600' };
            return `<span class="${r.color} text-white text-[0.55rem] font-black px-1.5 py-0.5 rounded tracking-wider mx-1 flex-shrink-0 shadow-sm">${r.text}</span>`;
        }

        function getUserAvatar(name, isTeamBox = false) {
            const bg = isTeamBox ? '010a13' : '1e2328'; const color = isTeamBox ? 'c8aa6e' : 'f0e6d2';
            return `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=${bg}&color=${color}&bold=true&size=128`;
        }

        function getEsportImage(name, isTeam = false, season = null) {
            const safeName = name.replace(/[^a-zA-Z0-9]/g, '');
            const filename = season ? `${safeName}_${season}.png` : `${safeName}.png`;
            return isTeam ? `/images/teams/${filename}` : `/images/players/${filename}`;
        }

        socket.emit('join_lobby', { userId: USER_ID, inviteCode: '<%= inviteCode %>' }, () => {});

        function updateLobbyStateUI(data) {
            const phase = data.currentPhase;
            const hasPending = data.hasPendingMatches;
            
            if (data.status === 'SIMULATING' || data.status === 'FINISHED') {
                const roomCodeContainer = document.getElementById('roomCodeContainer');
                if (roomCodeContainer && !roomCodeContainer.classList.contains('hidden')) {
                    roomCodeContainer.classList.add('hidden');
                }
            }
            
            if (USER_ID === data.hostId && !isTournamentEnded && data.status === 'SIMULATING') {
                document.getElementById('hostControls')?.classList.remove('hidden');
                document.getElementById('hostControls')?.classList.add('flex');
                
                const nextMatchBtn = document.getElementById('nextMatchBtn');
                const fastForwardGroup = document.getElementById('fastForwardGroup');
                const btnAll = document.getElementById('ffAllBtn');
                const btnGroup = document.getElementById('ffGroupBtn');
                const btnBo5 = document.getElementById('ffBo5Btn');

                if(nextMatchBtn) { nextMatchBtn.classList.remove('hidden'); nextMatchBtn.disabled = false; }
                
                if (!hasPending) {
                    if(fastForwardGroup) { fastForwardGroup.classList.add('hidden'); fastForwardGroup.classList.remove('flex'); }
                    if (phase === 'GROUP' && nextMatchBtn) { nextMatchBtn.innerText = "IRÁNY A RÁJÁTSZÁS"; } 
                    else if (phase === 'QUARTER' && nextMatchBtn) { nextMatchBtn.innerText = "IRÁNY AZ ELŐDÖNTŐ"; } 
                    else if (phase === 'SEMI' && nextMatchBtn) { nextMatchBtn.innerText = "IRÁNY A DÖNTŐ"; } 
                    else if (phase === 'FINAL' && nextMatchBtn) { nextMatchBtn.innerText = "EREDMÉNYHIRDETÉS"; }
                } else {
                    if(nextMatchBtn) nextMatchBtn.innerText = "KÖVETKEZŐ MECCS";
                    if(fastForwardGroup) { fastForwardGroup.classList.remove('hidden'); fastForwardGroup.classList.add('flex'); }
                    if (phase === 'GROUP') {
                        if(btnAll) btnAll.classList.remove('hidden'); 
                        if(btnGroup) btnGroup.classList.remove('hidden'); 
                        if(btnBo5) btnBo5.classList.add('hidden');
                    } else if (phase === 'QUARTER' || phase === 'SEMI' || phase === 'FINAL') {
                        if(btnAll) btnAll.classList.add('hidden'); 
                        if(btnGroup) btnGroup.classList.add('hidden'); 
                        if(btnBo5) btnBo5.classList.remove('hidden');
                    }
                }
            }

            renderGroupTables(data.players, 'sidebarContent', 'sidebar');
            if (data.bracket && data.bracket.length > 0 && ['QUARTER', 'SEMI', 'FINAL'].includes(data.currentPhase)) { 
                renderBracket(data.bracket); 
            } else {
                document.getElementById('bracketArea')?.classList.add('hidden');
                document.getElementById('bracketArea')?.classList.remove('flex');
            }
        }

        socket.on('lobby_state_update', (data) => {
            CURRENT_HOST_ID = data.hostId;
            if (data.status === 'SIMULATING' || data.status === 'FINISHED') {
                if (!isSimulating) { isSimulating = true; transitionToSimulation(); }
                updateLobbyStateUI(data);
            } else { renderManagerSidebar(data.players); }
        });

        function renderShop() {
            if (selectedTeamIndex !== null) { renderPhase2(); } else { renderPhase1(); }
        }

        function renderPhase1() {
            document.getElementById('teamsAreaPhase2')?.classList.add('hidden'); 
            document.getElementById('teamsAreaPhase1')?.classList.remove('flex'); 
            document.getElementById('teamsAreaPhase1')?.classList.remove('hidden'); 
            document.getElementById('teamsAreaPhase1')?.classList.add('flex');
            const list = document.getElementById('teamsListPhase1'); 
