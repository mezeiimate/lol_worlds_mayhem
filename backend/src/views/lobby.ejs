        function rollTeams() { 
            socket.emit('roll_teams', { lobbyId: LOBBY_ID, userId: USER_ID }, (res) => { 
                if (res.status === 'success') { 
                    currentOffer = res.data.offer; selectedTeamIndex = null; 
                    const rt1 = document.getElementById('rerollsTextP1');
                    if(rt1) rt1.innerText = `${res.data.rerollsLeft} LEFT`; 
                    const ir1 = document.getElementById('initialRerollText');
                    if(ir1) ir1.innerText = `${res.data.rerollsLeft} REROLLS LEFT`; 
                    document.getElementById('startArea')?.classList.add('hidden'); 
                    renderShop(); 
                } else { showToast('Hiba', res.message, 'error'); } 
            });
        }

        function pickPlayer(playerId, role, playerName, teamName, season) { 
            socket.emit('pick_player', { lobbyId: LOBBY_ID, userId: USER_ID, playerId, role }, (res) => { 
                if (res.status === 'success') { 
                    filledRoles.add(role); 
                    const node = document.getElementById(`node-${role}-1`);
                    if(node) {
                        node.innerHTML = `
