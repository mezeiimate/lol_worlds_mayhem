        // --- ÚJ, ÉLŐ ÁGRAJZ LOGIKA LOKÁLIS FELÜLÍRÁSSAL ---
        window.bracketScores = window.bracketScores || {}; 

        function renderBracket(matches) {
            const area = document.getElementById('bracketArea');
            const container = document.getElementById('bracketContainer');
            if(!area || !container) return;
            
            area.classList.remove('hidden'); area.classList.add('flex');
            
            // Kényszerítsük ki, hogy mindig legyen 4 negyed, 2 elő, 1 döntő doboz
            let quarters = matches.filter(m => m.match_type === 'QUARTER');
            while(quarters.length < 4) quarters.push({ match_type: 'QUARTER' });

            let semis = matches.filter(m => m.match_type === 'SEMI'); 
            while(semis.length < 2) semis.push({ match_type: 'SEMI' });

            let final = matches.filter(m => m.match_type === 'FINAL');
            while(final.length < 1) final.push({ match_type: 'FINAL' });

            // Segédfüggvény a győztes kiderítésére (Backend + Lokális Cache kombinálva)
            const getWinner = (m) => {
                if (!m) return null;
                if (m.winner_name && m.winner_name !== 'TBD') return m.winner_name;
                
                if (m.team1_name && m.team2_name) {
                    const matchKey = m.team1_name + "_vs_" + m.team2_name;
                    const matchKeyRev = m.team2_name + "_vs_" + m.team1_name;
                    if (window.bracketScores[matchKey] && window.bracketScores[matchKey].winner) return window.bracketScores[matchKey].winner;
                    if (window.bracketScores[matchKeyRev] && window.bracketScores[matchKeyRev].winner) return window.bracketScores[matchKeyRev].winner;
                }
                
                let s1 = m.score1 !== undefined ? m.score1 : m.team1_wins;
                let s2 = m.score2 !== undefined ? m.score2 : m.team2_wins;
                if (s1 == 3) return m.team1_name;
                if (s2 == 3) return m.team2_name;

                return null;
            };

            // Lokális ágrajz-továbbjutó felülírás, hogy azonnal megjelenjen a győztes a következő körben
            if (getWinner(quarters[0])) semis[0].team1_name = getWinner(quarters[0]);
            if (getWinner(quarters[1])) semis[0].team2_name = getWinner(quarters[1]);
            if (getWinner(quarters[2])) semis[1].team1_name = getWinner(quarters[2]);
            if (getWinner(quarters[3])) semis[1].team2_name = getWinner(quarters[3]);

            if (getWinner(semis[0])) final[0].team1_name = getWinner(semis[0]);
            if (getWinner(semis[1])) final[0].team2_name = getWinner(semis[1]);
            
            const getMatchBox = (m, isFinal = false) => {
                if (!m || (!m.team1_name && !m.team2_name)) {
                    return `
                        <div class="bg-[#010a13] border border-[#c8aa6e]/30 p-${isFinal ? '3' : '2'} rounded-sm text-center text-${isFinal ? 'xs' : '[0.6rem]'} font-bold flex flex-col justify-center shadow-md">
                            <div class="flex justify-between px-2 items-center"><span class="text-slate-600 truncate text-left flex-1">TBD</span><span class="text-slate-600 font-mono mx-2">-</span></div>
                            <div class="flex justify-between px-2 mt-1 border-t border-slate-800 pt-1 items-center"><span class="text-slate-600 truncate text-left flex-1">TBD</span><span class="text-slate-600 font-mono mx-2">-</span></div>
                        </div>`;
                }
                
                let t1 = m.team1_name || 'TBD'; 
                let t2 = m.team2_name || 'TBD';
                
                let s1 = '-'; let s2 = '-';
                
                if (m.score1 !== undefined && m.score1 !== null) s1 = m.score1;
                else if (m.team1_wins !== undefined && m.team1_wins !== null) s1 = m.team1_wins;

                if (m.score2 !== undefined && m.score2 !== null) s2 = m.score2;
                else if (m.team2_wins !== undefined && m.team2_wins !== null) s2 = m.team2_wins;

                let winner = getWinner(m);

                // Erőszakos lokális felülírás a megjelenítésnél
                const matchKey = t1 + "_vs_" + t2;
                const matchKeyRev = t2 + "_vs_" + t1;
                
                if (window.bracketScores[matchKey]) {
                    s1 = window.bracketScores[matchKey].s1;
                    s2 = window.bracketScores[matchKey].s2;
                } else if (window.bracketScores[matchKeyRev]) {
                    s1 = window.bracketScores[matchKeyRev].s2;
                    s2 = window.bracketScores[matchKeyRev].s1;
                }
                
                const c1 = winner === t1 ? 'text-emerald-400' : (winner && t1 !== 'TBD' ? 'text-slate-500' : 'text-slate-300');
                const c2 = winner === t2 ? 'text-emerald-400' : (winner && t2 !== 'TBD' ? 'text-slate-500' : 'text-slate-300');
                
                const borderColor = isFinal ? 'border-[#c8aa6e] shadow-[0_0_15px_rgba(200,170,110,0.2)]' : (m.match_type === 'SEMI' ? 'border-[#c8aa6e]/60' : 'border-[#c8aa6e]/30');
                
                return `
                    <div class="bg-[#010a13] border ${borderColor} p-${isFinal ? '3' : '2'} rounded-sm text-center text-${isFinal ? 'xs' : '[0.6rem]'} font-bold flex flex-col justify-center shadow-md transition-colors">
                        <div class="flex justify-between px-2 items-center">
                            <span class="${c1} truncate text-left flex-1">${t1}</span>
                            <span class="text-[#c8aa6e] font-mono mx-2">${s1}</span>
                        </div>
                        <div class="flex justify-between px-2 mt-1 border-t border-slate-800 pt-1 items-center">
                            <span class="${c2} truncate text-left flex-1">${t2}</span>
                            <span class="text-[#c8aa6e] font-mono mx-2">${s2}</span>
                        </div>
                    </div>`;
            };

            let html = `<div class="flex-1 space-y-2 flex flex-col justify-around min-w-[120px]">`;
            for(let i=0; i<4; i++) html += getMatchBox(quarters[i]);
            html += `</div><div class="flex flex-col justify-around gap-2 flex-1 min-w-[120px]">`;
            for(let i=0; i<2; i++) html += getMatchBox(semis[i]);
            html += `</div><div class="flex flex-col justify-center flex-1 min-w-[120px]">`;
            html += getMatchBox(final[0], true);
            html += `</div>`;
            
            container.innerHTML = html;
        }

        socket.on('match_simulated_event', (data) => {
            if (isTournamentEnded) return;
            document.getElementById('matchStatusText')?.classList.add('hidden');
            document.getElementById('matchWinnerDisplay')?.classList.add('hidden');
            document.getElementById('fastForwardGroup')?.classList.add('hidden');
            document.getElementById('nextMatchBtn')?.classList.add('hidden');

            // AZONNALI CACHE ÉPÍTÉS A PONTOKHOZ (BO5 esetén)
            if (data.isBO5) {
                window.bracketScores = window.bracketScores || {};
                const k1 = data.team1 + "_vs_" + data.team2;
                const winName = data.isSeriesFinished ? data.winner : null;
                
                window.bracketScores[k1] = { s1: data.score1, s2: data.score2, winner: winName };
            }
            
            const badge = document.getElementById('matchGroupBadge');
            if(badge) {
                badge.classList.remove('hidden'); 
                badge.innerText = data.isBO5 ? `${data.group} - Game ${data.gameNumber}` : data.group;
            }
            
            const teamsDisplay = document.getElementById('matchTeamsDisplay');
            if(teamsDisplay) {
                teamsDisplay.classList.remove('hidden'); 
                teamsDisplay.classList.add('flex');
            }
            
            const img1 = document.getElementById('matchTeam1Img');
            if(img1) img1.src = getUserAvatar(data.team1, true);
            const img2 = document.getElementById('matchTeam2Img');
            if(img2) img2.src = getUserAvatar(data.team2, true);

            const t1El = document.getElementById('matchTeam1'); const t2El = document.getElementById('matchTeam2');
            if(t1El) {
                t1El.innerText = data.team1;
                t1El.className = "text-xl esport-font font-bold tracking-wider truncate w-full text-right text-slate-300 transition-colors duration-500";
            }
            if(t2El) {
                t2El.innerText = data.team2;
                t2El.className = "text-xl esport-font font-bold tracking-wider truncate w-full text-left text-slate-300 transition-colors duration-500";
            }
            
            if (data.isBO5) {
                document.getElementById('bo5ScoreDisplay')?.classList.remove('hidden');
                const st1 = document.getElementById('scoreT1');
                const st2 = document.getElementById('scoreT2');
                if(st1) st1.innerText = (data.winner === data.team1) ? data.score1 - 1 : data.score1;
                if(st2) st2.innerText = (data.winner === data.team2) ? data.score2 - 1 : data.score2;
            } else { document.getElementById('bo5ScoreDisplay')?.classList.add('hidden'); }

            const logEl = document.getElementById('playByPlayLog');
            if(logEl) {
                logEl.innerHTML = ''; 
                logEl.classList.remove('hidden');
            }

            const isMyTeamInvolved = (USER_ID === data.t1_user_id || USER_ID === data.t2_user_id);
            const myTeamId = (USER_ID === data.t1_user_id) ? data.team1_id : data.team2_id;
            
            const mapTitle = document.getElementById('mapTitle');
            if (isMyTeamInvolved) {
                if(mapTitle) mapTitle.innerText = "AKTUÁLIS MÉRKŐZÉS";
                if (USER_ID === data.t1_user_id) { drawTeamOnMap(data.t1_players, 1); drawTeamOnMap(data.t2_players, 2); } 
                else { drawTeamOnMap(data.t2_players, 1); drawTeamOnMap(data.t1_players, 2); }
            } else {
                if(mapTitle) mapTitle.innerText = "SAJÁT ROSTER";
                ['TOP', 'JUNGLE', 'MID', 'ADC', 'SUPPORT'].forEach(r => document.getElementById(`node-${r}-2`)?.classList.add('hidden'));
            }

            let delay = 0; let stepDelay = data.isFastForward ? 0 : 1500;

            data.actionLogs.forEach((logObj, index) => {
                setTimeout(() => {
                    if (isTournamentEnded) return;
                    const p = document.createElement('p');
                    p.className = 'transition-opacity duration-500 font-medium tracking-wide flex gap-2 items-start text-[11px]';
                    if (!data.isFastForward) p.classList.add('opacity-0');
                    
                    let colorClass = 'text-[#c8aa6e]';
                    if (isMyTeamInvolved && logObj.favoredTeamId) { colorClass = (logObj.favoredTeamId === myTeamId) ? 'text-emerald-400' : 'text-red-400'; } 
                    else if (!isMyTeamInvolved && logObj.favoredTeamId) { colorClass = (logObj.favoredTeamId === data.team1_id) ? 'text-blue-300' : 'text-purple-300'; }

                    p.classList.add(colorClass); 
                    p.innerHTML = `<span class="mt-1 flex-shrink-0"><svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 12l10 10 10-10L12 2zm0 3.8l6.2 6.2-6.2 6.2-6.2-6.2L12 5.8z"/></svg></span> <span>${logObj.text}</span>`;
                    if(logEl) logEl.appendChild(p); 
                    
                    if (!data.isFastForward) setTimeout(() => p.classList.remove('opacity-0'), 50);

                    // MECCS VÉGE LOGIKA + SILVER SCRAPES + LIVE BRACKET
                    if (index === data.actionLogs.length - 1) {
                        setTimeout(() => {
                            if (isTournamentEnded) return;
                            
                            document.getElementById('matchWinnerDisplay')?.classList.remove('hidden');
                            const wText = document.getElementById('winnerText');
                            if(wText) wText.innerText = data.winner;

                            if (data.isBO5) { 
                                const st1 = document.getElementById('scoreT1');
                                const st2 = document.getElementById('scoreT2');
                                if(st1) st1.innerText = data.score1; 
                                if(st2) st2.innerText = data.score2; 
                            }

                            const wLabel = document.getElementById('winnerTextLabel');
                            if (data.isSeriesFinished) {
                                if(wLabel) wLabel.innerText = "🏆 GYŐZTES:";
                                if (data.team1 === data.winner) { t1El?.classList.add('text-emerald-400'); t2El?.classList.add('text-slate-600'); } 
                                else { t1El?.classList.add('text-slate-600'); t2El?.classList.add('text-emerald-400'); }
                            } else { 
                                if(wLabel) wLabel.innerText = "Game győztes:"; 
                            }

                            if (data.newState) { 
                                updateLobbyStateUI(data.newState); 
                                // FORCE BRACKET RENDER ON MATCH FINISH TO AVOID WAITING FOR NEXT MATCH
                                if(data.newState.bracket && ['QUARTER', 'SEMI', 'FINAL'].includes(data.newState.currentPhase)) {
                                    renderBracket(data.newState.bracket);
                                }
                            }

                            // SILVER SCRAPES TRIGGER
                            if (data.isBO5 && data.score1 === 2 && data.score2 === 2 && !data.isSeriesFinished && !data.isFastForward) {
                                const btn = document.getElementById('nextMatchBtn');
                                const fwdGroup = document.getElementById('fastForwardGroup');
                                if(btn) {
                                    btn.classList.remove('hidden');
                                    btn.disabled = true;
                                    btn.innerText = "GAME 5 KÖVETKEZIK...";
                                }
                                if(fwdGroup) {
                                    fwdGroup.classList.add('hidden'); fwdGroup.classList.remove('flex');
                                }
                                
                                playTrack('silver', 'Silver Scrapes');

                                setTimeout(() => {
                                    if(!isTournamentEnded && btn && fwdGroup) {
                                        btn.disabled = false;
                                        btn.innerText = "KÖVETKEZŐ MECCS";
                                        fwdGroup.classList.remove('hidden'); fwdGroup.classList.add('flex');
                                        playTrack('knockout', 'Worlds Theme');
                                    }
                                }, 14000); 
                            }

                        }, data.isFastForward ? 0 : 1000);
                    }
                }, delay);
                delay += stepDelay; 
            });
        });

        socket.on('tournament_winner', (data) => {
            isTournamentEnded = true;
            document.getElementById('hostControls')?.classList.add('hidden');
            document.getElementById('nextMatchBtn')?.classList.add('hidden');
            document.getElementById('studioMatchBox')?.classList.add('hidden');
            
            document.getElementById('leftMapArea')?.classList.add('hidden');
            document.getElementById('centerArea')?.classList.replace('xl:col-span-2', 'xl:col-span-3'); 
            
            document.getElementById('championArea')?.classList.remove('hidden');
            document.getElementById('championArea')?.classList.add('flex');
            
            const champName = document.getElementById('championName');
            if(champName) champName.innerText = data.winner;
            
            const champLogo = document.getElementById('championLogo');
            if(champLogo) champLogo.src = getUserAvatar(data.winner, true);

            // Töröljük a tagok táblázatát a jobb sávból, és kinyitjuk a chatet 100%-ra
            const sidebarTop = document.getElementById('sidebarTopSection');
            if(sidebarTop) sidebarTop.classList.add('hidden');
            const sidebarChat = document.getElementById('sidebarChatSection');
            if(sidebarChat) {
                sidebarChat.classList.remove('h-[350px]');
                sidebarChat.classList.add('flex-1');
            }

            const stContainer = document.getElementById('standingsContainer');
            if(stContainer) {
                stContainer.innerHTML = ''; 
                if (data.standings) {
                    data.standings.forEach(st => {
                        let cssClass = "bg-[#1e2328] border-[#c8aa6e]/30";
                        let rColor = "text-slate-400";
                        let nColor = "text-slate-300";
                        if (st.rank == 1 || st.rank === '1.') { cssClass = "bg-gradient-to-r from-amber-900/40 to-transparent border-amber-500"; rColor = "text-amber-400"; nColor = "text-white font-bold"; }
                        else if (st.rank == 2 || st.rank === '2.') { cssClass = "bg-gradient-to-r from-slate-600/40 to-transparent border-slate-400"; rColor = "text-slate-300"; nColor = "text-white"; }
                        else if (st.rank === 'Top 4' || st.rank == 3 || st.rank == 4) { cssClass = "bg-gradient-to-r from-orange-900/40 to-transparent border-orange-700"; rColor = "text-orange-400"; nColor = "text-white"; }

                        stContainer.innerHTML += `
                            <div class="flex items-center p-2 rounded-sm mb-1.5 shadow border ${cssClass}">
                                <span class="font-mono w-8 text-center ${rColor} font-bold text-xs">${st.rank}</span>
                                <img src="${getUserAvatar(st.name, true)}" class="w-6 h-6 border border-[#c8aa6e]/50 mx-2">
                                <span class="flex-1 ${nColor} truncate tracking-wide text-xs">${st.name}</span>
                            </div>
                        `;
                    });
                }
            }

            document.getElementById('finalGroupTablesArea')?.classList.remove('hidden');
            document.getElementById('finalGroupTablesArea')?.classList.add('flex');
            renderGroupTables(data.newState.players, 'finalGroupTablesContainer', 'final');
            
            if (data.newState && data.newState.bracket) {
                renderBracket(data.newState.bracket);
            }
        });

        function transitionToSimulation() {
            const titleEl = document.getElementById('lobbyTitle');
            if (titleEl) titleEl.innerText = "LOL WORLDS MAYHEM";
            
            // Szoba Kód elrejtése
            const roomCodeDiv = document.getElementById('roomCodeContainer');
            if (roomCodeDiv) { roomCodeDiv.classList.add('hidden'); }
            
            // Audio Panel a Header Jobb oldalára kerül
            const headerRight = document.getElementById('headerRightArea');
            const audioPanel = document.getElementById('audioControlPanel');
            if (headerRight && audioPanel) {
                headerRight.innerHTML = '';
                headerRight.appendChild(audioPanel);
            }

            document.getElementById('startArea')?.classList.add('hidden');
            document.getElementById('teamsAreaPhase1')?.classList.add('hidden');
            document.getElementById('teamsAreaPhase2')?.classList.add('hidden');
            document.getElementById('waitingArea')?.classList.add('hidden');
            
            document.getElementById('simulationStudio')?.classList.remove('hidden'); 
            document.getElementById('simulationStudio')?.classList.add('flex');
            
            const sidebarTitle = document.getElementById('sidebarTitle');
            if (sidebarTitle) sidebarTitle.innerText = "TABELLA";

            if (USER_ID === CURRENT_HOST_ID) {
                document.getElementById('hostControls')?.classList.remove('hidden');
                document.getElementById('hostControls')?.classList.add('flex');
                document.getElementById('nextMatchBtn')?.classList.remove('hidden');
            }

            playTrack('groups', 'Worlds Theme');
        }

        function triggerNextMatch() {
            const btn = document.getElementById('nextMatchBtn');
            const fwg = document.getElementById('fastForwardGroup');
            if(btn) { btn.disabled = true; btn.classList.add('hidden'); }
            if(fwg) { fwg.classList.add('hidden'); }

            socket.emit('next_match_step', { lobbyId: LOBBY_ID, userId: USER_ID }, (res) => {
                if (res.status === 'phase_changed') {
                    if(btn) { btn.classList.remove('hidden'); btn.disabled = false; }
                    
                    const mText = document.getElementById('matchStatusText');
                    if(mText) { mText.innerText = `✨ Szakasz lezárva ✨`; mText.classList.remove('hidden'); }
                    
                    document.getElementById('matchGroupBadge')?.classList.add('hidden'); 
                    document.getElementById('matchTeamsDisplay')?.classList.add('hidden'); 
                    document.getElementById('matchWinnerDisplay')?.classList.add('hidden'); 
                    document.getElementById('bo5ScoreDisplay')?.classList.add('hidden'); 
                    document.getElementById('playByPlayLog')?.classList.add('hidden');
                    
                    ['TOP', 'JUNGLE', 'MID', 'ADC', 'SUPPORT'].forEach(r => document.getElementById(`node-${r}-2`)?.classList.add('hidden'));
                    
                    const mapTitle = document.getElementById('mapTitle');
                    if(mapTitle) mapTitle.innerText = "SAJÁT ROSTER";
                    
                    playTrack('knockout', 'Worlds Theme');

                } else if (res.status === 'error') {
                    showToast('Hálózati Hiba', res.message, 'error');
                    if(btn) { btn.classList.remove('hidden'); btn.disabled = false; }
                }
            });
        }

        function fastForward(mode) {
            document.getElementById('fastForwardGroup')?.classList.add('hidden');
            document.getElementById('nextMatchBtn')?.classList.add('hidden');
            socket.emit('fast_forward_matches', { lobbyId: LOBBY_ID, userId: USER_ID, mode: mode }, (res) => {});
        }
    </script>
</body>
</html>