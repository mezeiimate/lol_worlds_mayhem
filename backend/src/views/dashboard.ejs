<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Központ | LoL Worlds Mayhem</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style> 
        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');

        body { 
            background-color: #010a13; 
            color: #f0e6d2; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0; padding: 0;
        } 
        
        .esport-font { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        .cyber-font { font-family: 'Orbitron', sans-serif; }

        .hex-panel {
            background: linear-gradient(135deg, rgba(9, 20, 40, 0.9) 0%, rgba(1, 10, 19, 0.95) 100%);
            border: 1px solid rgba(200, 170, 110, 0.3);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
            position: relative;
        }
        
        /* Görgetősáv styler */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #010a13; }
        ::-webkit-scrollbar-thumb { background: rgba(200,170,110,0.3); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #c8aa6e; }

        /* --- COSMIC PORTAL BUTTON (HEXTECH COLORS) --- */
        .cosmic-portal-btn {
            --btn-bg: #010a13; --btn-color: #c8aa6e; --btn-highlight: #091428;
            --portal-color1: #c8aa6e; --portal-color2: #f0e6d2;
            position: relative; font-family: "Oswald", sans-serif; font-size: 1.1em; font-weight: bold;
            letter-spacing: 0.1em; text-transform: uppercase; color: var(--btn-color); background-color: var(--btn-bg);
            border: none; padding: 0.8em 1.5em; cursor: pointer; overflow: hidden; transition: all 0.3s ease;
            clip-path: polygon(0% 0%, 100% 0%, 100% 70%, 90% 100%, 10% 100%, 0% 70%);
        }
        .cosmic-portal-btn::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: conic-gradient(from 0deg at 50% 50%, var(--portal-color1) 0deg, var(--portal-color2) 120deg, var(--portal-color1) 240deg, var(--portal-color2) 360deg);
            animation: rotatePortal 4s linear infinite; opacity: 0.4; transition: opacity 0.3s ease;
        }
        .cosmic-portal-btn:hover::before { opacity: 1; }
        .cosmic-portal-btn::after { content: ""; position: absolute; inset: 2px; background-color: var(--btn-bg); clip-path: inherit; z-index: 1; }
        .cosmic-btn-text { position: relative; z-index: 2; text-shadow: 0 0 10px rgba(200, 170, 110, 0.5); }
        .portal-effect { position: absolute; inset: 0; background: radial-gradient(circle at 50% 50%, var(--btn-highlight), transparent 50%); opacity: 0; transition: opacity 0.3s ease; z-index: 1; }
        .cosmic-portal-btn:hover .portal-effect { opacity: 1; animation: pulsePortal 2s ease-in-out infinite; }
        .cosmic-portal-btn:hover { transform: translateY(-2px); filter: drop-shadow(0 5px 10px rgba(200, 170, 110, 0.4)); color: #fff; }
        .cosmic-portal-btn:active { transform: translateY(0); }
        @keyframes rotatePortal { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes pulsePortal { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

        /* --- CHAT OVERLAY --- */
        .chat-msg { display: flex; flex-direction: column; margin-bottom: 4px; }
        .chat-msg .sender { color: #c8aa6e; font-weight: bold; margin-bottom: 2px; font-size: 11px; }
        .chat-msg.self .sender { color: #f0e6d2; }
        .chat-msg .text { color: #e0e0e0; word-break: break-word; margin-left: 5px; border-left: 2px solid rgba(200,170,110,0.3); padding-left: 8px; font-size: 12px; }
        .chat-msg.self .text { border-left: 2px solid rgba(240,230,210,0.3); }
        .sys-msg { color: #94a3b8; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; text-align: center; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 1px solid rgba(148, 163, 184, 0.2); }

    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#010a13]">

    <!-- MAIN CONTENT (Left Side) -->
    <div class="flex-1 flex flex-col h-full overflow-y-auto p-8 bg-[url('/map.png')] bg-cover bg-center bg-no-repeat bg-fixed relative">
        <div class="absolute inset-0 bg-[#010a13]/80 z-0"></div> <!-- Sötétítő overlay a háttérre -->
        
        <div class="relative z-10 max-w-[1200px] mx-auto w-full flex flex-col gap-8">
            <!-- HEADER -->
            <div class="text-center md:text-left border-b border-[#c8aa6e]/30 pb-6 mb-4">
                <h1 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font drop-shadow-[0_0_10px_rgba(200,170,110,0.3)]">LoL Worlds Mayhem</h1>
                <p class="text-slate-400 mt-2 uppercase tracking-widest text-sm font-bold cyber-font">Központi Irányítópult</p>
            </div>

            <!-- LOBBY ACTIONS -->
            <div class="hex-panel p-8 rounded-sm flex flex-col md:flex-row gap-8 items-center justify-center">
                <div class="flex-1 text-center border-r border-[#c8aa6e]/30 pr-8">
                    <h2 class="text-xl font-bold text-white uppercase tracking-widest mb-2 esport-font">Új Szimuláció</h2>
                    <p class="text-slate-400 text-xs mb-6 cyber-font">Állítsd fel a szobát és dominálj!</p>
                    <button id="createLobbyBtn" class="cosmic-portal-btn w-full">
                        <span class="cosmic-btn-text">Létrehozás</span>
                        <div class="portal-effect"></div>
                    </button>
                </div>
                
                <div class="flex-1 text-center pl-8">
                    <h2 class="text-xl font-bold text-[#c8aa6e] uppercase tracking-widest mb-2 esport-font">Csatlakozás</h2>
                    <p class="text-slate-400 text-xs mb-6 cyber-font">Kód alapú szinkronizáció.</p>
                    <div class="flex gap-2">
                        <input type="text" id="inviteCodeInput" placeholder="XXXXXX" maxlength="6" class="w-full bg-[#010a13] border border-[#c8aa6e]/50 rounded-sm px-4 py-2 text-center text-lg font-mono text-[#c8aa6e] uppercase tracking-widest focus:outline-none focus:border-[#f0e6d2] focus:shadow-[0_0_10px_rgba(200,170,110,0.3)] transition-all">
                        <button id="joinLobbyBtn" class="bg-[#1e2328] hover:bg-[#c8aa6e] hover:text-[#010a13] border border-[#c8aa6e]/50 text-[#c8aa6e] px-5 font-bold rounded-sm transition-colors uppercase text-sm cyber-font">→</button>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- MATCH HISTORY -->
                <div class="hex-panel p-6 rounded-sm">
                    <h2 class="text-sm font-bold text-[#c8aa6e] uppercase tracking-widest cyber-font border-b border-[#c8aa6e]/30 pb-2 mb-4">Archívum (Utolsó 5)</h2>
                    
                    <% const validMatches = matchHistory ? matchHistory.slice(0, 5) : []; %>
                    <% if (validMatches.length === 0) { %>
                        <div class="text-center py-6 border border-dashed border-slate-700/50">
                            <p class="text-slate-500 text-[0.7rem] tracking-widest uppercase font-bold cyber-font">Üres adatbázis.</p>
                        </div>
                    <% } else { %>
                        <div class="space-y-3">
                            <% validMatches.forEach(match => { %>
                                <div class="bg-[#010a13] border <%= match.final_position === 1 ? 'border-yellow-500/50 shadow-[0_0_10px_rgba(234,179,8,0.1)]' : 'border-[#c8aa6e]/20' %> p-3 rounded-sm flex flex-col items-start gap-2 hover:border-[#c8aa6e]/50 transition-colors">
                                    <div class="w-full flex justify-between items-center border-b border-[#c8aa6e]/10 pb-1">
                                        <div class="font-bold text-slate-200 text-sm tracking-wide truncate cyber-font"><%= match.lobby_name %></div>
                                        <div class="text-[0.6rem] text-slate-500 font-mono"><%= new Date(match.played_at).toLocaleDateString('hu-HU') %></div>
                                    </div>
                                    <div class="w-full flex justify-between items-center">
                                        <div class="text-[0.7rem] font-bold tracking-widest uppercase <%= match.final_position === 1 ? 'text-yellow-400' : 'text-[#c8aa6e]' %>">
                                            <%= match.final_position === 1 ? '🏆 Bajnok' : `SYS.RANK: ${match.final_position}.` %>
                                        </div>
                                        <div class="flex gap-1">
                                            <img src="/images/players/<%= match.roster_summary.top.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-6 h-6 rounded-sm object-cover object-top border border-[#c8aa6e]/30" title="Top">
                                            <img src="/images/players/<%= match.roster_summary.jng.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-6 h-6 rounded-sm object-cover object-top border border-[#c8aa6e]/30" title="Jungle">
                                            <img src="/images/players/<%= match.roster_summary.mid.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-6 h-6 rounded-sm object-cover object-top border border-[#c8aa6e]/30" title="Mid">
                                            <img src="/images/players/<%= match.roster_summary.adc.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-6 h-6 rounded-sm object-cover object-top border border-[#c8aa6e]/30" title="ADC">
                                            <img src="/images/players/<%= match.roster_summary.sup.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-6 h-6 rounded-sm object-cover object-top border border-[#c8aa6e]/30" title="Support">
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <!-- LEADERBOARD -->
                <div class="hex-panel p-6 rounded-sm">
                    <h2 class="text-sm font-bold text-[#c8aa6e] uppercase tracking-widest border-b border-[#c8aa6e]/30 pb-2 mb-4 cyber-font">Globális ranglista</h2>
                    <div class="space-y-2">
                        <% 
                        const validLeaderboard = leaderboard
                            .filter(u => u && u.username && !u.username.toLowerCase().includes('törölt') && !u.username.toLowerCase().includes('anonim') && !u.username.toLowerCase().startsWith('deleted'))
                            .slice(0, 10);
                        
                        validLeaderboard.forEach((user, index) => { 
                            let rankColor = 'text-slate-400';
                            let bgClass = 'bg-[#010a13] border-[#c8aa6e]/20 hover:border-[#c8aa6e]/50 transition-colors';
                            
                            if(index === 0) { rankColor = 'text-yellow-400 font-black drop-shadow-[0_0_5px_rgba(234,179,8,0.5)]'; bgClass = 'bg-[#091428] border-yellow-500/50 shadow-[0_0_10px_rgba(234,179,8,0.1)]'; }
                            else if(index === 1) { rankColor = 'text-slate-300 font-bold'; bgClass = 'bg-[#091428] border-slate-400/50'; }
                            else if(index === 2) { rankColor = 'text-orange-500 font-bold'; bgClass = 'bg-[#091428] border-orange-700/50'; }
                        %>
                            <div class="border <%= bgClass %> p-2 rounded-sm flex justify-between items-center">
                                <div class="flex items-center gap-2">
                                    <span class="font-mono w-5 text-center text-xs <%= rankColor %>"><%= index + 1 %>.</span>
                                    <span class="text-xs font-bold text-slate-200 truncate max-w-[150px] cyber-font"><%= user.username %></span>
                                </div>
                                <span class="text-[#c8aa6e] font-bold text-xs tracking-wider">🏆 <%= user.trophies_count %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT SIDEBAR (Social Panel) -->
    <div class="w-80 bg-[#091428] border-l border-[#c8aa6e]/30 flex flex-col h-full z-20 shadow-[-10px_0_30px_rgba(0,0,0,0.5)]">
        <!-- Profile Header -->
        <div class="p-4 border-b border-[#c8aa6e]/30 bg-[#010a13] flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name=<%= username %>&background=091428&color=c8aa6e&bold=true" class="w-10 h-10 rounded-sm border border-[#c8aa6e]/50">
                    <div class="absolute -bottom-1 -right-1 w-3 h-3 bg-emerald-500 rounded-full border border-[#010a13]"></div>
                </div>
                <div>
                    <div class="font-bold text-sm text-white cyber-font truncate w-32"><%= username %></div>
                    <div class="text-[0.65rem] text-[#c8aa6e] font-bold">🏆 <%= trophies %> Trófea</div>
                </div>
            </div>
            <div class="flex gap-2">
                <button onclick="window.location.href='/profile'" class="text-slate-400 hover:text-[#c8aa6e] transition-colors" title="Beállítások">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </button>
                <button onclick="logout()" class="text-slate-400 hover:text-red-500 transition-colors" title="Kilépés">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </button>
            </div>
        </div>

        <!-- Social Search -->
        <div class="p-3 border-b border-[#c8aa6e]/20 bg-[#091428]">
            <div class="relative">
                <input type="text" id="friendSearchInput" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm py-1.5 pl-8 pr-2 text-xs text-[#f0e6d2] focus:outline-none focus:border-[#c8aa6e]" placeholder="Keresés..." onkeypress="if(event.key === 'Enter') searchFriends()">
                <svg class="w-3.5 h-3.5 text-[#c8aa6e] absolute left-2.5 top-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
        </div>

        <div id="searchResults" class="p-2 space-y-1 empty:hidden border-b border-[#c8aa6e]/20 bg-[#010a13]"></div>

        <!-- Friends List -->
        <div class="flex-1 overflow-y-auto p-2 space-y-4">
            
            <% 
            const accepted = friends.filter(f => f.status === 'ACCEPTED');
            const pendingRequests = friends.filter(f => f.status === 'PENDING' && f.action_user_id !== userId);
            %>

            <div id="pendingRequestsContainer" class="<%= pendingRequests.length > 0 ? '' : 'hidden' %>">
                <% if (pendingRequests.length > 0) { %>
                    <div class="text-[0.6rem] font-bold text-slate-400 uppercase tracking-widest mb-1 px-2">Jelölések (<%= pendingRequests.length %>)</div>
                    <div class="space-y-1">
                        <% pendingRequests.forEach(req => { %>
                            <div class="bg-[#1e2328] border border-blue-500/30 p-2 rounded-sm flex justify-between items-center">
                                <span class="text-xs font-bold text-white truncate"><%= req.friend_name %></span>
                                <div class="flex gap-1 shrink-0">
                                    <button onclick="handleFriendAction('accept', '<%= req.friend_id %>')" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[0.6rem] px-1.5 py-0.5 rounded-sm">✓</button>
                                    <button onclick="handleFriendAction('remove', '<%= req.friend_id %>')" class="bg-red-600 hover:bg-red-500 text-white text-[0.6rem] px-1.5 py-0.5 rounded-sm">✕</button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <div id="acceptedFriendsContainer">
                <div class="text-[0.6rem] font-bold text-slate-400 uppercase tracking-widest mb-1 px-2">Kapcsolatok (<%= accepted.length %>)</div>
                <div class="space-y-0.5">
                    <% if (accepted.length === 0) { %>
                        <p class="text-slate-600 text-[0.65rem] italic px-2">Nincs aktív kapcsolat.</p>
                    <% } else { %>
                        <% accepted.forEach(friend => { %>
                            <div class="group flex justify-between items-center p-2 rounded-sm cursor-pointer hover:bg-[#1e2328] transition-colors" onclick="openFriendChat('<%= friend.friend_id %>', '<%= friend.friend_name %>')">
                                <div class="flex items-center gap-2">
                                    <div class="relative">
                                        <img src="https://ui-avatars.com/api/?name=<%= friend.friend_name %>&background=1e2328&color=c8aa6e&bold=true&size=32" class="w-6 h-6 rounded-sm border border-[#c8aa6e]/30 group-hover:border-[#c8aa6e]">
                                        <span id="unread_<%= friend.friend_id %>" class="hidden absolute -top-1 -right-1 w-2 h-2 rounded-full bg-[#ff0092] animate-pulse shadow-[0_0_5px_#ff0092]"></span>
                                    </div>
                                    <span class="text-xs font-bold text-slate-300 group-hover:text-white truncate max-w-[120px]"><%= friend.friend_name %></span>
                                </div>
                                <button onclick="event.stopPropagation(); handleFriendAction('remove', '<%= friend.friend_id %>')" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 text-[0.6rem] transition-opacity uppercase font-bold">X</button>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- FLOATING CHAT OVERLAY (LoL Style) -->
    <div id="chatOverlay" class="fixed bottom-0 right-[320px] w-[550px] h-[320px] bg-[#010a13] border-t border-l border-r border-[#c8aa6e]/40 flex z-50 hidden rounded-t-md shadow-[-5px_-5px_20px_rgba(0,0,0,0.5)]">
        <!-- Bal panel: Aktív beszélgetések -->
        <div class="w-1/3 border-r border-[#c8aa6e]/20 bg-[#091428] flex flex-col">
            <div class="p-2 border-b border-[#c8aa6e]/20 text-[#c8aa6e] text-[0.6rem] font-bold uppercase tracking-widest bg-[#1e2328]">Aktív Csevegések</div>
            <div id="activeChatSessionsList" class="flex-1 overflow-y-auto bg-[#010a13]">
                <!-- Javascript tölti fel -->
            </div>
        </div>
        <!-- Jobb panel: Üzenetek -->
        <div class="w-2/3 flex flex-col relative">
            <div class="p-2 border-b border-[#c8aa6e]/20 bg-[#1e2328] flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                    <span id="currentChatFriendName" class="text-[#f0e6d2] text-xs font-bold cyber-font"></span>
                </div>
                <button onclick="closeChatOverlay()" class="text-slate-400 hover:text-[#c8aa6e] text-sm">✕</button>
            </div>
            <div id="chatMessageList" class="flex-1 overflow-y-auto p-3 flex flex-col bg-gradient-to-b from-[#010a13] to-[#091428]">
                <!-- Javascript tölti fel -->
            </div>
            <div class="p-2 border-t border-[#c8aa6e]/20 bg-[#091428]">
                <input type="text" id="chatInputField" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-3 py-1.5 text-[#f0e6d2] focus:outline-none focus:border-[#c8aa6e] text-xs font-sans" placeholder="Üzenet küldése..." onkeypress="handleChatInput(event)">
            </div>
        </div>
    </div>

    <!-- TOAST CONTAINER -->
    <div id="toastContainer" class="fixed bottom-4 right-[340px] z-50 flex flex-col gap-2 pointer-events-none"></div>

    <script>
        const socket = io();
        const USER_ID = '<%= userId %>';
        const USERNAME = '<%= username %>';

        // CHAT ÁLLAPOT
        let activeChats = []; // { id, name }
        let currentChatFriendId = null;
        let lastSender = null;

        socket.emit('identify', { userId: USER_ID });

        socket.on('receive_private_message', (data) => {
            if (currentChatFriendId === data.senderId) {
                appendChatMessage(data.senderName, data.message, false);
            } else {
                const unreadDot = document.getElementById(`unread_${data.senderId}`);
                if(unreadDot) unreadDot.classList.remove('hidden');
            }
        });

        socket.on('friend_update', () => { refreshFriendsUI(); });
        socket.on('lobby_invite_received', (data) => { showToast('MEGHÍVÓ', `<span class="font-bold text-[#c8aa6e]">${data.fromUser}</span> lobbiba hívott!`, 'invite', data); });

        // Biztonságos renderelés (Névcsoportosítás, 10 üzenet kliens limit)
        function appendChatMessage(sender, msg, isSelf, isSystem = false) {
            const list = document.getElementById('chatMessageList');
            
            if (isSystem) {
                const msgDiv = document.createElement('div');
                msgDiv.className = 'sys-msg';
                msgDiv.textContent = `[ ${msg} ]`;
                list.appendChild(msgDiv);
                lastSender = null; 
                return;
            }

            let msgDiv;
            if (sender === lastSender) {
                msgDiv = list.lastElementChild;
                if (msgDiv && !msgDiv.classList.contains('sys-msg')) {
                    const textSpan = document.createElement('span');
                    textSpan.className = `text mt-0.5 block`;
                    textSpan.textContent = msg;
                    msgDiv.appendChild(textSpan);
                } else {
                    lastSender = null;
                    appendChatMessage(sender, msg, isSelf, false);
                    return;
                }
            } else {
                msgDiv = document.createElement('div');
                msgDiv.className = `chat-msg ${isSelf ? 'self items-end' : 'items-start'}`;
                
                const senderSpan = document.createElement('span');
                senderSpan.className = 'sender';
                senderSpan.textContent = isSelf ? 'Te' : sender;
                
                const textSpan = document.createElement('span');
                textSpan.className = `text block max-w-[85%] rounded-sm px-2 py-1 ${isSelf ? 'bg-[#1e2328] border border-[#c8aa6e]/30' : 'bg-[#c8aa6e]/10 border border-[#c8aa6e]/20'}`;
                textSpan.textContent = msg; 
                
                msgDiv.appendChild(senderSpan);
                msgDiv.appendChild(textSpan);
                list.appendChild(msgDiv);
                
                lastSender = sender;
            }

            const allTexts = list.querySelectorAll('.text');
            if (allTexts.length > 10) {
                const oldestText = allTexts[0];
                const parent = oldestText.parentElement;
                oldestText.remove();
                if (parent.querySelectorAll('.text').length === 0) { parent.remove(); }
            }

            list.scrollTop = list.scrollHeight;
        }

        function renderActiveChatsList() {
            const container = document.getElementById('activeChatSessionsList');
            container.innerHTML = '';
            activeChats.forEach(chat => {
                const isActive = chat.id === currentChatFriendId;
                container.innerHTML += `
                    <div class="flex items-center gap-2 p-2 cursor-pointer border-l-2 ${isActive ? 'bg-[#1e2328] border-[#c8aa6e]' : 'border-transparent hover:bg-[#091428]'}" onclick="openFriendChat('${chat.id}', '${chat.name}')">
                        <img src="https://ui-avatars.com/api/?name=${chat.name}&background=010a13&color=c8aa6e&bold=true&size=24" class="w-6 h-6 rounded-sm border border-[#c8aa6e]/30">
                        <span class="text-xs ${isActive ? 'text-white font-bold' : 'text-slate-400'} truncate">${chat.name}</span>
                    </div>
                `;
            });
        }

        function openFriendChat(friendId, friendName) {
            document.getElementById('chatOverlay').classList.remove('hidden');
            
            const unreadDot = document.getElementById(`unread_${friendId}`);
            if(unreadDot) unreadDot.classList.add('hidden');

            if (!activeChats.find(c => c.id === friendId)) {
                activeChats.push({ id: friendId, name: friendName });
            }
            
            currentChatFriendId = friendId;
            document.getElementById('currentChatFriendName').textContent = friendName;
            renderActiveChatsList();

            const list = document.getElementById('chatMessageList');
            list.innerHTML = ''; 
            lastSender = null;

            socket.emit('fetch_private_history', { userId: USER_ID, friendId: friendId }, (res) => {
                list.innerHTML = ''; 
                appendChatMessage('SYSTEM', `Titkosítás: Aktív.`, false, true);
                if (res.status === 'success') {
                    res.messages.forEach(m => { appendChatMessage(m.sender_name, m.content, m.sender_id === USER_ID); });
                }
            });

            document.getElementById('chatInputField').focus();
        }

        function closeChatOverlay() {
            document.getElementById('chatOverlay').classList.add('hidden');
            currentChatFriendId = null;
            lastSender = null;
            renderActiveChatsList();
        }

        function handleChatInput(e) {
            if (e.key === 'Enter') {
                const input = document.getElementById('chatInputField');
                const msg = input.value.trim();
                
                if (msg && currentChatFriendId) {
                    appendChatMessage(USERNAME, msg, true);
                    socket.emit('send_private_message', { senderId: USER_ID, targetId: currentChatFriendId, message: msg.substring(0, 250) });
                    input.value = '';
                }
            }
        }

        async function refreshFriendsUI() {
            try {
                const res = await fetch('/api/friends/all');
                if (!res.ok) return;
                const friends = await res.json();
                
                const accepted = friends.filter(f => f.status === 'ACCEPTED');
                const pendingRequests = friends.filter(f => f.status === 'PENDING' && f.action_user_id !== USER_ID);

                const pendingContainer = document.getElementById('pendingRequestsContainer');
                if (pendingRequests.length > 0) {
                    let html = '<div class="text-[0.6rem] font-bold text-slate-400 uppercase tracking-widest mb-1 px-2">Jelölések ('+pendingRequests.length+')</div><div class="space-y-1">';
                    pendingRequests.forEach(req => {
                        html += `<div class="bg-[#1e2328] border border-blue-500/30 p-2 rounded-sm flex justify-between items-center"><span class="text-xs font-bold text-white truncate">${req.friend_name}</span><div class="flex gap-1 shrink-0"><button onclick="handleFriendAction('accept', '${req.friend_id}')" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[0.6rem] px-1.5 py-0.5 rounded-sm">✓</button><button onclick="handleFriendAction('remove', '${req.friend_id}')" class="bg-red-600 hover:bg-red-500 text-white text-[0.6rem] px-1.5 py-0.5 rounded-sm">✕</button></div></div>`;
                    });
                    html += '</div>'; pendingContainer.innerHTML = html; pendingContainer.classList.remove('hidden');
                } else { pendingContainer.innerHTML = ''; pendingContainer.classList.add('hidden'); }

                const acceptedContainer = document.getElementById('acceptedFriendsContainer');
                let acceptedHtml = `<div class="text-[0.6rem] font-bold text-slate-400 uppercase tracking-widest mb-1 px-2">Kapcsolatok (${accepted.length})</div><div class="space-y-0.5">`;
                if (accepted.length === 0) { acceptedHtml += '<p class="text-slate-600 text-[0.65rem] italic px-2">Nincs aktív kapcsolat.</p>'; } 
                else {
                    accepted.forEach(friend => {
                        acceptedHtml += `
                            <div class="group flex justify-between items-center p-2 rounded-sm cursor-pointer hover:bg-[#1e2328] transition-colors" onclick="openFriendChat('${friend.friend_id}', '${friend.friend_name}')">
                                <div class="flex items-center gap-2">
                                    <div class="relative">
                                        <img src="https://ui-avatars.com/api/?name=${friend.friend_name}&background=1e2328&color=c8aa6e&bold=true&size=32" class="w-6 h-6 rounded-sm border border-[#c8aa6e]/30 group-hover:border-[#c8aa6e]">
                                        <span id="unread_${friend.friend_id}" class="hidden absolute -top-1 -right-1 w-2 h-2 rounded-full bg-[#ff0092] animate-pulse shadow-[0_0_5px_#ff0092]"></span>
                                    </div>
                                    <span class="text-xs font-bold text-slate-300 group-hover:text-white truncate max-w-[120px]">${friend.friend_name}</span>
                                </div>
                                <button onclick="event.stopPropagation(); handleFriendAction('remove', '${friend.friend_id}')" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 text-[0.6rem] transition-opacity uppercase font-bold">X</button>
                            </div>
                        `;
                    });
                }
                acceptedHtml += '</div>'; acceptedContainer.innerHTML = acceptedHtml;
            } catch (error) { console.error("Hiba:", error); }
        }

        function showToast(title, message, type, extraData = null) {
            const toast = document.createElement('div');
            toast.className = `bg-[#091428] border ${type === 'success' ? 'border-[#c8aa6e]' : 'border-red-500'} p-3 rounded-sm shadow-xl min-w-[250px] pointer-events-auto transform transition-all translate-x-full opacity-0 relative overflow-hidden`;
            
            let actionHtml = '';
            if (type === 'invite') {
                actionHtml = `<div class="mt-2 flex gap-2"><button onclick="acceptInvite('${extraData.inviteCode}')" class="flex-1 bg-[#c8aa6e] text-[#010a13] px-2 py-1 text-[0.65rem] font-bold uppercase tracking-widest rounded-sm hover:bg-white transition-colors">Csatlakozás</button></div>`;
            }

            toast.innerHTML = `
                <h4 class="text-[${type === 'success' ? '#c8aa6e' : '#fff'}] font-bold text-[0.7rem] tracking-wider uppercase cyber-font">${title}</h4>
                <p class="text-slate-300 text-[0.65rem] mt-1">${message}</p>
                ${actionHtml}
            `;

            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => { toast.classList.remove('translate-x-full', 'opacity-0'); }, 50);

            if (type !== 'invite') { setTimeout(() => { toast.classList.add('translate-x-full', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 5000); }
        }

        function acceptInvite(code) {
            socket.emit('join_lobby', { userId: USER_ID, inviteCode: code }, (response) => {
                if (response.status === 'success') { window.location.href = `/lobby/${response.lobbyId}`; } else { alert(response.message); }
            });
        }

        document.getElementById('createLobbyBtn').addEventListener('click', () => {
            document.getElementById('createLobbyBtn').querySelector('.cosmic-btn-text').innerText = 'Inicializálás...';
            socket.emit('create_lobby', { userId: USER_ID }, (response) => {
                if (response.status === 'success') { window.location.href = `/lobby/${response.lobbyId}`; } else { alert(response.message); document.getElementById('createLobbyBtn').querySelector('.cosmic-btn-text').innerText = 'Létrehozás'; }
            });
        });

        document.getElementById('joinLobbyBtn').addEventListener('click', () => {
            const code = document.getElementById('inviteCodeInput').value.trim().toUpperCase();
            if (code.length !== 6) return alert('Érvénytelen kód!'); acceptInvite(code);
        });

        async function logout() { await fetch('/api/auth/logout', { method: 'POST' }); window.location.href = '/login'; }

        async function searchFriends() {
            const q = document.getElementById('friendSearchInput').value.trim();
            if(q.length < 3) return alert('Min. 3 karakter.');
            try {
                const res = await fetch(`/api/friends/search?q=${encodeURIComponent(q)}`); const data = await res.json();
                const resultsContainer = document.getElementById('searchResults'); resultsContainer.innerHTML = '';
                if (data.length === 0) { resultsContainer.innerHTML = '<p class="text-[0.6rem] text-slate-500 italic">Nincs találat.</p>'; return; }
                data.forEach(user => { resultsContainer.innerHTML += `<div id="search-result-${user.id}" class="bg-transparent py-1 flex justify-between items-center transition-all duration-300"><div class="flex flex-col"><span class="text-xs font-bold text-white cyber-font">${user.username}</span><span class="text-[0.55rem] text-[#c8aa6e] font-bold">🏆 ${user.trophies_count}</span></div><button id="addBtn_${user.id}" onclick="sendFriendRequest('${user.id}')" class="bg-transparent hover:bg-[#c8aa6e]/10 border border-[#c8aa6e]/50 text-[#c8aa6e] text-[0.55rem] font-bold uppercase tracking-widest px-2 py-1 rounded-sm transition-colors">+</button></div>`; });
            } catch (error) { alert('Hálózat megszakadt.'); }
        }

        async function sendFriendRequest(targetId) {
            const btn = document.getElementById(`addBtn_${targetId}`);
            if(btn) { btn.innerText = '...'; btn.disabled = true; }
            try {
                const res = await fetch('/api/friends/request', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetUserId: targetId }) });
                const data = await res.json();
                if (data.status !== 'success') { alert(data.error || 'Hiba történt.'); if(btn) { btn.innerText = '+'; btn.disabled = false; } } 
                else { showToast('Jelölés elküldve!', 'Sikeres.', 'success'); const resultCard = document.getElementById(`search-result-${targetId}`); if (resultCard) { resultCard.style.opacity = '0'; setTimeout(() => resultCard.remove(), 300); } }
            } catch (error) { alert('Hálózati hiba.'); if(btn) { btn.innerText = '+'; btn.disabled = false; } }
        }

        async function handleFriendAction(action, targetId) {
            try {
                const res = await fetch(`/api/friends/${action}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetUserId: targetId }) });
                const data = await res.json();
                if (data.status !== 'success') { alert(data.error || 'Művelet megtagadva.'); } else { refreshFriendsUI(); }
            } catch (error) { alert('Hálózati hiba.'); }
        }
    </script>
</body>
</html>