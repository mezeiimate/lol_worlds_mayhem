                </div>
            </div>
        </header>

        <main class="grid grid-cols-1 xl:grid-cols-12 gap-6">
            
            <!-- LEFT COLUMN: FRIENDS & CHAT -->
            <div class="xl:col-span-3 space-y-6 flex flex-col">
                <div class="hex-panel p-5 flex-shrink-0">
                    <h2 class="text-sm font-bold text-[#00e5ff] uppercase tracking-widest border-b border-[#00e5ff]/30 pb-2 mb-4 cyber-font">Kapcsolatok</h2>
                    
                    <!-- COSMIC SEARCH BAR -->
                    <div class="search-container">
                        <div class="search-nebula"></div>
                        <input type="text" id="friendSearchInput" class="search-input" placeholder="Felhasználó keresése..." onkeypress="if(event.key === 'Enter') searchFriends()">
                        <div class="search-icon">
                            <svg stroke-linejoin="round" stroke-linecap="round" stroke-width="2" stroke="#00e5ff" fill="none" height="20" width="20" viewBox="0 0 24 24">
                                <circle r="8" cy="11" cx="11" />
                                <line y2="16.65" x2="16.65" y1="21" x1="21" />
                            </svg>
                        </div>
                        <button onclick="searchFriends()" class="wormhole-btn">
                            <svg stroke-linejoin="round" stroke-linecap="round" stroke-width="2" stroke="#ff0092" fill="none" height="20" width="20" viewBox="0 0 24 24">
                                <circle r="10" cy="12" cx="12" />
                                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                                <path d="M2 12h20" />
                            </svg>
                        </button>
                    </div>

                    <div id="searchResults" class="space-y-2 mb-6 empty:hidden max-h-40 overflow-y-auto pr-1"></div>

                    <% 
                    const accepted = friends.filter(f => f.status === 'ACCEPTED');
                    const pendingRequests = friends.filter(f => f.status === 'PENDING' && f.action_user_id !== userId);
                    %>

                    <div id="pendingRequestsContainer" class="<%= pendingRequests.length > 0 ? '' : 'hidden' %>">
                        <% if (pendingRequests.length > 0) { %>
                            <h3 class="text-[0.65rem] font-bold text-slate-400 uppercase tracking-widest mb-2 cyber-font">Bejövő jelölések</h3>
                            <div class="space-y-2 mb-4">
                                <% pendingRequests.forEach(req => { %>
                                    <div class="bg-[#010a13] border border-[#00e5ff]/30 p-2 rounded-sm flex justify-between items-center">
                                        <span class="text-xs font-bold text-white"><%= req.friend_name %></span>
                                        <div class="flex gap-1">
                                            <button onclick="handleFriendAction('accept', '<%= req.friend_id %>')" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[0.6rem] px-2 py-1 rounded-sm">✓</button>
                                            <button onclick="handleFriendAction('remove', '<%= req.friend_id %>')" class="bg-red-600 hover:bg-red-500 text-white text-[0.6rem] px-2 py-1 rounded-sm">✕</button>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>

                    <div id="acceptedFriendsContainer">
                        <h3 class="text-[0.65rem] font-bold text-slate-400 uppercase tracking-widest mb-2 cyber-font">Barátaim (<%= accepted.length %>)</h3>
                        <div class="space-y-2 max-h-48 overflow-y-auto pr-1">
                            <% if (accepted.length === 0) { %>
                                <p class="text-slate-500 text-[0.7rem] italic cyber-font">Nincs aktív kapcsolat.</p>
                            <% } else { %>
                                <% accepted.forEach(friend => { %>
                                    <!-- Barátra kattintva megnyílik a terminal chat -->
                                    <div class="bg-[#010a13] border border-[#00e5ff]/20 p-2 rounded-sm flex justify-between items-center group cursor-pointer hover:border-[#ff0092]/50 transition-colors" onclick="openFriendChat('<%= friend.friend_id %>', '<%= friend.friend_name %>')">
                                        <div class="flex items-center gap-2">
                                            <div class="w-1.5 h-1.5 rounded-full bg-[#00e5ff] shadow-[0_0_5px_#00e5ff] group-hover:bg-[#ff0092] group-hover:shadow-[0_0_5px_#ff0092] transition-colors"></div>
                                            <span class="text-xs font-bold text-slate-200"><%= friend.friend_name %></span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[0.6rem] text-[#ff0092] font-bold">🏆 <%= friend.trophies_count %></span>
                                            <button onclick="event.stopPropagation(); handleFriendAction('remove', '<%= friend.friend_id %>')" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 text-[0.6rem] transition-opacity uppercase font-bold">Del</button>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- TERMINAL CHAT BOX -->
                <div id="terminalChatContainer" class="hidden flex-1">
                    <div class="terminal-container h-full">
                        <div class="terminal-toolbar">
                            <div class="terminal-butt">
                                <button class="terminal-btn t-btn-r" onclick="closeChat()"></button>
                                <button class="terminal-btn t-btn-y"></button>
                                <button class="terminal-btn t-btn-g"></button>
                            </div>
                            <p class="terminal-user-title" id="terminalHeaderName">SYS.COM</p>
                            <div class="text-slate-600 text-xs">v1.0</div>
                        </div>
                        <div class="terminal-body" id="chatMessageList">
                            <!-- JS tölti fel -->
                        </div>
                        <div class="terminal-prompt">
                            <span class="term-user"><%= username.substring(0,5) %>@sys:</span>
                            <span class="term-loc">~</span>
                            <span class="term-bling">$</span>
                            <input type="text" id="chatInputField" class="term-input" autocomplete="off" onkeypress="handleChatInput(event)">
                            <span class="term-cursor"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CENTER COLUMN: LOBBY & HISTORY -->
            <div class="xl:col-span-6 space-y-6">
                <!-- LOBBY ACTIONS -->
                <div class="hex-panel p-8 flex flex-col md:flex-row gap-8 items-center justify-center relative">
                    <div class="flex-1 text-center border-r border-[#00e5ff]/30 pr-8">
                        <h2 class="text-xl font-bold text-white uppercase tracking-widest mb-2 esport-font">LoL Worlds Mayhem</h2>
                        <p class="text-slate-400 text-xs mb-4 cyber-font">Állítsd fel a szobát és dominálj!</p>
                        <div class="w-full">
                            <button id="createLobbyBtn" class="cosmic-portal-btn w-full !py-3">
                                <span class="btn-text">Létrehozás</span>
                                <div class="portal-effect"></div>
                            </button>
                        </div>
                    </div>
                    
                    <div class="flex-1 text-center pl-8">
                        <h2 class="text-xl font-bold text-[#ff0092] uppercase tracking-widest mb-2 esport-font">Csatlakozás</h2>
                        <p class="text-slate-400 text-xs mb-4 cyber-font">Kód alapú szinkronizáció.</p>
                        <div class="flex gap-2">
                            <input type="text" id="inviteCodeInput" placeholder="XXXXXX" maxlength="6" class="w-full bg-[#010a13] border border-[#ff0092]/50 rounded-sm px-4 py-2 text-center text-lg font-mono text-[#ff0092] uppercase tracking-widest focus:outline-none focus:border-[#00e5ff] focus:shadow-[0_0_10px_rgba(0,229,255,0.3)] transition-all">
                            <button id="joinLobbyBtn" class="bg-[#1e2328] hover:bg-[#ff0092] border border-[#ff0092]/50 text-white px-5 font-bold rounded-sm transition-colors uppercase text-sm cyber-font">→</button>
                        </div>
                    </div>
                </div>

                <!-- MATCH HISTORY -->
                <div class="hex-panel p-6">
                    <div class="flex justify-between items-center border-b border-[#00e5ff]/30 pb-2 mb-4 cursor-pointer group" onclick="toggleHistory()">
                        <h2 class="text-sm font-bold text-[#00e5ff] uppercase tracking-widest cyber-font group-hover:text-white transition-colors">Archívum (Utolsó 10)</h2>
                        <span id="historyToggleIcon" class="text-[#00e5ff] transition-transform duration-300">▼</span>
                    </div>
                    
                    <div id="historyContainer" class="hidden">
                        <% const validMatches = matchHistory ? matchHistory.slice(0, 10) : []; %>
                        <% if (validMatches.length === 0) { %>
                            <div class="text-center py-6 border border-dashed border-slate-700/50">
                                <p class="text-slate-500 text-[0.7rem] tracking-widest uppercase font-bold cyber-font">Üres adatbázis.</p>
                            </div>
                        <% } else { %>
                            <div class="space-y-3 max-h-[400px] overflow-y-auto pr-2" style="scrollbar-width: thin; scrollbar-color: #00e5ff transparent;">
                                <% validMatches.forEach(match => { %>
                                    <div class="bg-[#010a13] border <%= match.final_position === 1 ? 'border-yellow-500/50 shadow-[0_0_10px_rgba(234,179,8,0.1)]' : 'border-[#00e5ff]/20' %> p-3 rounded-sm flex flex-col md:flex-row items-center justify-between gap-4 transition-all hover:border-[#ff0092]/50">
                                        <div class="flex-1 min-w-0 text-center md:text-left">
                                            <div class="text-[0.6rem] text-slate-500 font-mono mb-0.5"><%= new Date(match.played_at).toLocaleDateString('hu-HU') %></div>
                                            <div class="font-bold text-slate-200 text-sm tracking-wide truncate cyber-font"><%= match.lobby_name %></div>
                                            <div class="text-[0.7rem] font-bold tracking-widest mt-1 uppercase <%= match.final_position === 1 ? 'text-yellow-400' : 'text-[#ff0092]' %>">
                                                <%= match.final_position === 1 ? '🏆 Bajnok' : `SYS.RANK: ${match.final_position}.` %>
                                            </div>
                                        </div>
                                        <div class="flex gap-1.5 bg-[#091428] p-1.5 rounded-sm border border-[#00e5ff]/20">
                                            <img src="/images/players/<%= match.roster_summary.top.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-8 h-8 rounded-sm object-cover object-top border border-[#c8aa6e]/30 grayscale hover:grayscale-0 transition-all" title="<%= match.roster_summary.top %> (Top)">
                                            <img src="/images/players/<%= match.roster_summary.jng.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-8 h-8 rounded-sm object-cover object-top border border-[#c8aa6e]/30 grayscale hover:grayscale-0 transition-all" title="<%= match.roster_summary.jng %> (Jungle)">
                                            <img src="/images/players/<%= match.roster_summary.mid.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-8 h-8 rounded-sm object-cover object-top border border-[#c8aa6e]/30 grayscale hover:grayscale-0 transition-all" title="<%= match.roster_summary.mid %> (Mid)">
                                            <img src="/images/players/<%= match.roster_summary.adc.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-8 h-8 rounded-sm object-cover object-top border border-[#c8aa6e]/30 grayscale hover:grayscale-0 transition-all" title="<%= match.roster_summary.adc %> (ADC)">
                                            <img src="/images/players/<%= match.roster_summary.sup.replace(/[^a-zA-Z0-9]/g, '') %>.png" onerror="this.onerror=null; this.src='/profile-circle-svgrepo-com.svg';" class="w-8 h-8 rounded-sm object-cover object-top border border-[#c8aa6e]/30 grayscale hover:grayscale-0 transition-all" title="<%= match.roster_summary.sup %> (Support)">
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN: LEADERBOARD -->
            <div class="xl:col-span-3 space-y-6">
                <div class="hex-panel p-5">
                    <h2 class="text-sm font-bold text-[#00e5ff] uppercase tracking-widest border-b border-[#00e5ff]/30 pb-2 mb-4 cyber-font">Globális ranglista</h2>
                    <div class="space-y-2">
                        <% 
                        const validLeaderboard = leaderboard
                            .filter(u => u && u.username && !u.username.toLowerCase().includes('törölt') && !u.username.toLowerCase().includes('anonim') && !u.username.toLowerCase().startsWith('deleted'))
                            .slice(0, 10);
                        
                        validLeaderboard.forEach((user, index) => { 
                            let rankColor = 'text-slate-400';
                            let bgClass = 'bg-[#010a13] border-[#00e5ff]/20 hover:border-[#00e5ff]/50 transition-colors';
                            
                            if(index === 0) { rankColor = 'text-yellow-400 font-black drop-shadow-[0_0_5px_rgba(234,179,8,0.5)]'; bgClass = 'bg-[#091428] border-yellow-500/50 shadow-[0_0_10px_rgba(234,179,8,0.1)]'; }
                            else if(index === 1) { rankColor = 'text-slate-300 font-bold'; bgClass = 'bg-[#091428] border-slate-400/50'; }
                            else if(index === 2) { rankColor = 'text-orange-500 font-bold'; bgClass = 'bg-[#091428] border-orange-700/50'; }
                        %>
                            <div class="border <%= bgClass %> p-2 rounded-sm flex justify-between items-center group">
                                <div class="flex items-center gap-2">
                                    <span class="font-mono w-5 text-center text-xs <%= rankColor %>"><%= index + 1 %>.</span>
                                    <span class="text-xs font-bold text-slate-200 truncate max-w-[100px] cyber-font"><%= user.username %></span>
                                </div>
                                <span class="text-[#ff0092] font-bold text-xs tracking-wider group-hover:drop-shadow-[0_0_5px_rgba(255,0,146,0.5)] transition-all">🏆 <%= user.trophies_count %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script>
        const socket = io();
        const USER_ID = '<%= userId %>';
        const USERNAME = '<%= username %>';

        // TERMINAL CHAT ÁLLAPOT
        let currentChatFriendId = null;

        socket.emit('identify', { userId: USER_ID });

        // Valós idejű üzenetek fogadása
        socket.on('receive_private_message', (data) => {
            if (currentChatFriendId === data.senderId) {
                appendChatMessage(data.senderName, data.message, false);
            } else {
                showToast('Bejövő átvitel', `Üzenet tőle: ${data.senderName}`, 'chat');
            }
        });

        socket.on('friend_update', () => { refreshFriendsUI(); });

        socket.on('lobby_invite_received', (data) => {
            showToast('SYS.INVITE', `<span class="font-bold text-[#00e5ff]">${data.fromUser}</span> szinkronizációt kezdeményezett!`, 'invite', data);
        });

        // Biztonságos renderelés (Zero Trust, XSS védelem textContent-tel)
        function appendChatMessage(sender, msg, isSelf) {
            const list = document.getElementById('chatMessageList');
            const msgDiv = document.createElement('div');
            msgDiv.className = `chat-msg ${isSelf ? 'self' : ''}`;
            
            const senderSpan = document.createElement('span');
            senderSpan.className = 'sender';
            senderSpan.textContent = `${sender}:`;
            
            const textSpan = document.createElement('span');
            textSpan.className = 'text';
            textSpan.textContent = msg; 
            
            msgDiv.appendChild(senderSpan);
            msgDiv.appendChild(textSpan);
            
            list.insertBefore(msgDiv, list.lastElementChild);
            list.scrollTop = list.scrollHeight;
        }

        // Chat ablak megnyitása és előzmények lekérése
        function openFriendChat(friendId, friendName) {
            currentChatFriendId = friendId;
            document.getElementById('terminalChatContainer').classList.remove('hidden');
            document.getElementById('terminalHeaderName').textContent = `SEC_CHANNEL // ${friendName}`;
            
            const list = document.getElementById('chatMessageList');
            Array.from(list.children).forEach(child => {
                if(child.tagName === 'DIV' && child.classList.contains('chat-msg')) { child.remove(); }
            });

            appendChatMessage('SYSTEM', `Kapcsolat felépítve ${friendName}-val. Szinkronizálás...`, false);

            socket.emit('fetch_private_history', { userId: USER_ID, friendId: friendId }, (res) => {
                if (res.status === 'success') {
                    Array.from(list.children).forEach(child => {
                        if(child.tagName === 'DIV' && child.classList.contains('chat-msg')) { child.remove(); }
                    });
                    appendChatMessage('SYSTEM', `Titkosítás: Aktív. Csatorna nyitva.`, false);
                    
                    res.messages.forEach(m => {
                        appendChatMessage(m.sender_name, m.content, m.sender_id === USER_ID);
                    });
                }
            });

            document.getElementById('chatInputField').focus();
        }

        function closeChat() {
            currentChatFriendId = null;
            document.getElementById('terminalChatContainer').classList.add('hidden');
        }

        function handleChatInput(e) {
            if (e.key === 'Enter') {
                const input = document.getElementById('chatInputField');
                const msg = input.value.trim();
                
                if (msg && currentChatFriendId) {
                    appendChatMessage(USERNAME, msg, true);
                    
                    socket.emit('send_private_message', {
                        senderId: USER_ID,
                        targetId: currentChatFriendId,
                        message: msg.substring(0, 250) 
                    });
                    
                    input.value = '';
                }
            }
        }

        function toggleHistory() {
            const container = document.getElementById('historyContainer');
            const icon = document.getElementById('historyToggleIcon');
            if (container.classList.contains('hidden')) {
                container.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                container.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        }

        async function refreshFriendsUI() {
            try {
                const res = await fetch('/api/friends/all');
                if (!res.ok) return;
                const friends = await res.json();
                
                const accepted = friends.filter(f => f.status === 'ACCEPTED');
                const pendingRequests = friends.filter(f => f.status === 'PENDING' && f.action_user_id !== USER_ID);

                const pendingContainer = document.getElementById('pendingRequestsContainer');
                if (pendingRequests.length > 0) {
                    let html = '<h3 class="text-[0.65rem] font-bold text-slate-400 uppercase tracking-widest mb-2 cyber-font">Bejövő jelölések</h3><div class="space-y-2 mb-4">';
                    pendingRequests.forEach(req => {
                        html += `
                            <div class="bg-[#010a13] border border-[#00e5ff]/30 p-2 rounded-sm flex justify-between items-center">
                                <span class="text-xs font-bold text-white">${req.friend_name}</span>
                                <div class="flex gap-1">
                                    <button onclick="handleFriendAction('accept', '${req.friend_id}')" class="bg-emerald-600 hover:bg-emerald-500 text-white text-[0.6rem] px-2 py-1 rounded-sm">✓</button>
                                    <button onclick="handleFriendAction('remove', '${req.friend_id}')" class="bg-red-600 hover:bg-red-500 text-white text-[0.6rem] px-2 py-1 rounded-sm">✕</button>
                                </div>
                            </div>
                        `;
                    });
                    html += '</div>';
                    pendingContainer.innerHTML = html;
                    pendingContainer.classList.remove('hidden');
                } else {
                    pendingContainer.innerHTML = '';
                    pendingContainer.classList.add('hidden');
                }

                const acceptedContainer = document.getElementById('acceptedFriendsContainer');
                let acceptedHtml = `<h3 class="text-[0.65rem] font-bold text-slate-400 uppercase tracking-widest mb-2 cyber-font">Barátaim (${accepted.length})</h3><div class="space-y-2 max-h-48 overflow-y-auto pr-1">`;
                if (accepted.length === 0) {
                    acceptedHtml += '<p class="text-slate-500 text-[0.7rem] italic cyber-font">Nincs aktív kapcsolat.</p>';
                } else {
                    accepted.forEach(friend => {
                        acceptedHtml += `
                            <div class="bg-[#010a13] border border-[#00e5ff]/20 p-2 rounded-sm flex justify-between items-center group cursor-pointer hover:border-[#ff0092]/50 transition-colors" onclick="openFriendChat('${friend.friend_id}', '${friend.friend_name}')">
                                <div class="flex items-center gap-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-[#00e5ff] shadow-[0_0_5px_#00e5ff] group-hover:bg-[#ff0092] transition-colors"></div>
                                    <span class="text-xs font-bold text-slate-200">${friend.friend_name}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-[0.6rem] text-[#ff0092] font-bold">🏆 ${friend.trophies_count}</span>
                                    <button onclick="event.stopPropagation(); handleFriendAction('remove', '${friend.friend_id}')" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 text-[0.6rem] transition-opacity uppercase font-bold">Del</button>
                                </div>
                            </div>
                        `;
                    });
                }
                acceptedHtml += '</div>';
                acceptedContainer.innerHTML = acceptedHtml;
            } catch (error) { 
                console.error("Hiba:", error);
            }
        }

        function showToast(title, message, type, extraData = null) {
            const toast = document.createElement('div');
            toast.className = `bg-[#091428] border ${type === 'success' ? 'border-[#00e5ff]' : 'border-[#ff0092]'} p-4 rounded-sm shadow-xl min-w-[280px] pointer-events-auto transform transition-all translate-x-full opacity-0 relative overflow-hidden`;
            
            const scanLine = `<div class="absolute w-full h-[2px] bg-[${type === 'success' ? '#00e5ff' : '#ff0092'}]/50 top-0 left-0 animate-[scan_2s_infinite]"></div>`;
            
            let actionHtml = '';
            if (type === 'invite') {
                actionHtml = `<div class="mt-3 flex gap-2">
                    <button onclick="acceptInvite('${extraData.inviteCode}')" class="flex-1 bg-[#00e5ff] text-[#010a13] px-3 py-1.5 text-[0.7rem] font-bold uppercase tracking-widest rounded-sm hover:bg-white transition-colors">Csatlakozás</button>
                    <button onclick="this.parentElement.parentElement.remove()" class="flex-1 bg-transparent text-slate-400 px-3 py-1.5 text-[0.7rem] uppercase tracking-widest rounded-sm border border-[#ff0092]/50 hover:bg-[#ff0092]/10 transition-colors">Figyelmen kívül</button>
                </div>`;
            } else if (type === 'chat') {
                 actionHtml = `<div class="mt-2 text-right"><button onclick="this.parentElement.parentElement.remove()" class="text-[0.6rem] text-slate-500 uppercase tracking-widest hover:text-white">Bezárás</button></div>`;
            }

            toast.innerHTML = `
                ${scanLine}
                <h4 class="text-[${type === 'success' ? '#00e5ff' : '#ff0092'}] font-bold text-[0.75rem] tracking-wider uppercase cyber-font">${title}</h4>
                <p class="text-white text-xs mt-1 leading-relaxed">${message}</p>
                ${actionHtml}
            `;

            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => { toast.classList.remove('translate-x-full', 'opacity-0'); }, 50);

            if (type !== 'invite') {
                setTimeout(() => { toast.classList.add('translate-x-full', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 5000);
            }
        }

        function acceptInvite(code) {
            socket.emit('join_lobby', { userId: USER_ID, inviteCode: code }, (response) => {
                if (response.status === 'success') { window.location.href = `/lobby/${response.lobbyId}`; } 
                else { alert(response.message); }
            });
        }

        document.getElementById('createLobbyBtn').addEventListener('click', () => {
            document.getElementById('createLobbyBtn').querySelector('.btn-text').innerText = 'Inicializálás...';
            socket.emit('create_lobby', { userId: USER_ID }, (response) => {
                if (response.status === 'success') { window.location.href = `/lobby/${response.lobbyId}`; } 
                else { alert(response.message); document.getElementById('createLobbyBtn').querySelector('.btn-text').innerText = 'Létrehozás'; }
            });
        });

        document.getElementById('joinLobbyBtn').addEventListener('click', () => {
            const code = document.getElementById('inviteCodeInput').value.trim().toUpperCase();
            if (code.length !== 6) return alert('SYS.ERR: Érvénytelen szinkronizációs kód!');
            acceptInvite(code);
        });

        async function logout() { 
            await fetch('/api/auth/logout', { method: 'POST' }); 
            window.location.href = '/login';
        }

        async function searchFriends() {
            const q = document.getElementById('friendSearchInput').value.trim();
            if(q.length < 3) return alert('Min. 3 karakter szükséges a protokoll futtatásához.');

            try {
                const res = await fetch(`/api/friends/search?q=${encodeURIComponent(q)}`);
                const data = await res.json();
                const resultsContainer = document.getElementById('searchResults');
                resultsContainer.innerHTML = '';

                if (data.length === 0) { 
                    resultsContainer.innerHTML = '<p class="text-[0.65rem] text-slate-500 italic cyber-font">Nincs regisztrált entitás.</p>'; return;
                }
                
                data.forEach(user => {
                    resultsContainer.innerHTML += `
                        <div id="search-result-${user.id}" class="bg-transparent border-b border-[#00e5ff]/20 py-2 flex justify-between items-center transition-all duration-300">
                            <div class="flex flex-col">
                                <span class="text-xs font-bold text-white cyber-font">${user.username}</span>
                                <span class="text-[0.6rem] text-[#ff0092] font-bold">🏆 ${user.trophies_count}</span>
                            </div>
                            <button id="addBtn_${user.id}" onclick="sendFriendRequest('${user.id}')" class="bg-transparent hover:bg-[#00e5ff]/10 border border-[#00e5ff]/50 text-[#00e5ff] text-[0.65rem] font-bold uppercase tracking-widest px-3 py-1.5 rounded-sm transition-colors">Jelölés</button>
                        </div>`;
                });
            } catch (error) { alert('Hálózat megszakadt.'); }
        }

        async function sendFriendRequest(targetId) {
            const btn = document.getElementById(`addBtn_${targetId}`);
            if(btn) { btn.innerText = 'Küldés...'; btn.disabled = true; }
            
            try {
                const res = await fetch('/api/friends/request', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetUserId: targetId })
                });
                const data = await res.json();
                
                if (data.status !== 'success') { 
                    alert(data.error || 'Hiba történt.');
                    if(btn) { btn.innerText = 'Jelölés'; btn.disabled = false; }
                } else {
                    showToast('Jelölés elküldve!', 'Adatcsomag sikeresen továbbítva a célponthoz.', 'success');
                    const resultCard = document.getElementById(`search-result-${targetId}`);
                    if (resultCard) {
                        resultCard.style.opacity = '0';
                        setTimeout(() => resultCard.remove(), 300);
                    }
                }
            } catch (error) { 
                alert('Hálózati hiba.');
                if(btn) { btn.innerText = 'Jelölés'; btn.disabled = false; }
            }
        }

        async function handleFriendAction(action, targetId) {
            try {
                const res = await fetch(`/api/friends/${action}`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetUserId: targetId })
                });
                const data = await res.json();
                if (data.status !== 'success') { alert(data.error || 'Művelet megtagadva.'); }
                else { refreshFriendsUI(); }
            } catch (error) { alert('Hálózati hiba.'); }
        }
    </script>
</body>
</html>