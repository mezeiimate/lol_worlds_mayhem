                    </div>
                    <div class="h-8 w-px bg-[#00e5ff]/50 mx-2"></div>
                    <div class="flex flex-col items-center">
                        <span class="text-2xl leading-none font-black text-[#ff0092] drop-shadow-[0_0_8px_rgba(255,0,146,0.6)]"><%= trophies %></span>
                        <span class="text-[0.6rem] uppercase tracking-widest text-slate-400 font-bold mt-1 cyber-font">Trófea</span>
                    </div>
                </div>
                
                <div class="flex items-center gap-3">
                    <!-- BEÁLLÍTÁSOK / FIÓK GOMB JAVÍTVA -->
