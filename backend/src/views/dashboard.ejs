        #stars:after, #stars2:after, #stars3:after { content: " "; position: absolute; top: 2000px; width: inherit; height: inherit; box-shadow: inherit; }
        @keyframes animStar { from { transform: translateY(0px); } to { transform: translateY(-2000px); } }

        /* --- ANIMATED LOGOUT BUTTON --- */
        .logout-btn {
            display: flex; align-items: center; justify-content: flex-start;
            width: 40px; height: 40px; border: none; border-radius: 50%;
            cursor: pointer; position: relative; overflow: hidden;
            transition-duration: .3s; box-shadow: 0 0 15px rgba(255, 0, 146, 0.4);
            background-color: #ff0092; z-index: 10;
        }
        .logout-sign { width: 100%; transition-duration: .3s; display: flex; align-items: center; justify-content: center; }
        .logout-sign svg { width: 15px; }
        .logout-sign svg path { fill: white; }
        .logout-text { position: absolute; right: 0%; width: 0%; opacity: 0; color: white; font-size: 12px; font-weight: 700; transition-duration: .3s; text-transform: uppercase; font-family: 'Orbitron', sans-serif;}
        .logout-btn:hover { width: 110px; border-radius: 20px; transition-duration: .3s; }
        .logout-btn:hover .logout-sign { width: 30%; transition-duration: .3s; padding-left: 10px; }
        .logout-btn:hover .logout-text { opacity: 1; width: 70%; transition-duration: .3s; padding-right: 10px; }
        .logout-btn:active { transform: translate(2px ,2px); }

        /* --- SETTINGS BUTTON (Fiók) --- */
        .settings-btn {
            display: flex; align-items: center; justify-content: center; gap: 6px;
            background: rgba(0, 229, 255, 0.1); border: 1px solid rgba(0, 229, 255, 0.5);
            padding: 8px 16px; border-radius: 4px; color: #00e5ff; font-family: 'Orbitron', sans-serif;
            font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 10px rgba(0, 229, 255, 0.1);
        }
        .settings-btn:hover {
            background: rgba(0, 229, 255, 0.2); box-shadow: 0 0 15px rgba(0, 229, 255, 0.4);
            color: #fff; transform: translateY(-2px);
        }

        /* --- COSMIC PORTAL BUTTON --- */
        .cosmic-portal-btn {
            --btn-bg: #010a13; --btn-color: #00e5ff; --btn-highlight: #091428;
            --portal-color1: #ff0092; --portal-color2: #00e5ff;
            position: relative; font-family: "Orbitron", sans-serif; font-size: 1em; font-weight: bold;
            letter-spacing: 0.1em; text-transform: uppercase; color: var(--btn-color); background-color: var(--btn-bg);
            border: none; padding: 1em 2em; cursor: pointer; overflow: hidden; transition: all 0.3s ease;
            clip-path: polygon(0% 0%, 100% 0%, 100% 70%, 90% 100%, 10% 100%, 0% 70%);
        }
        .cosmic-portal-btn::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: conic-gradient(from 0deg at 50% 50%, var(--portal-color1) 0deg, var(--portal-color2) 120deg, var(--portal-color1) 240deg, var(--portal-color2) 360deg);
            animation: rotatePortal 4s linear infinite; opacity: 0.4; transition: opacity 0.3s ease;
        }
        .cosmic-portal-btn:hover::before { opacity: 1; }
        .cosmic-portal-btn::after { content: ""; position: absolute; inset: 2px; background-color: var(--btn-bg); clip-path: inherit; z-index: 1; }
        .btn-text { position: relative; z-index: 2; text-shadow: 0 0 10px rgba(0, 229, 255, 0.5); }
        .portal-effect { position: absolute; inset: 0; background: radial-gradient(circle at 50% 50%, var(--btn-highlight), transparent 50%); opacity: 0; transition: opacity 0.3s ease; z-index: 1; }
        .cosmic-portal-btn:hover .portal-effect { opacity: 1; animation: pulsePortal 2s ease-in-out infinite; }
        .cosmic-portal-btn:hover { transform: translateY(-3px); filter: drop-shadow(0 5px 15px rgba(0, 229, 255, 0.4)); color: #fff; }
        .cosmic-portal-btn:active { transform: translateY(0); }
        @keyframes rotatePortal { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes pulsePortal { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

        /* --- COSMIC SEARCH BAR --- */
        .search-container { position: relative; display: flex; align-items: center; justify-content: center; width: 100%; height: 50px; margin-bottom: 1rem; }
        .search-input {
            background-color: rgba(5, 7, 27, 0.8); border: 1px solid rgba(0,229,255,0.3); width: 100%; height: 100%; border-radius: 10px;
            color: #00e5ff; padding-left: 45px; padding-right: 45px; font-size: 14px; font-family: 'Orbitron', sans-serif;
            backdrop-filter: blur(5px); transition: all 0.3s ease;
        }
        .search-input::placeholder { color: rgba(0,229,255,0.4); text-transform: uppercase; font-size: 12px; }
        .search-input:focus { outline: none; border-color: #00e5ff; box-shadow: 0 0 15px rgba(0,229,255,0.3); }
        
        .search-nebula, .search-starfield { position: absolute; top:0; left:0; width: 100%; height: 100%; border-radius: 10px; pointer-events: none; z-index: -1; overflow: hidden; filter: blur(2px); opacity: 0.5; }
        .search-nebula::before {
            content: ""; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(60deg); width: 200%; height: 400%;
            background-image: conic-gradient(transparent, rgba(0,229,255,0.4) 5%, transparent 38%, transparent 50%, rgba(255,0,146,0.4) 60%, transparent 87%);
            transition: all 1s ease; animation: rotate 10s linear infinite;
        }
        .search-container:hover .search-nebula::before { opacity: 0.8; }
        
        .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); pointer-events: none; }
        .wormhole-btn { position: absolute; right: 5px; top: 50%; transform: translateY(-50%); background: linear-gradient(180deg, #1c2452, #05071b, #2a3875); border: 1px solid rgba(0,229,255,0.3); border-radius: 8px; width: 40px; height: 40px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s ease; overflow: hidden; }
        .wormhole-btn::before {
            content: ""; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 150%; height: 150%;
            background-image: conic-gradient(transparent, #00e5ff, transparent 50%, transparent 50%, #ff0092, transparent 100%);
            animation: rotate 4s linear infinite; opacity: 0; transition: opacity 0.3s; pointer-events: none;
        }
        .wormhole-btn:hover::before { opacity: 0.5; }
        .wormhole-btn:hover { box-shadow: 0 0 10px #00e5ff; }
        .wormhole-btn svg { position: relative; z-index: 2; }

        /* --- TERMINAL CHAT --- */
        .terminal-container { width: 100%; height: 350px; background: #0a0a0a; border-radius: 5px; box-shadow: 0 0 20px rgba(0, 229, 255, 0.15); overflow: hidden; display: flex; flex-direction: column; border: 1px solid rgba(0,229,255,0.3); transition: all 0.3s ease; }
        .terminal-toolbar { display: flex; height: 35px; align-items: center; padding: 0 15px; background: #111; justify-content: space-between; border-bottom: 1px solid rgba(0,229,255,0.2); }
        .terminal-butt { display: flex; align-items: center; }
        .terminal-btn { height: 12px; width: 12px; border-radius: 50%; margin-right: 8px; border: none; cursor: pointer; transition: transform 0.2s ease; }
        .terminal-btn:hover { transform: scale(1.2); }
        .t-btn-r { background: #ff5f56; } .t-btn-y { background: #ffbd2e; } .t-btn-g { background: #27c93f; }
        .terminal-user-title { color: #00e5ff; font-size: 12px; font-weight: bold; font-family: 'Orbitron', monospace; letter-spacing: 1px; }
        .terminal-body { background: rgba(5,7,20,0.9); flex: 1; padding: 15px; font-family: "Consolas", monospace; font-size: 13px; line-height: 1.6; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; }
        
        /* Görgetősáv */
        .terminal-body::-webkit-scrollbar { width: 6px; }
        .terminal-body::-webkit-scrollbar-track { background: transparent; }
        .terminal-body::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.3); border-radius: 3px; }
        .terminal-body::-webkit-scrollbar-thumb:hover { background: #00e5ff; }

        .chat-msg { display: flex; flex-direction: column; }
        .chat-msg .sender { color: #ff0092; font-weight: bold; margin-right: 5px; text-shadow: 0 0 5px rgba(255,0,146,0.5); }
        .chat-msg.self .sender { color: #00e5ff; text-shadow: 0 0 5px rgba(0,229,255,0.5); }
        .chat-msg .text { color: #e0e0e0; word-break: break-word; }
        
        .terminal-prompt { display: flex; align-items: center; padding: 10px 15px; background: #050505; border-top: 1px solid rgba(0,229,255,0.2); }
        .terminal-prompt span { margin-right: 6px; font-family: "Consolas", monospace; font-size: 13px; }
        .term-user { color: #00e5ff; }
        .term-loc { color: #ff0092; }
        .term-bling { color: #f0e6d2; }
        .term-input { background: transparent; border: none; outline: none; color: #fff; flex: 1; font-family: "Consolas", monospace; font-size: 13px; caret-color: #00e5ff; }
        .term-cursor { display: inline-block; width: 6px; height: 15px; background: #00e5ff; animation: blink 1s step-end infinite; margin-left: 2px; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

    </style>
</head>
<body class="p-4 md:p-8 min-h-screen overflow-x-hidden">

    <!-- HÁTTÉR DIV-EK -->
    <div class="star-container fixed inset-0 z-[-1] pointer-events-none">
        <div id="stars"></div><div id="stars2"></div><div id="stars3"></div>
    </div>

    <div class="max-w-[1600px] mx-auto relative z-10">
        <div id="toastContainer" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

        <!-- HEADER -->
        <header class="hex-panel p-5 mb-8 flex flex-col md:flex-row justify-between items-center gap-4 relative">
