<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style> body { background-color: #0f172a; color: #f8fafc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; } </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-6xl mx-auto">
        <header class="bg-slate-800 rounded-xl border border-slate-700 p-6 shadow-xl mb-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold text-amber-400 tracking-wider uppercase">Worlds Mayhem</h1>
                <p class="text-slate-400 mt-1">Üdvözlünk a menedzseri központban!</p>
            </div>
            <div class="flex items-center gap-6">
                <div class="text-right">
                    <div class="font-bold text-lg text-white"><%= username %></div>
                    <div class="text-sm text-emerald-400 font-semibold flex items-center justify-end gap-1">🏆 <%= trophies %> Trófea</div>
                </div>
                <div class="h-10 w-px bg-slate-600"></div>
                <button onclick="logout()" class="text-slate-400 hover:text-red-400 font-bold transition-colors">Kijelentkezés</button>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-slate-800 rounded-xl border border-slate-700 p-6 hover:border-blue-500 transition-colors shadow-lg flex flex-col justify-between" style="min-height: 200px;">
                <div>
                    <h2 class="text-2xl font-bold text-white mb-2">Új Bajnokság</h2>
                    <p class="text-slate-400">Hozd létre a saját lobbidat, és hívd meg a barátaidat.</p>
                </div>
                <button id="createLobbyBtn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-lg mt-4 transition-colors">
                    Lobbi Létrehozása
                </button>
            </div>

            <div class="bg-slate-800 rounded-xl border border-slate-700 p-6 hover:border-purple-500 transition-colors shadow-lg flex flex-col justify-between" style="min-height: 200px;">
                <div>
                    <h2 class="text-2xl font-bold text-white mb-2">Csatlakozás</h2>
                    <p class="text-slate-400">Lépj be egy létező szobába a 6 karakteres kóddal.</p>
                </div>
                <div class="mt-4 flex gap-2">
                    <input type="text" id="inviteCodeInput" placeholder="KÓD" maxlength="6" class="w-full bg-slate-900 border border-slate-600 rounded-lg px-4 font-mono text-center uppercase focus:outline-none focus:border-purple-500">
                    <button id="joinLobbyBtn" class="bg-purple-600 hover:bg-purple-500 text-white font-bold px-6 py-3 rounded-lg transition-colors">
                        Belépés
                    </button>
                </div>
            </div>

            <div class="bg-slate-800/50 rounded-xl border border-slate-700/50 p-6 shadow-lg flex flex-col" style="min-height: 200px;">
                <h2 class="text-xl font-bold text-white/50 mb-4 border-b border-slate-700/50 pb-2">Közösség (Hamarosan)</h2>
            </div>
        </div>
    </div>

    <script>
        const socket = io();
        const USER_ID = '<%= userId %>';

        document.getElementById('createLobbyBtn').addEventListener('click', () => {
            document.getElementById('createLobbyBtn').innerText = 'Létrehozás...';
            socket.emit('create_lobby', { userId: USER_ID }, (response) => {
                if (response.status === 'success') {
                    window.location.href = `/lobby/${response.lobbyId}`;
                } else {
                    alert(response.message);
                    document.getElementById('createLobbyBtn').innerText = 'Lobbi Létrehozása';
                }
            });
        });

        document.getElementById('joinLobbyBtn').addEventListener('click', () => {
            const code = document.getElementById('inviteCodeInput').value.trim().toUpperCase();
            if (code.length !== 6) return alert('A kódnak pontosan 6 karakternek kell lennie!');
            
            socket.emit('join_lobby', { userId: USER_ID, inviteCode: code }, (response) => {
                if (response.status === 'success') {
                    window.location.href = `/lobby/${response.lobbyId}`;
                } else {
                    alert(response.message);
                }
            });
        });

        async function logout() {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/login';
        }
    </script>
</body>
</html>