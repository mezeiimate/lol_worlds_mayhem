<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <style> 
        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Russo+One&display=swap');

        body { 
            background-color: #010a13; 
            color: #f0e6d2; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            position: relative;
        } 
        .esport-font { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        
        .hex-panel {
            background: linear-gradient(135deg, rgba(9, 20, 40, 0.9) 0%, rgba(1, 10, 19, 0.95) 100%);
            border: 1px solid rgba(0, 229, 255, 0.3);
            box-shadow: 0 0 25px rgba(0, 229, 255, 0.1), inset 0 0 20px rgba(0,0,0,0.8);
            position: relative;
            backdrop-filter: blur(10px);
            overflow: hidden;
        }
        .hex-panel::before, .hex-panel::after {
            content: ''; position: absolute; width: 12px; height: 12px; border: 1px solid #00e5ff;
        }
        .hex-panel::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
        .hex-panel::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
        
        .input-hex {
            background: #010a13; border: 1px solid rgba(0, 229, 255, 0.2); border-left: 2px solid #ff0092;
        }
        .input-hex:focus { border-color: #00e5ff; box-shadow: 0 0 15px rgba(0, 229, 255, 0.3); outline: none; }

        /* --- CSILLAGOS HÁTTÉR --- */
        .star-container { background: radial-gradient(ellipse at bottom, #091428 0%, #010a13 100%); }
        #stars, #stars2, #stars3 { background: transparent; }
        #stars { width: 1px; height: 1px; box-shadow: 501px 811px #00e5ff, 1450px 1324px #fff, 1093px 1780px #fff, 1469px 678px #ff0092, 904px 741px #fff, 1160px 781px #fff, 1841px 1962px #fff, 1630px 1667px #fff, 1788px 676px #fff, 367px 1734px #fff, 1343px 156px #fff, 1283px 1142px #fff, 1062px 378px #fff, 1395px 467px #fff, 1017px 1891px #fff, 137px 1114px #fff, 1767px 1403px #fff, 1543px 11px #fff, 1078px 181px #fff, 1189px 1574px #fff, 1697px 1551px #fff, 439px 472px #fff, 1491px 677px #fff, 1364px 599px #fff, 34px 382px #fff, 1221px 1584px #00e5ff, 1266px 1499px #fff, 169px 1907px #fff, 1219px 1125px #fff, 659px 18px #fff, 1731px 1959px #fff, 332px 1216px #fff, 1913px 788px #fff, 80px 712px #fff, 326px 1605px #fff, 574px 1502px #fff, 473px 1653px #fff, 404px 975px #fff, 322px 1797px #fff, 425px 1321px #fff, 1121px 1797px #fff, 731px 647px #fff, 891px 1584px #fff, 1523px 109px #fff, 1379px 244px #fff, 865px 1064px #fff, 493px 956px #fff, 624px 1380px #fff, 440px 619px #fff, 1630px 767px #fff, 955px 1196px #ff0092, 62px 729px #fff, 126px 946px #fff, 1256px 896px #fff, 1444px 256px #fff, 661px 1628px #fff, 1078px 1716px #fff, 300px 737px #fff, 1734px 413px #fff, 1296px 129px #fff; animation: animStar 50s linear infinite; }
        #stars2 { width: 2px; height: 2px; box-shadow: 1925px 1320px #fff, 693px 1778px #fff, 1016px 711px #00e5ff, 1171px 563px #fff, 661px 1919px #fff, 1610px 44px #fff, 1275px 140px #fff, 1208px 1802px #fff, 1473px 1587px #fff, 11px 1117px #fff, 853px 1757px #fff, 1149px 937px #fff, 1353px 428px #fff, 270px 279px #fff, 258px 1404px #fff, 417px 1188px #fff, 286px 561px #fff, 393px 1765px #fff, 147px 881px #fff, 666px 1097px #fff, 1425px 1278px #fff, 806px 156px #ff0092, 1252px 561px #fff, 218px 52px #fff, 1371px 1980px #fff, 171px 745px #fff, 1424px 89px #fff, 137px 244px #fff, 939px 1922px #fff, 137px 1080px #fff, 1757px 50px #fff, 904px 536px #fff, 1938px 1001px #fff, 1172px 440px #fff, 72px 1475px #fff, 102px 121px #fff, 804px 1671px #fff, 1314px 270px #fff, 440px 1341px #fff, 1216px 511px #fff, 1061px 1523px #fff, 97px 274px #fff, 704px 1318px #fff, 52px 1872px #fff, 1962px 296px #fff, 111px 289px #fff, 1157px 1236px #fff, 1347px 1451px #fff, 820px 286px #fff, 1389px 1169px #fff; animation: animStar 100s linear infinite; }
        #stars3 { width: 3px; height: 3px; box-shadow: 200px 981px #fff, 1731px 521px #fff, 132px 1039px #fff, 1888px 1547px #ff0092, 899px 1226px #fff, 1887px 580px #fff, 1548px 1092px #fff, 1626px 689px #fff, 254px 1072px #fff, 1684px 1211px #fff, 672px 1267px #fff, 939px 668px #fff, 1969px 645px #fff, 1126px 983px #fff, 457px 568px #fff, 476px 876px #fff, 829px 1896px #fff, 1364px 1846px #fff, 1507px 1120px #fff, 936px 1948px #fff, 1833px 832px #fff, 1424px 285px #fff, 1377px 1596px #fff, 432px 153px #fff, 1348px 1410px #fff, 1529px 954px #00e5ff, 1102px 387px #fff, 264px 297px #fff, 811px 977px #fff, 1931px 673px #fff, 1734px 978px #fff, 1772px 1567px #fff, 1197px 1400px #fff, 764px 282px #fff, 1103px 822px #fff, 872px 1803px #fff, 1057px 1763px #fff, 52px 1299px #fff, 1312px 1236px #fff, 235px 1082px #fff, 299px 1086px #fff, 1017px 1602px #fff, 1950px 626px #fff, 1306px 132px #fff, 1358px 1618px #fff, 1873px 1718px #fff, 1447px 940px #fff, 1888px 1195px #fff, 1704px 1765px #fff, 872px 1357px #fff; animation: animStar 150s linear infinite; }
        #stars:after, #stars2:after, #stars3:after { content: " "; position: absolute; top: 2000px; width: inherit; height: inherit; box-shadow: inherit; }
        @keyframes animStar { from { transform: translateY(0px); } to { transform: translateY(-2000px); } }

        /* --- CYBER NEON SVG PATH (Background effect) --- */
        .neon-svg-container { position: absolute; top: -50px; left: 50%; transform: translateX(-50%); width: 100%; height: 200px; pointer-events: none; z-index: 0; opacity: 0.5; display: flex; justify-content: center; align-items: center; }
        .neon-svg { position: absolute; width: 400px; fill: none; }
        .neon-svg:nth-child(2) { filter: blur(40px); }
        .neon-svg path {
            d: path("M0,25 C150,110 150, -60 300,25");
            stroke: #00e5ff; stroke-width: 25; stroke-linecap: round;
            transform: translate(50px,50%); animation: svgAnimate 3s ease-in-out infinite alternate;
        }
        @keyframes svgAnimate {
            0% { stroke: #00e5ff; d: path("M0,25 C150,110 150, -60 300,25"); }
            50% { stroke: #ff0092; d: path("M0,25 C160,-50 140, 110 300,25"); }
            100% { stroke: #8949ff; d: path("M0,25 C140,100 160, -40 300,25"); }
        }

        /* --- INLINE TOOLTIP --- */
        .item-hints { display: inline-flex; justify-content: center; align-items: center; cursor: help; }
        .item-hints .hint { position: relative; display: flex; justify-content: center; align-items: center; }
        .item-hints .hint-dot {
            z-index: 3; border: 1px solid rgba(0, 229, 255, 0.5); border-radius: 50%;
            width: 14px; height: 14px; display: flex; align-items: center; justify-content: center;
            color: #00e5ff; font-size: 9px; font-weight: bold; transition: all 0.3s;
        }
        .item-hints .hint:hover .hint-dot { background-color: #00e5ff; color: #010a13; border-color: #00e5ff; }
        .item-hints .hint-content {
            width: 220px; position: absolute; z-index: 50; padding: 10px; background: #091428; border: 1px solid #00e5ff; border-radius: 2px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5); opacity: 0; visibility: hidden; pointer-events: none;
            transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
            color: #f0e6d2; font-size: 0.7rem; font-weight: normal; text-transform: none;
            bottom: 150%; left: 50%; transform: translateX(-50%) translateY(10px); text-align: center; line-height: 1.4;
        }
        .item-hints .hint:hover .hint-content { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
        .item-hints .hint-content::after {
            content: ''; position: absolute; bottom: -5px; left: 50%; margin-left: -5px; width: 10px; height: 10px; background: #091428; border-bottom: 1px solid #00e5ff; border-right: 1px solid #00e5ff; transform: rotate(45deg);
        }

        /* --- COSMIC PORTAL BUTTON --- */
        .cosmic-portal-btn-wrapper { width: 100%; margin-top: 2rem; margin-bottom: 1rem; }
        .cosmic-portal-btn {
            --btn-bg: #010a13;
            --btn-color: #00e5ff;
            --btn-highlight: #091428;
            --portal-color1: #ff0092;
            --portal-color2: #00e5ff;
            position: relative; width: 100%; display: block; text-align: center;
            font-family: "Orbitron", sans-serif; font-size: 1.1em; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--btn-color); background-color: var(--btn-bg); border: none; padding: 1em 2em;
            cursor: pointer; overflow: hidden; transition: all 0.3s ease;
            clip-path: polygon(0% 0%, 100% 0%, 100% 70%, 90% 100%, 10% 100%, 0% 70%);
        }
        .cosmic-portal-btn::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: conic-gradient(from 0deg at 50% 50%, var(--portal-color1) 0deg, var(--portal-color2) 120deg, var(--portal-color1) 240deg, var(--portal-color2) 360deg);
            animation: rotatePortal 4s linear infinite; opacity: 0.4; transition: opacity 0.3s ease;
        }
        .cosmic-portal-btn:hover::before { opacity: 1; }
        .cosmic-portal-btn::after { content: ""; position: absolute; inset: 2px; background-color: var(--btn-bg); clip-path: inherit; z-index: 1; }
        .cosmic-btn-text { position: relative; z-index: 2; text-shadow: 0 0 10px rgba(0, 229, 255, 0.5); }
        .portal-effect { position: absolute; inset: 0; background: radial-gradient(circle at 50% 50%, var(--btn-highlight), transparent 50%); opacity: 0; transition: opacity 0.3s ease; z-index: 1; }
        .cosmic-portal-btn:hover .portal-effect { opacity: 1; animation: pulsePortal 2s ease-in-out infinite; }
        .cosmic-portal-btn:hover { transform: translateY(-3px); filter: drop-shadow(0 5px 15px rgba(255, 0, 146, 0.4)); color: #fff; }
        .cosmic-portal-btn:active { transform: translateY(0); }
        @keyframes rotatePortal { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes pulsePortal { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

        /* --- VALORANT LOADER (MODAL) --- */
        .val-loader { position: relative; width: 120px; height: 120px; margin: 0 auto; }
        .val-pattern-1 { position: absolute; background-color: #ff4c5a; width: 100%; height: 100%; clip-path: polygon(0 10%, 70% 90%, 40% 90%, 0 45%); overflow: hidden; }
        .val-pattern-2 { position: absolute; background-color: #ff4c5a; width: 110%; height: 95%; clip-path: polygon(100% 10%, 100% 45%, 83% 65%, 55% 65%); }
        .val-shade { position: absolute; transform: translateX(-20px); opacity: 0.7; z-index: 10; background-color: white; width: 15px; height: 100%; animation: val-shiny 1.5s infinite; filter: blur(2px); }
        @keyframes val-shiny { 0% { transform: translateX(-20px) skewX(-20deg); } 100% { transform: translateX(150px) skewX(-20deg); } }

    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 overflow-hidden">

    <div class="star-container fixed inset-0 z-[-1] pointer-events-none">
        <div id="stars"></div>
        <div id="stars2"></div>
        <div id="stars3"></div>
    </div>

    <div id="valorantModal" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#010a13]/90 backdrop-blur-sm transition-opacity duration-500 opacity-0 pointer-events-none" onclick="closeModal(event)">
        <div class="bg-[#0f1923] border border-[#ff4c5a]/50 p-10 rounded-sm text-center relative max-w-sm w-full mx-4 shadow-[0_0_50px_rgba(255,76,90,0.15)] transform scale-95 transition-transform duration-500" id="valorantModalContent">
            <button onclick="closeModalBtn()" class="absolute top-2 right-4 text-slate-500 hover:text-[#ff4c5a] font-bold text-2xl transition-colors">&times;</button>
            <div class="val-loader mb-8 mt-4">
                <div class="val-pattern-1"><div class="val-shade"></div></div>
                <div class="val-pattern-2"></div>
            </div>
            <h2 class="text-4xl font-black text-white tracking-widest uppercase" style="font-family: 'Russo One', sans-serif;">SOON...</h2>
            <p class="text-slate-400 text-xs mt-3 font-bold uppercase tracking-widest">LoL Worlds Mayhem x Valorant</p>
        </div>
    </div>

    <div class="max-w-md w-full hex-panel p-8 sm:p-10 rounded-sm">
        
        <div class="neon-svg-container">
            <svg class="neon-svg" viewBox="0 0 400 100"><path/></svg>
            <svg class="neon-svg" viewBox="0 0 400 100"><path/></svg>
        </div>

        <div id="alertBox" class="hidden mb-6 p-4 border text-sm text-center font-bold tracking-wide transition-all duration-300 relative z-10"></div>

        <div id="loginSection" class="block relative z-10">
            <div class="text-center mb-8 border-b border-[#00e5ff]/30 pb-4">
                <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#00e5ff] to-[#ff0092] tracking-wider esport-font drop-shadow-[0_0_10px_rgba(0,229,255,0.5)]">LoL Worlds Mayhem</h1>
            </div>

            <form id="loginForm" class="space-y-4">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest mb-1.5">Felhasználónév</label>
                    <input type="text" id="loginUsername" required class="w-full input-hex px-4 py-3 text-white transition-colors placeholder-slate-600" placeholder="Felhasználónév">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest">Jelszó</label>
                        <a href="#" onclick="showSection('forgotSection')" class="text-[0.65rem] text-slate-400 hover:text-[#ff0092] uppercase tracking-widest font-bold transition-colors">Elfelejtett jelszó?</a>
                    </div>
                    <div class="relative">
                        <input type="password" id="loginPassword" required class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('loginPassword', 'eyeLogin')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#00e5ff] focus:outline-none transition-colors">
                            <svg id="eyeLogin" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>

                <div class="cosmic-portal-btn-wrapper">
                    <button type="submit" id="btnLogin" class="cosmic-portal-btn">
                        <span class="cosmic-btn-text">Belépés</span>
                        <div class="portal-effect"></div>
                    </button>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-4">Nincs még fiókod? <a href="#" onclick="showSection('registerSection')" class="text-[#00e5ff] hover:text-[#ff0092] font-bold transition-colors">Regisztráció</a></p>
        </div>

        <div id="registerSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#00e5ff]/30 pb-4">
                <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#00e5ff] to-[#ff0092] tracking-wider esport-font">Regisztráció</h1>
            </div>

            <form id="registerForm" class="space-y-4">
                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest">Felhasználónév</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A felhasználónévnek minimum 3 karakter hosszúnak kell lennie.</div>
                            </div>
                        </div>
                    </div>
                    <input type="text" id="regUsername" required minlength="3" class="w-full input-hex px-4 py-3 text-white transition-colors" placeholder="Felhasználónév">
                </div>
                
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="regEmail" required class="w-full input-hex px-4 py-3 text-white transition-colors">
                </div>

                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest">Jelszó</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A jelszónak minimum 6 karakter hosszúnak kell lennie, a biztonság érdekében.</div>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <input type="password" id="regPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('regPassword', 'eyeReg1')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#00e5ff] focus:outline-none transition-colors">
                            <svg id="eyeReg1" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest mb-1.5">Jelszó megerősítése</label>
                    <div class="relative">
                        <input type="password" id="regConfirmPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('regConfirmPassword', 'eyeReg2')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#00e5ff] focus:outline-none transition-colors">
                            <svg id="eyeReg2" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>

                <div class="cosmic-portal-btn-wrapper">
                    <button type="submit" id="btnRegister" class="cosmic-portal-btn">
                        <span class="cosmic-btn-text">Regisztráció</span>
                        <div class="portal-effect"></div>
                    </button>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-4">Már van fiókod? <a href="#" onclick="showSection('loginSection')" class="text-[#00e5ff] hover:text-[#ff0092] font-bold transition-colors">Belépés</a></p>
        </div>

        <div id="forgotSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#00e5ff]/30 pb-4">
                <h1 class="text-3xl font-black text-[#00e5ff] tracking-wider esport-font">Elfelejtett jelszó</h1>
                <p class="text-slate-400 mt-2 text-sm">Add meg az e-mail címed a visszaállító linkhez.</p>
            </div>

            <form id="forgotForm" class="space-y-4">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="forgotEmail" required class="w-full input-hex px-4 py-3 text-white transition-colors">
                </div>
                
                <div class="cosmic-portal-btn-wrapper">
                    <button type="submit" id="btnForgot" class="cosmic-portal-btn">
                        <span class="cosmic-btn-text">Link küldése</span>
                        <div class="portal-effect"></div>
                    </button>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-4"><a href="#" onclick="showSection('loginSection')" class="text-slate-500 hover:text-[#00e5ff] font-bold transition-colors">← Vissza a belépéshez</a></p>
        </div>

        <div id="resetSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#00e5ff]/30 pb-4">
                <h1 class="text-3xl font-black text-[#00e5ff] tracking-wider esport-font">Új jelszó</h1>
                <p class="text-slate-400 mt-2 text-sm">Állítsd be a fiókod új jelszavát.</p>
            </div>

            <form id="resetForm" class="space-y-4">
                <input type="hidden" id="resetTokenInput">
                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest">Új jelszó</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A jelszónak minimum 6 karakter hosszúnak kell lennie.</div>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <input type="password" id="resetNewPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('resetNewPassword', 'eyeReset1')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#00e5ff] focus:outline-none transition-colors">
                            <svg id="eyeReset1" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#00e5ff] uppercase tracking-widest mb-1.5">Új jelszó megerősítése</label>
                    <div class="relative">
                        <input type="password" id="resetConfirmPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('resetConfirmPassword', 'eyeReset2')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#00e5ff] focus:outline-none transition-colors">
                            <svg id="eyeReset2" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                
                <div class="cosmic-portal-btn-wrapper">
                    <button type="submit" id="btnReset" class="cosmic-portal-btn">
                        <span class="cosmic-btn-text">Jelszó frissítése</span>
                        <div class="portal-effect"></div>
                    </button>
                </div>
            </form>
        </div>

    </div>

    <script>
        // Modal Logic
        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                const modal = document.getElementById('valorantModal');
                const content = document.getElementById('valorantModalContent');
                modal.classList.remove('opacity-0', 'pointer-events-none');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 500); // Fél másodperc késleltetés betöltés után
        });

        function closeModal(e) {
            if (e.target.id === 'valorantModal') { closeModalBtn(); }
        }

        function closeModalBtn() {
            const modal = document.getElementById('valorantModal');
            const content = document.getElementById('valorantModalContent');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            modal.classList.add('opacity-0', 'pointer-events-none');
        }

        // Form Logic
        const alertBox = document.getElementById('alertBox');

        function showAlert(msg, isError = false) {
            alertBox.innerHTML = msg;
            alertBox.classList.remove('hidden', 'bg-red-950/80', 'border-red-500/50', 'text-red-400', 'bg-emerald-950/80', 'border-emerald-500/50', 'text-emerald-400');
            if (isError) { alertBox.classList.add('bg-red-950/80', 'border-red-500/50', 'text-red-400'); } 
            else { alertBox.classList.add('bg-emerald-950/80', 'border-emerald-500/50', 'text-emerald-400'); }
        }

        function showSection(sectionId) {
            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('registerSection').classList.add('hidden');
            document.getElementById('forgotSection').classList.add('hidden');
            document.getElementById('resetSection').classList.add('hidden');
            alertBox.classList.add('hidden');
            document.getElementById(sectionId).classList.remove('hidden');
        }

        function toggleVisibility(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;
            } else {
                input.type = 'password';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`;
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const token = urlParams.get('reset_token');
            const verified = urlParams.get('verified');

            if (token) {
                document.getElementById('resetTokenInput').value = token;
                showSection('resetSection');
            } else if (verified === 'true') {
                showAlert('A fiókod sikeresen megerősítve! Most már bejelentkezhetsz.', false);
            }
        });

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter; 
            const btnText = btn.querySelector('.cosmic-btn-text');
            btn.disabled = true; btnText.innerText = 'Belépés...';
            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: document.getElementById('loginUsername').value, password: document.getElementById('loginPassword').value })
                });
                const data = await res.json();
                if (!res.ok) { showAlert(data.message, true); btn.disabled = false; btnText.innerText = 'Belépés'; } 
                else { window.location.href = '/dashboard'; }
            } catch(err) { showAlert('Szerver hiba történt.', true); btn.disabled = false; btnText.innerText = 'Belépés'; }
        });

        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const p1 = document.getElementById('regPassword').value;
            const p2 = document.getElementById('regConfirmPassword').value;
            if (p1 !== p2) return showAlert('A jelszavak nem egyeznek!', true);

            const btn = e.submitter; 
            const btnText = btn.querySelector('.cosmic-btn-text');
            btn.disabled = true; btnText.innerText = 'Regisztráció...';
            
            try {
                const res = await fetch('/api/auth/register', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('regUsername').value,
                        email: document.getElementById('regEmail').value,
                        password: p1,
                        confirmPassword: p2
                    })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) {
                    document.getElementById('registerForm').reset();
                    setTimeout(() => showSection('loginSection'), 4000);
                }
                btn.disabled = false; btnText.innerText = 'Regisztráció';
            } catch(err) { showAlert('Szerver hiba történt.', true); btn.disabled = false; btnText.innerText = 'Regisztráció'; }
        });

        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter; 
            const btnText = btn.querySelector('.cosmic-btn-text');
            btn.disabled = true; btnText.innerText = 'Küldés...';
            try {
                const res = await fetch('/api/auth/forgot-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('forgotEmail').value })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) { setTimeout(() => showSection('loginSection'), 3000); } 
                else { btn.disabled = false; btnText.innerText = 'Link küldése'; }
            } catch(err) { showAlert('Hálózati hiba.', true); btn.disabled = false; btnText.innerText = 'Link küldése'; }
        });

        document.getElementById('resetForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const p1 = document.getElementById('resetNewPassword').value;
            const p2 = document.getElementById('resetConfirmPassword').value;
            
            if (p1 !== p2) return showAlert('Az új jelszavak nem egyeznek!', true);

            const btn = e.submitter; 
            const btnText = btn.querySelector('.cosmic-btn-text');
            btn.disabled = true; btnText.innerText = 'Frissítés...';
            try {
                const res = await fetch('/api/auth/reset-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        token: document.getElementById('resetTokenInput').value,
                        newPassword: p1,
                        confirmNewPassword: p2
                    })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) { setTimeout(() => window.location.href = '/login', 2500); } 
                else { btn.disabled = false; btnText.innerText = 'Jelszó frissítése'; }
            } catch(err) { showAlert('Hiba történt a kommunikációban.', true); btn.disabled = false; btnText.innerText = 'Jelszó frissítése'; }
        });
    </script>
</body>
</html>