<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: #f8fafc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="max-w-md w-full bg-slate-800 rounded-xl border border-slate-700 shadow-2xl overflow-hidden">
        <div class="bg-slate-900 p-6 text-center border-b border-slate-700">
            <h1 class="text-3xl font-bold text-amber-400 tracking-wider uppercase">Worlds Mayhem</h1>
            <p class="text-slate-400 mt-2 text-sm">Jelentkezz be a menedzseri pultba</p>
        </div>

        <div class="p-8">
            <div id="errorBox" class="hidden mb-6 bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded text-sm">
                Ide jön a hibaüzenet.
            </div>

            <div class="flex bg-slate-900 rounded-lg p-1 mb-8">
                <button id="tabLogin" onclick="switchTab('login')" class="flex-1 py-2 text-sm font-bold rounded-md bg-blue-600 text-white transition-all">Bejelentkezés</button>
                <button id="tabRegister" onclick="switchTab('register')" class="flex-1 py-2 text-sm font-bold rounded-md text-slate-400 hover:text-white transition-all">Regisztráció</button>
            </div>

            <form id="authForm" onsubmit="handleSubmit(event)">
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">E-mail cím</label>
                        <input type="email" id="email" required class="w-full bg-slate-900 border border-slate-600 rounded-lg px-4 py-2.5 focus:outline-none focus:border-blue-500 transition-colors">
                    </div>

                    <div id="usernameContainer" class="hidden">
                        <label class="block text-sm font-medium text-slate-400 mb-1">Felhasználónév</label>
                        <input type="text" id="username" class="w-full bg-slate-900 border border-slate-600 rounded-lg px-4 py-2.5 focus:outline-none focus:border-blue-500 transition-colors">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Jelszó</label>
                        <input type="password" id="password" required class="w-full bg-slate-900 border border-slate-600 rounded-lg px-4 py-2.5 focus:outline-none focus:border-blue-500 transition-colors">
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-4 rounded-lg mt-8 transition-colors">
                    Belépés a rendszerbe
                </button>
            </form>
        </div>
    </div>

    <script>
        let currentMode = 'login'; // 'login' vagy 'register'

        function switchTab(mode) {
            currentMode = mode;
            const errorBox = document.getElementById('errorBox');
            errorBox.classList.add('hidden');

            const tabLogin = document.getElementById('tabLogin');
            const tabRegister = document.getElementById('tabRegister');
            const usernameContainer = document.getElementById('usernameContainer');
            const submitBtn = document.getElementById('submitBtn');
            const usernameInput = document.getElementById('username');

            if (mode === 'login') {
                tabLogin.className = 'flex-1 py-2 text-sm font-bold rounded-md bg-blue-600 text-white transition-all';
                tabRegister.className = 'flex-1 py-2 text-sm font-bold rounded-md text-slate-400 hover:text-white transition-all';
                usernameContainer.classList.add('hidden');
                usernameInput.removeAttribute('required');
                submitBtn.innerText = 'Belépés a rendszerbe';
            } else {
                tabRegister.className = 'flex-1 py-2 text-sm font-bold rounded-md bg-blue-600 text-white transition-all';
                tabLogin.className = 'flex-1 py-2 text-sm font-bold rounded-md text-slate-400 hover:text-white transition-all';
                usernameContainer.classList.remove('hidden');
                usernameInput.setAttribute('required', 'true');
                submitBtn.innerText = 'Fiók létrehozása';
            }
        }

        async function handleSubmit(event) {
            event.preventDefault(); // Megakadályozzuk az oldal újratöltését

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const username = document.getElementById('username').value;
            const errorBox = document.getElementById('errorBox');
            
            const payload = currentMode === 'login' 
                ? { email, password } 
                : { email, username, password };

            const endpoint = currentMode === 'login' ? '/api/auth/login' : '/api/auth/register';

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (!response.ok) {
                    // Ha a Zod validációs hibát dobott, formázzuk meg
                    if (data.errors) {
                        errorBox.innerText = data.errors.map(e => e.message).join('\n');
                    } else {
                        errorBox.innerText = data.message || 'Ismeretlen hiba történt.';
                    }
                    errorBox.classList.remove('hidden');
                    return;
                }

                // Ha regisztrált, rögtön utána be is léptetjük automatikusan
                if (currentMode === 'register') {
                    await fetch('/api/auth/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email, password })
                    });
                }

                // Sikeres belépés (a HttpOnly süti beállítódott a háttérben!) -> Irány a főoldal
                window.location.href = '/dashboard';

            } catch (error) {
                errorBox.innerText = 'Hálózati hiba. Nem sikerült kapcsolódni a szerverhez.';
                errorBox.classList.remove('hidden');
            }
        }
    </script>
</body>
</html>