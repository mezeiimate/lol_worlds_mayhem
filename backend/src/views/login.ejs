px #fff, 1491px 258px #fff, 1489px 1946px #fff, 1134px 1382px #fff, 1289px 1145px #fff, 464px 358px #fff, 1249px 1842px #fff, 1665px 831px #fff, 1982px 84px #fff, 541px 774px #fff, 1994px 523px #fff, 762px 1644px #fff, 1730px 867px #fff, 1951px 1287px #fff, 911px 1691px #fff, 1454px 725px #fff;
            animation: animStar 100s linear infinite;
        }
        #stars3 {
            width: 3px; height: 3px;
            box-shadow: 200px 981px #fff, 1731px 521px #fff, 132px 1039px #fff, 1888px 1547px #c8aa6e, 899px 1226px #fff, 1887px 580px #fff, 1548px 1092px #fff, 1626px 689px #fff, 254px 1072px #fff, 1684px 1211px #fff, 672px 1267px #fff, 939px 668px #fff, 1969px 645px #fff, 1126px 983px #fff, 457px 568px #fff, 476px 876px #fff, 829px 1896px #fff, 1364px 1846px #fff, 1507px 1120px #fff, 936px 1948px #fff, 1833px 832px #fff, 1424px 285px #fff, 1377px 1596px #fff, 432px 153px #fff, 1348px 1410px #fff, 1529px 954px #c8aa6e, 1102px 387px #fff, 264px 297px #fff, 811px 977px #fff, 1931px 673px #fff, 1734px 978px #fff, 1772px 1567px #fff, 1197px 1400px #fff, 764px 282px #fff, 1103px 822px #fff, 872px 1803px #fff, 1057px 1763px #fff, 52px 1299px #fff, 1312px 1236px #fff, 235px 1082px #fff, 299px 1086px #fff, 1017px 1602px #fff, 1950px 626px #fff, 1306px 132px #fff, 1358px 1618px #fff, 1873px 1718px #fff, 1447px 940px #fff, 1888px 1195px #fff, 1704px 1765px #fff, 872px 1357px #fff;
            animation: animStar 150s linear infinite;
        }
        #stars:after, #stars2:after, #stars3:after {
            content: " "; position: absolute; top: 2000px; width: inherit; height: inherit; box-shadow: inherit;
        }
        @keyframes animStar {
            from { transform: translateY(0px); }
            to { transform: translateY(-2000px); }
        }

        /* --- INLINE TOOLTIP --- */
        .item-hints {
            display: inline-flex; justify-content: center; align-items: center; cursor: help;
        }
        .item-hints .hint {
            position: relative; display: flex; justify-content: center; align-items: center;
        }
        .item-hints .hint-dot {
            z-index: 3; border: 1px solid rgba(200, 170, 110, 0.5); border-radius: 50%;
            width: 14px; height: 14px; display: flex; align-items: center; justify-content: center;
            color: #c8aa6e; font-size: 9px; font-weight: bold; transition: all 0.3s;
        }
        .item-hints .hint:hover .hint-dot {
            background-color: #c8aa6e; color: #010a13; border-color: #c8aa6e;
        }
        .item-hints .hint-content {
            width: 220px; position: absolute; z-index: 50; padding: 10px;
            background: #091428; border: 1px solid #c8aa6e; border-radius: 2px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5); opacity: 0; visibility: hidden; pointer-events: none;
            transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
            color: #f0e6d2; font-size: 0.7rem; font-weight: normal; text-transform: none;
            bottom: 150%; left: 50%; transform: translateX(-50%) translateY(10px);
            text-align: center; line-height: 1.4;
        }
        .item-hints .hint:hover .hint-content {
            opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0);
        }
        .item-hints .hint-content::after {
            content: ''; position: absolute; bottom: -5px; left: 50%; margin-left: -5px;
            width: 10px; height: 10px; background: #091428; border-bottom: 1px solid #c8aa6e; border-right: 1px solid #c8aa6e;
            transform: rotate(45deg);
        }

        /* --- HOLO GLITCH GOMB --- */
        .button-container {
            position: relative; perspective: 1000px; transform-style: preserve-3d; z-index: 10;
            width: 100%; height: 60px; margin-top: 30px; margin-bottom: 20px;
        }
        .holo-button {
            position: relative; width: 100%; height: 100%;
            background: rgba(10, 15, 30, 0.8); border: none; color: #c8aa6e;
            font-family: "Orbitron", sans-serif; font-size: 16px; font-weight: 700; letter-spacing: 3px;
            text-shadow: 0 0 10px rgba(200, 170, 110, 0.5); cursor: pointer; overflow: hidden;
            transform-style: preserve-3d; transition: all 0.3s ease; outline: none; z-index: 5;
            border-radius: 2px; display: flex; align-items: center; justify-content: center;
        }
        .holo-button::before {
            content: ""; position: absolute; top: 1px; left: 1px; right: 1px; bottom: 1px;
            background: linear-gradient(45deg, rgba(9, 20, 40, 0.9) 0%, rgba(15, 30, 60, 0.9) 50%, rgba(5, 10, 20, 0.9) 100%);
            z-index: -1; border-radius: 1px;
        }
        
        .button-border { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2; }
        .button-border::before, .button-border::after {
            content: ""; position: absolute; width: 100%; height: 100%; border: 1px solid transparent;
            box-shadow: 0 0 10px rgba(200, 170, 110, 0.4); animation: border-flow 3s infinite;
        }
        .button-border::before {
            border-top-color: #c8aa6e; border-left-color: #c8aa6e; filter: drop-shadow(0 0 5px rgba(200, 170, 110, 0.7));
        }
        .button-border::after {
            border-bottom-color: #f0e6d2; border-right-color: #f0e6d2; filter: drop-shadow(0 0 5px rgba(240, 230, 210, 0.7));
        }
        @keyframes border-flow { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.02); opacity: 0.8; } }

        .holo-glow {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 100%; height: 100%;
            background: radial-gradient(ellipse at center, rgba(200, 170, 110, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
            pointer-events: none; z-index: 1; opacity: 0.7; filter: blur(10px); animation: glow-pulse 3s infinite alternate;
        }
        @keyframes glow-pulse { 0% { opacity: 0.4; filter: blur(10px) brightness(0.8); } 100% { opacity: 0.7; filter: blur(15px) brightness(1.2); } }

        .holo-lines { position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; pointer-events: none; z-index: 2; }
        .holo-line { position: absolute; background: rgba(200, 170, 110, 0.5); filter: blur(1px); }
        .holo-line:nth-child(1) { top: 0; left: 20px; width: 1px; height: 100%; animation: line-pulse 2s infinite alternate; animation-delay: -0.5s; }
        .holo-line:nth-child(2) { top: 0; right: 20px; width: 1px; height: 100%; animation: line-pulse 2s infinite alternate; animation-delay: -1s; }
        .holo-line:nth-child(3) { top: 10px; left: 0; width: 100%; height: 1px; animation: line-pulse 2s infinite alternate; animation-delay: -1.5s; }
        .holo-line:nth-child(4) { bottom: 10px; left: 0; width: 100%; height: 1px; animation: line-pulse 2s infinite alternate; animation-delay: -2s; }
        @keyframes line-pulse { 0% { opacity: 0.3; background: rgba(200, 170, 110, 0.5); } 100% { opacity: 0.7; background: rgba(240, 230, 210, 0.5); } }

        .scan-line {
            position: absolute; width: 100%; height: 2px;
            background: linear-gradient(90deg, rgba(0,0,0,0) 0%, rgba(200,170,110,0.5) 20%, rgba(255,255,255,0.8) 50%, rgba(240,230,210,0.5) 80%, rgba(0,0,0,0) 100%);
            top: 0; left: 0; filter: blur(1px); opacity: 0; z-index: 2; pointer-events: none; animation: scan 2.5s infinite;
        }
        @keyframes scan { 0% { top: -5px; opacity: 0; } 15%, 85% { opacity: 0.7; } 100% { top: 65px; opacity: 0; } }

        .button-hexagons { position: absolute; width: 100%; height: 140px; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 1; }
        .hexagon {
            position: absolute; width: 20px; height: 11.5px; background: transparent; border: 1px solid rgba(200, 170, 110, 0.2);
            transform: rotate(30deg); opacity: 0; animation: hexagon-pulse 3s infinite;
        }
        .hexagon::before, .hexagon::after {
            content: ""; position: absolute; width: 100%; height: 100%; top: -1px; left: -1px;
            background: transparent; border: 1px solid rgba(200, 170, 110, 0.2);
        }
        .hexagon::before { transform: rotate(60deg); } .hexagon::after { transform: rotate(-60deg); }
        .hexagon:nth-child(1) { top: 0px; left: 5px; animation-delay: 0.1s; }
        .hexagon:nth-child(2) { top: 0px; right: 5px; animation-delay: 0.3s; }
        .hexagon:nth-child(3) { bottom: 0px; left: 5px; animation-delay: 0.5s; }
        .hexagon:nth-child(4) { bottom: 0px; right: 5px; animation-delay: 0.7s; }

        @keyframes hexagon-pulse {
            0% { opacity: 0; transform: rotate(30deg) scale(0.8); }
            20%, 80% { opacity: 0.4; transform: rotate(30deg) scale(1); }
            100% { opacity: 0; transform: rotate(30deg) scale(1.2); }
        }

        .digital-glyphs {
            position: absolute; width: 100%; height: 120px; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 1;
        }
        .digital-glyph {
            position: absolute; color: rgba(200, 170, 110, 0.4); font-size: 8px; font-family: "Orbitron", monospace; white-space: nowrap; opacity: 0; animation: glyph-fade 4s infinite;
        }
        .digital-glyph:nth-child(1) { top: 0px; left: 10px; animation-delay: 0.2s; }
        .digital-glyph:nth-child(2) { top: 10px; right: 5px; animation-delay: 0.6s; }
        .digital-glyph:nth-child(3) { bottom: 0px; left: 20px; animation-delay: 1s; }
        .digital-glyph:nth-child(4) { bottom: 10px; right: 10px; animation-delay: 1.4s; }
        @keyframes glyph-fade { 0% { opacity: 0; transform: translateY(0); } 10%, 90% { opacity: 0.7; } 100% { opacity: 0; transform: translateY(-5px); } }

        .button-glitch {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: transparent; pointer-events: none; z-index: 3; opacity: 0; animation: button-glitch 6s infinite;
        }
        @keyframes button-glitch {
            0%, 100%, 94%, 96% { opacity: 0; }
            94.5% { opacity: 0.8; transform: translate(3px, -1px) skew(-5deg, 1deg); background: rgba(240, 230, 210, 0.1); }
            95% { opacity: 0.8; transform: translate(-3px, 1px) skew(5deg, -1deg); background: rgba(200, 170, 110, 0.1); }
            95.5% { opacity: 0.8; transform: translate(1px, 0) skew(-1deg, 0); background: rgba(255, 255, 255, 0.1); }
        }

        .sound-wave {
            position: absolute; bottom: -15px; left: 0; width: 100%; height: 10px; display: flex; justify-content: center; align-items: center; pointer-events: none;
        }
        .wave-bar {
            width: 1.5px; height: 3px; background: rgba(200, 170, 110, 0.4); margin: 0 2px; border-radius: 1px; animation: wave-animation 1.5s infinite;
        }
        @keyframes wave-animation { 0%, 100% { height: 3px; } 50% { height: 10px; } }
        .wave-bar:nth-child(1) { animation-delay: 0.1s; } .wave-bar:nth-child(2) { animation-delay: 0.2s; } .wave-bar:nth-child(3) { animation-delay: 0.3s; } .wave-bar:nth-child(4) { animation-delay: 0.4s; } .wave-bar:nth-child(5) { animation-delay: 0.5s; } .wave-bar:nth-child(6) { animation-delay: 0.6s; } .wave-bar:nth-child(7) { animation-delay: 0.7s; } .wave-bar:nth-child(8) { animation-delay: 0.8s; } .wave-bar:nth-child(9) { animation-delay: 0.9s; } .wave-bar:nth-child(10) { animation-delay: 1s; } .wave-bar:nth-child(11) { animation-delay: 0.9s; } .wave-bar:nth-child(12) { animation-delay: 0.8s; }

        .holo-button:hover { color: #fff; text-shadow: 0 0 15px rgba(255, 255, 255, 0.8); transform: scale(1.02); }
        .holo-button:hover .holo-glow { background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.2) 0%, rgba(200, 170, 110, 0.2) 40%, rgba(0, 0, 0, 0) 70%); animation: glow-pulse-hover 1.5s infinite alternate; }
        @keyframes glow-pulse-hover { 0% { opacity: 0.6; filter: blur(10px) brightness(1); } 100% { opacity: 0.9; filter: blur(15px) brightness(1.5); } }
        .holo-button:active { transform: scale(0.98); transition: all 0.1s ease; }
        
        .button-text { position: relative; z-index: 5; transform-style: preserve-3d; text-transform: uppercase; }

    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 overflow-hidden">

    <div class="star-container fixed inset-0 z-[-1] pointer-events-none">
        <div id="stars"></div>
        <div id="stars2"></div>
        <div id="stars3"></div>
    </div>

    <div class="max-w-md w-full hex-panel p-8 sm:p-10 rounded-sm">
        
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#c8aa6e] opacity-5 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-blue-500 opacity-5 rounded-full blur-3xl pointer-events-none"></div>

        <div id="alertBox" class="hidden mb-6 p-4 border text-sm text-center font-bold tracking-wide transition-all duration-300 relative z-10"></div>

        <div id="loginSection" class="block relative z-10">
            <div class="text-center mb-8 border-b border-[#c8aa6e]/30 pb-4">
                <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font">LoL Worlds Mayhem</h1>
            </div>

            <form id="loginForm" class="space-y-4">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Felhasználónév</label>
                    <input type="text" id="loginUsername" required class="w-full input-hex px-4 py-3 text-white transition-colors placeholder-slate-600" placeholder="Felhasználónév">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest">Jelszó</label>
                        <a href="#" onclick="showSection('forgotSection')" class="text-[0.65rem] text-slate-400 hover:text-[#c8aa6e] uppercase tracking-widest font-bold transition-colors">Elfelejtett jelszó?</a>
                    </div>
                    <div class="relative">
                        <input type="password" id="loginPassword" required class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('loginPassword', 'eyeLogin')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#c8aa6e] focus:outline-none">
                            <svg id="eyeLogin" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>

                <div class="button-container">
                    <div class="button-hexagons">
                        <div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div>
                    </div>
                    <div class="digital-glyphs">
                        <div class="digital-glyph">0x89F2 AUTH PROTOCOL</div>
                        <div class="digital-glyph">SYS.HEX.INIT()</div>
                    </div>
                    <button type="submit" id="btnLogin" class="holo-button">
                        <div class="button-border"></div>
                        <div class="button-text">Belépés</div>
                        <div class="holo-glow"></div>
                        <div class="button-glitch"></div>
                        <div class="holo-lines"><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div></div>
                        <div class="scan-line"></div>
                    </button>
                    <div class="sound-wave">
                        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
                    </div>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6">Nincs még fiókod? <a href="#" onclick="showSection('registerSection')" class="text-[#c8aa6e] hover:text-[#f0e6d2] font-bold transition-colors">Regisztráció</a></p>
        </div>

        <div id="registerSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#c8aa6e]/30 pb-4">
                <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font">Regisztráció</h1>
            </div>

            <form id="registerForm" class="space-y-4">
                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest">Felhasználónév</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A felhasználónévnek minimum 3 karakter hosszúnak kell lennie.</div>
                            </div>
                        </div>
                    </div>
                    <input type="text" id="regUsername" required minlength="3" class="w-full input-hex px-4 py-3 text-white transition-colors" placeholder="Felhasználónév">
                </div>
                
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="regEmail" required class="w-full input-hex px-4 py-3 text-white transition-colors">
                </div>

                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest">Jelszó</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A jelszónak minimum 6 karakter hosszúnak kell lennie, a biztonság érdekében.</div>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <input type="password" id="regPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('regPassword', 'eyeReg1')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#c8aa6e] focus:outline-none">
                            <svg id="eyeReg1" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Jelszó megerősítése</label>
                    <div class="relative">
                        <input type="password" id="regConfirmPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('regConfirmPassword', 'eyeReg2')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#c8aa6e] focus:outline-none">
                            <svg id="eyeReg2" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>

                <div class="button-container">
                    <div class="button-hexagons">
                        <div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div>
                    </div>
                    <div class="digital-glyphs">
                        <div class="digital-glyph">0x89F2 REG PROTOCOL</div>
                        <div class="digital-glyph">SYS.CREATE.INIT()</div>
                    </div>
                    <button type="submit" id="btnRegister" class="holo-button">
                        <div class="button-border"></div>
                        <div class="button-text">Regisztráció</div>
                        <div class="holo-glow"></div>
                        <div class="button-glitch"></div>
                        <div class="holo-lines"><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div></div>
                        <div class="scan-line"></div>
                    </button>
                    <div class="sound-wave">
                        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
                    </div>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6">Már van fiókod? <a href="#" onclick="showSection('loginSection')" class="text-[#c8aa6e] hover:text-[#f0e6d2] font-bold transition-colors">Belépés</a></p>
        </div>

        <div id="forgotSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#c8aa6e]/30 pb-4">
                <h1 class="text-3xl font-black text-[#c8aa6e] tracking-wider esport-font">Elfelejtett jelszó</h1>
                <p class="text-slate-400 mt-2 text-sm">Add meg az e-mail címed a visszaállító linkhez.</p>
            </div>

            <form id="forgotForm" class="space-y-4">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="forgotEmail" required class="w-full input-hex px-4 py-3 text-white transition-colors">
                </div>
                
                <div class="button-container">
                    <div class="button-hexagons">
                        <div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div>
                    </div>
                    <button type="submit" id="btnForgot" class="holo-button">
                        <div class="button-border"></div>
                        <div class="button-text">Link küldése</div>
                        <div class="holo-glow"></div>
                        <div class="button-glitch"></div>
                        <div class="holo-lines"><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div></div>
                        <div class="scan-line"></div>
                    </button>
                    <div class="sound-wave">
                        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
                    </div>
                </div>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6"><a href="#" onclick="showSection('loginSection')" class="text-slate-500 hover:text-[#f0e6d2] font-bold transition-colors">← Vissza a belépéshez</a></p>
        </div>

        <div id="resetSection" class="hidden relative z-10">
            <div class="text-center mb-8 border-b border-[#c8aa6e]/30 pb-4">
                <h1 class="text-3xl font-black text-[#c8aa6e] tracking-wider esport-font">Új jelszó</h1>
                <p class="text-slate-400 mt-2 text-sm">Állítsd be a fiókod új jelszavát.</p>
            </div>

            <form id="resetForm" class="space-y-4">
                <input type="hidden" id="resetTokenInput">
                <div>
                    <div class="flex items-center gap-2 mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest">Új jelszó</label>
                        <div class="item-hints">
                            <div class="hint">
                                <span class="hint-dot">?</span>
                                <div class="hint-content">A jelszónak minimum 6 karakter hosszúnak kell lennie.</div>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <input type="password" id="resetNewPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('resetNewPassword', 'eyeReset1')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#c8aa6e] focus:outline-none">
                            <svg id="eyeReset1" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Jelszó megerősítése</label>
                    <div class="relative">
                        <input type="password" id="resetConfirmPassword" required minlength="6" class="w-full input-hex px-4 py-3 pr-12 text-white transition-colors">
                        <button type="button" onclick="toggleVisibility('resetConfirmPassword', 'eyeReset2')" class="absolute inset-y-0 right-0 px-4 flex items-center text-slate-400 hover:text-[#c8aa6e] focus:outline-none">
                            <svg id="eyeReset2" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                        </button>
                    </div>
                </div>
                
                <div class="button-container">
                    <div class="button-hexagons">
                        <div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div><div class="hexagon"></div>
                    </div>
                    <button type="submit" id="btnReset" class="holo-button">
                        <div class="button-border"></div>
                        <div class="button-text">Jelszó frissítése</div>
                        <div class="holo-glow"></div>
                        <div class="button-glitch"></div>
                        <div class="holo-lines"><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div><div class="holo-line"></div></div>
                        <div class="scan-line"></div>
                    </button>
                    <div class="sound-wave">
                        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
                    </div>
                </div>
            </form>
        </div>

    </div>

    <script>
        const alertBox = document.getElementById('alertBox');

        function showAlert(msg, isError = false) {
            alertBox.innerHTML = msg;
            alertBox.classList.remove('hidden', 'bg-red-950/80', 'border-red-500/50', 'text-red-400', 'bg-emerald-950/80', 'border-emerald-500/50', 'text-emerald-400');
            if (isError) { alertBox.classList.add('bg-red-950/80', 'border-red-500/50', 'text-red-400'); } 
            else { alertBox.classList.add('bg-emerald-950/80', 'border-emerald-500/50', 'text-emerald-400'); }
        }

        function showSection(sectionId) {
            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('registerSection').classList.add('hidden');
            document.getElementById('forgotSection').classList.add('hidden');
            document.getElementById('resetSection').classList.add('hidden');
            alertBox.classList.add('hidden');
            document.getElementById(sectionId).classList.remove('hidden');
        }

        function toggleVisibility(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;
            } else {
                input.type = 'password';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`;
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const token = urlParams.get('reset_token');
            const verified = urlParams.get('verified');

            if (token) {
                document.getElementById('resetTokenInput').value = token;
                showSection('resetSection');
            } else if (verified === 'true') {
                showAlert('A fiókod sikeresen megerősítve! Most már bejelentkezhetsz.', false);
            }
        });

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter; 
            const btnText = btn.querySelector('.button-text');
            btn.disabled = true; btnText.innerText = 'Belépés...';
            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: document.getElementById('loginUsername').value, password: document.getElementById('loginPassword').value })
                });
                const data = await res.json();
                if (!res.ok) { showAlert(data.message, true); btn.disabled = false; btnText.innerText = 'Belépés'; } 
                else { window.location.href = '/dashboard'; }
            } catch(err) { showAlert('Szerver hiba történt.', true); btn.disabled = false; btnText.innerText = 'Belépés'; }
        });

        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const p1 = document.getElementById('regPassword').value;
            const p2 = document.getElementById('regConfirmPassword').value;
            if (p1 !== p2) return showAlert('A jelszavak nem egyeznek!', true);

            const btn = e.submitter; 
            const btnText = btn.querySelector('.button-text');
            btn.disabled = true; btnText.innerText = 'Regisztráció...';
            
            try {
                const res = await fetch('/api/auth/register', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('regUsername').value,
                        email: document.getElementById('regEmail').value,
                        password: p1,
                        confirmPassword: p2
                    })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) {
                    document.getElementById('registerForm').reset();
                    setTimeout(() => showSection('loginSection'), 4000);
                }
                btn.disabled = false; btnText.innerText = 'Regisztráció';
            } catch(err) { showAlert('Szerver hiba történt.', true); btn.disabled = false; btnText.innerText = 'Regisztráció'; }
        });

        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter; 
            const btnText = btn.querySelector('.button-text');
            btn.disabled = true; btnText.innerText = 'Küldés...';
            try {
                const res = await fetch('/api/auth/forgot-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('forgotEmail').value })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) { setTimeout(() => showSection('loginSection'), 3000); } 
                else { btn.disabled = false; btnText.innerText = 'Link küldése'; }
            } catch(err) { showAlert('Hálózati hiba.', true); btn.disabled = false; btnText.innerText = 'Link küldése'; }
        });

        document.getElementById('resetForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const p1 = document.getElementById('resetNewPassword').value;
            const p2 = document.getElementById('resetConfirmPassword').value;
            
            if (p1 !== p2) return showAlert('Az új jelszavak nem egyeznek!', true);

            const btn = e.submitter; 
            const btnText = btn.querySelector('.button-text');
            btn.disabled = true; btnText.innerText = 'Frissítés...';
            try {
                const res = await fetch('/api/auth/reset-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        token: document.getElementById('resetTokenInput').value,
                        newPassword: p1,
                        confirmNewPassword: p2
                    })
                });
                const data = await res.json();
                showAlert(data.message, !res.ok);
                if (res.ok) { setTimeout(() => window.location.href = '/login', 2500); } 
                else { btn.disabled = false; btnText.innerText = 'Jelszó frissítése'; }
            } catch(err) { showAlert('Hiba történt a kommunikációban.', true); btn.disabled = false; btnText.innerText = 'Jelszó frissítése'; }
        });
    </script>
</body>
</html>