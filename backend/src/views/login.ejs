<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <style> 
        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap');
        body { background-color: #010a13; color: #f0e6d2; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; } 
        .esport-font { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        .hex-bg { background-image: radial-gradient(circle at center, #091428 0%, #010a13 100%); }
    </style>
</head>
<body class="hex-bg min-h-screen flex items-center justify-center p-4">

    <div class="max-w-md w-full bg-[#091428] border border-[#c8aa6e]/50 p-8 rounded-sm shadow-[0_0_50px_rgba(200,170,110,0.15)] relative overflow-hidden">
        
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#c8aa6e] opacity-5 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-blue-500 opacity-5 rounded-full blur-3xl pointer-events-none"></div>

        <div id="alertBox" class="hidden mb-6 p-4 rounded-sm border text-sm text-center font-bold tracking-wide transition-all duration-300"></div>

        <div id="loginSection" class="block">
            <div class="text-center mb-8">
                <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font">Worlds Mayhem</h1>
                <p class="text-slate-400 mt-2 uppercase tracking-widest text-xs font-bold">Felhasználói hozzáférés</p>
            </div>

            <form id="loginForm" class="space-y-5">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="loginEmail" required class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors placeholder-slate-600" placeholder="hello@worldsmayhem.com">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1.5">
                        <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest">Jelszó</label>
                        <a href="#" onclick="showSection('forgotSection')" class="text-[0.65rem] text-slate-400 hover:text-[#c8aa6e] uppercase tracking-widest font-bold transition-colors">Elfelejtett jelszó?</a>
                    </div>
                    <input type="password" id="loginPassword" required class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <button type="submit" id="btnLogin" class="w-full bg-[#c8aa6e] hover:bg-[#f0e6d2] text-[#010a13] font-black uppercase tracking-widest text-lg px-6 py-3.5 rounded-sm transition-all shadow-lg hover:shadow-[0_0_15px_rgba(200,170,110,0.4)] mt-4">Belépés az arénába</button>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6">Nincs még fiókod? <a href="#" onclick="showSection('registerSection')" class="text-[#c8aa6e] hover:text-[#f0e6d2] font-bold transition-colors">Regisztráció</a></p>
        </div>

        <div id="registerSection" class="hidden">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#c8aa6e] to-[#f0e6d2] tracking-wider esport-font">Új felhasználó</h1>
                <p class="text-slate-400 mt-2 uppercase tracking-widest text-xs font-bold">Készítsd el a fiókod</p>
            </div>

            <form id="registerForm" class="space-y-4">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Felhasználónév</label>
                    <input type="text" id="regUsername" required minlength="3" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors" placeholder="Felhasználóneved">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="regEmail" required class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Jelszó</label>
                    <input type="password" id="regPassword" required minlength="6" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Jelszó megerősítése</label>
                    <input type="password" id="regConfirmPassword" required minlength="6" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <button type="submit" id="btnRegister" class="w-full bg-[#c8aa6e] hover:bg-[#f0e6d2] text-[#010a13] font-black uppercase tracking-widest text-lg px-6 py-3.5 rounded-sm transition-all shadow-lg hover:shadow-[0_0_15px_rgba(200,170,110,0.4)] mt-4">Fiók létrehozása</button>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6">Már van fiókod? <a href="#" onclick="showSection('loginSection')" class="text-[#c8aa6e] hover:text-[#f0e6d2] font-bold transition-colors">Belépés</a></p>
        </div>

        <div id="forgotSection" class="hidden">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black text-[#c8aa6e] tracking-wider esport-font">Elfelejtett jelszó</h1>
                <p class="text-slate-400 mt-2 text-sm">Add meg az e-mail címed, és küldünk egy linket a jelszavad visszaállításához.</p>
            </div>

            <form id="forgotForm" class="space-y-5">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">E-mail cím</label>
                    <input type="email" id="forgotEmail" required class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <button type="submit" id="btnForgot" class="w-full bg-[#c8aa6e] hover:bg-[#f0e6d2] text-[#010a13] font-black uppercase tracking-widest text-lg px-6 py-3.5 rounded-sm transition-all shadow-lg hover:shadow-[0_0_15px_rgba(200,170,110,0.4)] mt-4">Link küldése</button>
            </form>

            <p class="text-center text-slate-400 text-sm mt-6"><a href="#" onclick="showSection('loginSection')" class="text-slate-500 hover:text-[#f0e6d2] font-bold transition-colors">← Vissza a belépéshez</a></p>
        </div>

        <div id="resetSection" class="hidden">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black text-[#c8aa6e] tracking-wider esport-font">Új jelszó megadása</h1>
                <p class="text-slate-400 mt-2 text-sm">Állítsd be a fiókod új jelszavát.</p>
            </div>

            <form id="resetForm" class="space-y-5">
                <input type="hidden" id="resetTokenInput">
                <div>
                    <label class="block text-[0.65rem] font-bold text-[#c8aa6e] uppercase tracking-widest mb-1.5">Új jelszó</label>
                    <input type="password" id="resetNewPassword" required minlength="6" class="w-full bg-[#010a13] border border-[#c8aa6e]/30 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-[#c8aa6e] transition-colors">
                </div>
                <button type="submit" id="btnReset" class="w-full bg-[#c8aa6e] hover:bg-[#f0e6d2] text-[#010a13] font-black uppercase tracking-widest text-lg px-6 py-3.5 rounded-sm transition-all shadow-lg hover:shadow-[0_0_15px_rgba(200,170,110,0.4)] mt-4">Jelszó frissítése</button>
            </form>
        </div>

    </div>

    <script>
        const alertBox = document.getElementById('alertBox');

        function showAlert(msg, isError = false) {
            alertBox.innerHTML = msg;
            alertBox.classList.remove('hidden', 'bg-red-950/40', 'border-red-500/50', 'text-red-400', 'bg-emerald-950/40', 'border-emerald-500/50', 'text-emerald-400');
            if (isError) {
                alertBox.classList.add('bg-red-950/40', 'border-red-500/50', 'text-red-400');
            } else {
                alertBox.classList.add('bg-emerald-950/40', 'border-emerald-500/50', 'text-emerald-400');
            }
        }

        function showSection(sectionId) {
            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('registerSection').classList.add('hidden');
            document.getElementById('forgotSection').classList.add('hidden');
            document.getElementById('resetSection').classList.add('hidden');
            alertBox.classList.add('hidden');
            
            document.getElementById(sectionId).classList.remove('hidden');
        }

        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const token = urlParams.get('reset_token');
            if (token) {
                document.getElementById('resetTokenInput').value = token;
                showSection('resetSection');
            }
        });

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnLogin'); btn.disabled = true; btn.innerText = 'Betöltés...';
            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('loginEmail').value, password: document.getElementById('loginPassword').value })
                });
                const data = await res.json();
                if (!res.ok) { showAlert(data.message, true); btn.disabled = false; btn.innerText = 'Belépés az arénába'; } 
                else { window.location.href = '/dashboard'; }
            } catch(err) { showAlert('Hálózati hiba történt.', true); btn.disabled = false; btn.innerText = 'Belépés az arénába'; }
        });

        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const password = document.getElementById('regPassword').value;
            const confirmPassword = document.getElementById('regConfirmPassword').value;
            
            if (password !== confirmPassword) {
                return showAlert('A megadott jelszavak nem egyeznek!', true);
            }

            const btn = document.getElementById('btnRegister'); btn.disabled = true; btn.innerText = 'Betöltés...';
            try {
                const res = await fetch('/api/auth/register', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('regUsername').value,
                        email: document.getElementById('regEmail').value,
                        password: password,
                        confirmPassword: confirmPassword
                    })
                });
                const data = await res.json();
                if (!res.ok) { showAlert(data.message, true); btn.disabled = false; btn.innerText = 'Fiók létrehozása'; } 
                else { window.location.href = '/dashboard'; }
            } catch(err) { showAlert('Hálózati hiba történt.', true); btn.disabled = false; btn.innerText = 'Fiók létrehozása'; }
        });

        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnForgot'); btn.disabled = true; btn.innerText = 'Küldés...';
            try {
                const res = await fetch('/api/auth/forgot-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('forgotEmail').value })
                });
                const data = await res.json();
                if (!res.ok) { 
                    showAlert(data.message, true); 
                    btn.disabled = false; btn.innerText = 'Link küldése';
                } else { 
                    showAlert(data.message, false);
                    document.getElementById('forgotForm').reset();
                    btn.disabled = false; btn.innerText = 'Link küldése';
                }
            } catch(err) { showAlert('Hálózati hiba történt.', true); btn.disabled = false; btn.innerText = 'Link küldése'; }
        });

        document.getElementById('resetForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnReset'); btn.disabled = true; btn.innerText = 'Frissítés...';
            try {
                const res = await fetch('/api/auth/reset-password', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        token: document.getElementById('resetTokenInput').value,
                        newPassword: document.getElementById('resetNewPassword').value
                    })
                });
                const data = await res.json();
                if (!res.ok) { 
                    showAlert(data.message, true); 
                    btn.disabled = false; btn.innerText = 'Jelszó frissítése';
                } else { 
                    showAlert(data.message, false);
                    setTimeout(() => window.location.href = '/login', 2500);
                }
            } catch(err) { showAlert('Hálózati hiba történt.', true); btn.disabled = false; btn.innerText = 'Jelszó frissítése'; }
        });
    </script>
</body>
</html>
